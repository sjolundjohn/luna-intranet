---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import SectionCard from "~/components/SectionCard.astro";
---

<BaseLayout
  title="Learn"
  description="Where to find context — vision, governance, onboarding, the roadmap, and the technical platform docs."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Learn" size="compact" animateMoons={false}>
    <Fragment slot="headline">
      The context layer.
    </Fragment>
    <Fragment slot="subcopy">
      Why we're building this, how it's governed, how to get started,
      what's coming next, and how it actually works under the hood.
      Pick the page that matches your question.
    </Fragment>
  </Hero>

  <WhiteSection size="tall">
    <div class="max-w-[760px] mb-10">
      <p class="eyebrow mb-3">Six places</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 38px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Read in any order.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
    </div>

    <div class="grid gap-6 md:gap-7 md:grid-cols-2 auto-rows-fr">
      <SectionCard
        href="/vision"
        eyebrow="01 · Vision"
        title="Why we're building this."
        description="The principle behind Luna's AI workplace, what's changing for the team, and the fears we built around — with the design choices that respond to each one."
      />
      <SectionCard
        href="/governance"
        eyebrow="02 · Governance"
        title="How it's scoped, audited, and stopped."
        description="Roles, permissions, kill-switches, audit log, cost caps, PHI scope, and change control — written down because trust compounds."
      />
      <SectionCard
        href="/onboarding"
        eyebrow="03 · Onboarding"
        title="Pick your path."
        description="Five role-specific tracks. Twenty minutes each. The first module on every track is the same: what we're not asking you to do."
      />
      <SectionCard
        href="/roadmap"
        eyebrow="04 · Roadmap"
        title="What's shipped, next, and deferred."
        description="The honest view: what's in flight, what's queued, and what we're parking on purpose. If a control isn't here, it isn't shipped."
      />
      <SectionCard
        href="/org"
        eyebrow="05 · Org chart"
        title="Who works on what."
        description="Agents and Lunites by team and by person. See which agents each function uses and who owns each one."
      />
      <SectionCard
        href="/platform"
        eyebrow="06 · Platform"
        title="Under the hood."
        description="Tech stack, request flow, and architecture — the actual Cloudflare-native plumbing that makes the rest possible."
      />
    </div>
  </WhiteSection>
</BaseLayout>
