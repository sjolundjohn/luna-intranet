---
import "~/styles/ios-tokens.css";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import ScreenRenderer from "~/components/ux/ScreenRenderer.astro";
import StatusBadge from "~/components/ux/StatusBadge.astro";
import { SCREENS, byFeature, features, STATUS_ORDER, FEATURE_BRDS, SUPPORTING_DOCS } from "~/lib/ux-review";

const featureGroups = byFeature();
const THUMB_SCALE = 0.46;
---

<BaseLayout
  title="Internal UX/UI Review"
  description="Review the Luna iOS app wireframes and leave comments before Figma export."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · iOS app" size="compact" animateMoons={false}>
    <Fragment slot="headline">Internal UX/UI Review</Fragment>
    <Fragment slot="subcopy">
      Review every wireframe holistically and leave Google-Docs-style comments —
      pinned to the spot you mean — across each design cycle, before we export to Figma.
    </Fragment>
    <Fragment slot="cta">
      <div class="flex flex-wrap gap-3">
        <a
          href="/tools/ux-review/review"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-moonlight text-midnight font-body text-[14px] font-semibold hover:opacity-90 transition-opacity"
        >
          Open the review dashboard
          <span data-total-open class="inline-flex items-center justify-center min-w-[20px] h-[20px] px-1.5 rounded-full bg-midnight text-white text-[11px] font-bold" hidden></span>
        </a>
        <a
          href="/tools/ux-review/design-system"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-white/30 text-white font-body text-[14px] font-medium hover:bg-white/10 transition-colors"
        >
          Design system
        </a>
      </div>
    </Fragment>
  </Hero>

  <WhiteSection size="compact">
    {/* Controls */}
    <div class="flex flex-wrap items-end justify-between gap-4 mb-8">
      <div>
        <p class="eyebrow mb-2">Screens</p>
        <h2 class="font-display text-ink font-normal" style="font-size: clamp(24px,3vw,32px); line-height:1.05; letter-spacing:-0.02em;">
          {SCREENS.length} screens in review
        </h2>
        <div class="mt-3"><MoonlightRule width={40} color="midnight" /></div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        {/* View toggle */}
        <div class="inline-flex rounded-full border border-border-default p-0.5" role="tablist" aria-label="View">
          <button data-view-btn="all" class="ux-view-btn px-3 py-1.5 rounded-full text-[13px] font-medium" aria-selected="true">All screens</button>
          <button data-view-btn="feature" class="ux-view-btn px-3 py-1.5 rounded-full text-[13px] font-medium" aria-selected="false">By feature</button>
        </div>

        {/* Filters */}
        <label class="sr-only" for="f-status">Status</label>
        <select id="f-status" data-filter="status" class="ux-select">
          <option value="">All statuses</option>
          {STATUS_ORDER.map((s) => <option value={s}>{s}</option>)}
          <option value="__has_comments">Has comments</option>
        </select>

        <label class="sr-only" for="f-feature">Feature</label>
        <select id="f-feature" data-filter="feature" class="ux-select">
          <option value="">All features</option>
          {features().map((f) => <option value={f}>{f}</option>)}
        </select>
      </div>
    </div>

    {/* All Screens — flat grid */}
    <div data-view-panel="all" class="ux-grid">
      {SCREENS.map((s) => (
        <a
          href={`/tools/ux-review/${s.id}`}
          class="ux-card"
          data-screen-card
          data-status={s.status}
          data-feature={s.feature}
        >
          <div class="ux-card-thumb ux-ios">
            <ScreenRenderer id={s.id} mode="thumb" scale={THUMB_SCALE} />
          </div>
          <div class="ux-card-meta">
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="font-body text-[15px] font-semibold text-ink leading-tight">{s.title}</h3>
              <StatusBadge status={s.status} />
              <span data-count-for={s.id} class="ux-count" hidden></span>
            </div>
            <p class="mt-1 text-slate text-[12px]">{s.feature}</p>
          </div>
        </a>
      ))}
    </div>

    {/* By Feature — grouped */}
    <div data-view-panel="feature" hidden>
      {featureGroups.map((group) => (
        <section class="ux-feature-group" data-feature-group={group.feature}>
          <div class="flex items-center gap-3 mb-4 mt-2">
            <h3 class="font-body text-[16px] font-semibold text-ink">{group.feature}</h3>
            <span class="text-slate text-[12px]">{group.screens.length} screen{group.screens.length === 1 ? "" : "s"}</span>
            <div class="flex-1 border-t border-border-subtle"></div>
          </div>
          <div class="ux-grid">
            {group.screens.map((s) => (
              <a
                href={`/tools/ux-review/${s.id}`}
                class="ux-card"
                data-screen-card
                data-status={s.status}
                data-feature={s.feature}
              >
                <div class="ux-card-thumb ux-ios">
                  <ScreenRenderer id={s.id} mode="thumb" scale={THUMB_SCALE} />
                </div>
                <div class="ux-card-meta">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h3 class="font-body text-[15px] font-semibold text-ink leading-tight">{s.title}</h3>
                    <StatusBadge status={s.status} />
                    <span data-count-for={s.id} class="ux-count" hidden></span>
                  </div>
                  <p class="mt-1 text-slate text-[12px]">{s.feature}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <p data-empty class="text-slate text-[14px] py-10 text-center" hidden>No screens match these filters.</p>
  </WhiteSection>

  {/* Program reference — the BRDs and source docs, one place for engineering. */}
  <WhiteSection size="compact" class="bg-soft-paper">
    <div class="mb-6">
      <p class="eyebrow mb-2">Reference</p>
      <h2 class="font-body text-ink font-bold text-[20px]">BRDs &amp; program docs</h2>
      <p class="mt-2 text-slate text-[13px] max-w-[60ch]">Each screen's detail page links its feature BRD. The full set lives on Google Drive:</p>
    </div>
    <div class="grid gap-3 md:grid-cols-2">
      {Object.entries(FEATURE_BRDS).map(([feature, b]) => (
        <a href={b.url} target="_blank" rel="noopener" class="ux-ref">
          <span class="ux-ref-eyebrow">BRD · {feature}</span>
          <span class="ux-ref-title">{b.title}</span>
        </a>
      ))}
      {SUPPORTING_DOCS.map((d) => (
        <a href={d.url} target="_blank" rel="noopener" class="ux-ref">
          <span class="ux-ref-eyebrow">Reference</span>
          <span class="ux-ref-title">{d.title}</span>
          <span class="ux-ref-desc">{d.desc}</span>
        </a>
      ))}
    </div>
  </WhiteSection>
</BaseLayout>

<style>
  .ux-select {
    height: 34px;
    padding: 0 10px;
    border: 1px solid var(--color-border-default);
    border-radius: 999px;
    font-size: 13px;
    color: var(--color-ink);
    background: var(--color-white);
  }
  .ux-view-btn { color: var(--color-graphite); }
  .ux-view-btn[aria-selected="true"] { background: var(--color-midnight); color: #fff; }

  .ux-ref {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 14px 16px;
    background: var(--color-white);
    border: 1px solid var(--color-border-subtle);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 150ms, box-shadow 150ms;
  }
  .ux-ref:hover { border-color: var(--color-ink); box-shadow: 0 6px 24px rgba(4, 30, 66, 0.06); }
  .ux-ref-eyebrow { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-moonlight-deep); }
  .ux-ref-title { font-size: 14px; font-weight: 600; color: var(--color-ink); line-height: 1.35; }
  .ux-ref-desc { font-size: 12px; color: var(--color-slate); line-height: 1.45; }

  .ux-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 20px;
  }
  .ux-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-subtle);
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-cloud-lilac);
    transition: border-color 150ms, box-shadow 150ms;
  }
  .ux-card:hover {
    border-color: var(--color-ink);
    box-shadow: 0 8px 32px rgba(4, 30, 66, 0.08);
  }
  .ux-card-thumb {
    display: flex;
    justify-content: center;
    padding: 18px 18px 0;
    /* Thumbnails are previews — clicks fall through to the card link. */
    pointer-events: none;
  }
  .ux-card-meta {
    padding: 12px 14px 14px;
    background: var(--color-white);
    border-top: 1px solid var(--color-border-subtle);
  }
  .ux-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 999px;
    background: var(--color-critical-bg);
    color: var(--color-critical-ink);
    font-size: 11px;
    font-weight: 700;
  }
  .ux-feature-group { margin-bottom: 36px; }
</style>

<script>
  function setup() {
    const root = document.querySelector('[data-view-panel="all"]')?.closest("section");
    if (!root) return;

    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-screen-card]"));
    const selects = Array.from(document.querySelectorAll("[data-filter]"));
    const emptyMsg = document.querySelector<HTMLElement>("[data-empty]");
    const panels = {
      all: document.querySelector<HTMLElement>('[data-view-panel="all"]'),
      feature: document.querySelector<HTMLElement>('[data-view-panel="feature"]'),
    };
    const viewBtns = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-view-btn]"));

    function applyFilters() {
      const val = (sel: string) =>
        (document.querySelector(sel) as unknown as HTMLSelectElement | null)?.value || "";
      const f = {
        status: val('[data-filter="status"]'),
        feature: val('[data-filter="feature"]'),
      };
      let visible = 0;
      cards.forEach((c) => {
        const statusOk =
          !f.status ||
          (f.status === "__has_comments"
            ? c.dataset.hasComments === "true"
            : c.dataset.status === f.status);
        const ok = statusOk && (!f.feature || c.dataset.feature === f.feature);
        c.style.display = ok ? "" : "none";
        if (ok) visible++;
      });
      // Hide empty feature groups.
      document.querySelectorAll<HTMLElement>("[data-feature-group]").forEach((g) => {
        const anyVisible = Array.from(g.querySelectorAll<HTMLElement>("[data-screen-card]")).some(
          (c) => c.style.display !== "none",
        );
        g.style.display = anyVisible ? "" : "none";
      });
      if (emptyMsg) emptyMsg.hidden = visible !== 0;
    }

    selects.forEach((s) => s.addEventListener("change", applyFilters));

    viewBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const view = btn.dataset.viewBtn as "all" | "feature";
        viewBtns.forEach((b) => b.setAttribute("aria-selected", b === btn ? "true" : "false"));
        if (panels.all) panels.all.hidden = view !== "all";
        if (panels.feature) panels.feature.hidden = view !== "feature";
      });
    });

    // Hydrate unresolved counts from the comments store.
    fetch("/api/comments/unresolved")
      .then((r) => (r.ok ? r.json() : null))
      .then((data: any) => {
        if (!data?.countsByScreen) return;
        const counts = data.countsByScreen as Record<string, number>;
        let total = 0;
        document.querySelectorAll<HTMLElement>("[data-count-for]").forEach((el) => {
          const n = counts[el.dataset.countFor || ""] || 0;
          const card = el.closest<HTMLElement>("[data-screen-card]");
          if (n > 0) {
            el.textContent = `${n} open`;
            el.hidden = false;
            if (card) card.dataset.hasComments = "true";
          }
        });
        // Re-apply so the "Has comments" filter reflects freshly-loaded counts.
        applyFilters();
        total = Object.values(counts).reduce((a, b) => a + b, 0);
        const totalEl = document.querySelector<HTMLElement>("[data-total-open]");
        if (totalEl && total > 0) {
          totalEl.textContent = String(total);
          totalEl.hidden = false;
        }
      })
      .catch(() => {});

    applyFilters();
  }
  setup();
  document.addEventListener("astro:page-load", setup);
</script>
