---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import { coldBrew, kombucha, KEG_CATALOG, KEG_ORDER_EMAIL } from "~/lib/kegjoy";

const sections = [
  { key: "coldbrew", label: "Cold brew", items: coldBrew },
  { key: "kombucha", label: "Kombucha", items: kombucha },
] as const;

// Catalog the client needs to build the order email + winning labels.
const catalogForClient = KEG_CATALOG.map((i) => ({ id: i.id, name: i.name, category: i.category }));
---

<BaseLayout
  title="Kegerator"
  description="Vote on the next office cold brew and kombucha — and reorder the keg in one click."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Tools" size="compact" animateMoons={false}>
    <Fragment slot="headline">
      Keep the taps full.
    </Fragment>
    <Fragment slot="subcopy">
      Upvote the cold brew and kombucha you want on tap next. When the keg runs
      dry, the winners get reordered from Kegjoy in one click.
    </Fragment>
  </Hero>

  <WhiteSection size="compact">
    {/* Winning + make-order bar */}
    <div class="keg-bar">
      <div class="keg-winning">
        <p class="eyebrow mb-2">Winning right now</p>
        <div class="flex flex-wrap gap-x-8 gap-y-2">
          <p class="text-ink text-[15px]">
            <span class="text-slate">Cold brew:</span>
            <span class="font-semibold" data-win="coldbrew">—</span>
          </p>
          <p class="text-ink text-[15px]">
            <span class="text-slate">Kombucha:</span>
            <span class="font-semibold" data-win="kombucha">—</span>
          </p>
        </div>
      </div>
      <button type="button" data-make-order class="keg-order-btn" hidden>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h2l2.5 12h9l2-8H7"/><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/>
        </svg>
        Make order &amp; clear
      </button>
    </div>

    <p data-keg-note class="text-slate text-[13px] mb-6" hidden></p>

    {sections.map((section) => (
      <section class="mb-10" data-section={section.key}>
        <div class="mb-4 flex items-center gap-3">
          <h2 class="font-body text-ink font-bold text-[20px]">{section.label}</h2>
          <div class="flex-1"><MoonlightRule width={32} color="midnight" /></div>
        </div>
        <div class="grid gap-3" data-cards={section.key}>
          {section.items.map((i) => (
            <article class="keg-card" data-item data-id={i.id} data-category={i.category} data-name={i.name}>
              <div class="min-w-0 flex-1">
                <h3 class="font-body text-ink font-semibold text-[16px] leading-tight">{i.name}</h3>
                <p class="mt-1 text-graphite text-[13px] leading-[1.5]">{i.description}</p>
              </div>
              <div class="keg-vote">
                <button type="button" data-vote="up" aria-label={`Upvote ${i.name}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 15l6-6 6 6"/></svg>
                </button>
                <span class="keg-score" data-score>0</span>
                <button type="button" data-vote="down" aria-label={`Downvote ${i.name}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </button>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </WhiteSection>

  <script is:inline type="application/json" data-keg-catalog set:html={JSON.stringify(catalogForClient)}></script>
  <script is:inline define:vars={{ ORDER_EMAIL: KEG_ORDER_EMAIL }}>
    window.__KEG_ORDER_EMAIL = ORDER_EMAIL;
  </script>
</BaseLayout>

<style>
  .keg-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    padding: 18px 20px;
    margin-bottom: 28px;
    background: var(--color-soft-paper);
    border: 1px solid var(--color-border-subtle);
    border-radius: 16px;
  }
  .keg-order-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 999px;
    background: var(--color-midnight);
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 150ms;
  }
  .keg-order-btn:hover { background: var(--color-midnight-deep); }

  .keg-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 18px;
    background: #fff;
    border: 1px solid var(--color-border-subtle);
    border-radius: 14px;
    transition: border-color 150ms, box-shadow 150ms;
  }
  .keg-card:hover { box-shadow: 0 6px 24px rgba(4, 30, 66, 0.06); }

  .keg-vote {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: none;
  }
  .keg-vote button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid var(--color-border-default);
    background: #fff;
    color: var(--color-graphite);
    cursor: pointer;
    transition: all 130ms;
  }
  .keg-vote button:hover { border-color: var(--color-ink); color: var(--color-ink); }
  .keg-card[data-mine="up"] [data-vote="up"] {
    background: var(--color-moonlight);
    border-color: var(--color-moonlight);
    color: var(--color-midnight);
  }
  .keg-card[data-mine="down"] [data-vote="down"] {
    background: var(--color-periwinkle-mist);
    border-color: var(--color-border-strong);
    color: var(--color-ink);
  }
  .keg-score {
    min-width: 28px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 700;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  type Scores = Record<string, { score: number; up: number; down: number }>;
  type CatalogItem = { id: string; name: string; category: "coldbrew" | "kombucha" };

  function setupKeg() {
    if (!document.querySelector("[data-item]")) return;

    const catalogEl = document.querySelector<HTMLElement>("[data-keg-catalog]");
    const catalog: CatalogItem[] = catalogEl ? JSON.parse(catalogEl.textContent || "[]") : [];
    const orderEmail: string = (window as any).__KEG_ORDER_EMAIL || "ordersvista@kegjoy.com";
    const note = document.querySelector<HTMLElement>("[data-keg-note]");
    const makeOrderBtn = document.querySelector<HTMLButtonElement>("[data-make-order]");

    let scores: Scores = {};
    let mine: Record<string, number> = {};

    const cards = () => Array.from(document.querySelectorAll<HTMLElement>("[data-item]"));
    const nameOf = (id: string) => catalog.find((c) => c.id === id)?.name || id;

    function topOf(category: "coldbrew" | "kombucha"): { id: string; score: number } | null {
      const ids = catalog.filter((c) => c.category === category).map((c) => c.id);
      let best: { id: string; score: number } | null = null;
      for (const id of ids) {
        const s = scores[id]?.score ?? 0;
        if (best === null || s > best.score) best = { id, score: s };
      }
      // Only call it a winner if someone actually voted it up.
      return best && best.score > 0 ? best : null;
    }

    function render() {
      // per-card score + my-vote highlight
      cards().forEach((card) => {
        const id = card.dataset.id!;
        const s = scores[id]?.score ?? 0;
        card.querySelector<HTMLElement>("[data-score]")!.textContent = String(s);
        const v = mine[id];
        if (v === 1) card.dataset.mine = "up";
        else if (v === -1) card.dataset.mine = "down";
        else delete card.dataset.mine;
      });
      // re-rank each section by score desc (stable-ish: keep catalog order on ties)
      (["coldbrew", "kombucha"] as const).forEach((cat) => {
        const container = document.querySelector<HTMLElement>(`[data-cards="${cat}"]`);
        if (!container) return;
        const items = Array.from(container.querySelectorAll<HTMLElement>("[data-item]"));
        items
          .sort((a, b) => (scores[b.dataset.id!]?.score ?? 0) - (scores[a.dataset.id!]?.score ?? 0))
          .forEach((el) => container.appendChild(el));
      });
      // winning labels
      (["coldbrew", "kombucha"] as const).forEach((cat) => {
        const el = document.querySelector<HTMLElement>(`[data-win="${cat}"]`);
        if (!el) return;
        const top = topOf(cat);
        el.textContent = top ? `${nameOf(top.id)} (+${top.score})` : "—";
      });
    }

    async function load() {
      try {
        const r = await fetch("/api/keg/votes");
        if (!r.ok) throw new Error(String(r.status));
        const data = (await r.json()) as { scores: Scores; mine: Record<string, number> };
        scores = data.scores || {};
        mine = data.mine || {};
        if (note) note.hidden = true;
        render();
      } catch {
        if (note) {
          note.textContent = "Voting is offline — the store isn't configured yet.";
          note.hidden = false;
        }
      }
    }

    async function vote(id: string, value: 1 | -1 | 0) {
      try {
        const r = await fetch("/api/keg/vote", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ itemId: id, value }),
        });
        if (!r.ok) throw new Error(String(r.status));
        await load();
      } catch {
        if (note) {
          note.textContent = "Couldn't record that vote — try again.";
          note.hidden = false;
        }
      }
    }

    cards().forEach((card) => {
      const id = card.dataset.id!;
      card.querySelector('[data-vote="up"]')!.addEventListener("click", () => {
        vote(id, mine[id] === 1 ? 0 : 1);
      });
      card.querySelector('[data-vote="down"]')!.addEventListener("click", () => {
        vote(id, mine[id] === -1 ? 0 : -1);
      });
    });

    // Admin-only Make Order: build the mailto, then clear the queue.
    fetch("/api/whoami")
      .then((r) => (r.ok ? r.json() : null))
      .then((d: any) => { if (d?.isAdmin && makeOrderBtn) makeOrderBtn.hidden = false; })
      .catch(() => {});

    // Build a Gmail web compose URL (new tab) — independent of the OS default
    // mail client. Uses whichever Google account is currently active.
    function buildComposeUrl(): string {
      const cb = topOf("coldbrew");
      const kb = topOf("kombucha");
      const lines = ["Hi Kegjoy team,", "", "We'd like to reorder for the Luna office:", ""];
      lines.push(`Cold brew: ${cb ? nameOf(cb.id) : "(no votes yet — please leave as-is)"}`);
      lines.push(`Kombucha: ${kb ? nameOf(kb.id) : "(no votes yet — please leave as-is)"}`);
      lines.push("", "Thanks,", "Luna");
      const subject = "Luna office keg reorder";
      const q = new URLSearchParams({
        view: "cm",
        fs: "1",
        to: orderEmail,
        su: subject,
        body: lines.join("\n"),
      });
      return `https://mail.google.com/mail/?${q.toString()}`;
    }

    makeOrderBtn?.addEventListener("click", async () => {
      // Open the prefilled Gmail draft in a new tab (editable before sending).
      // Done synchronously in the click handler so the pop-up isn't blocked.
      window.open(buildComposeUrl(), "_blank", "noopener");
      // Clear the queue for the next round (kegerator tab stays put).
      try {
        await fetch("/api/keg/order", { method: "POST" });
        await load();
      } catch {
        /* draft already opened; clearing is best-effort */
      }
    });

    load();
  }

  setupKeg();
  document.addEventListener("astro:page-load", setupKeg);
</script>
