---
/**
 * Internal QA route — every component in every variant on one page.
 * Compare side-by-side with docs/brand/luna-design-system-v1.0.pdf.
 * Not linked from anywhere. Direct-URL only.
 */
import BaseLayout from "~/layouts/BaseLayout.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MidnightBand from "~/components/MidnightBand.astro";
import Hero from "~/components/Hero.astro";
import CTAButton from "~/components/CTAButton.astro";
import StatusChip from "~/components/StatusChip.astro";
import Alert from "~/components/Alert.astro";
import MoonPhases from "~/components/MoonPhases.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import Prose from "~/components/Prose.astro";
import RoleBadge from "~/components/RoleBadge.astro";
import FearAndAnswer from "~/components/FearAndAnswer.astro";
import CostMeter from "~/components/CostMeter.astro";
import AuditRow from "~/components/AuditRow.astro";
import WorkflowRunRow from "~/components/WorkflowRunRow.astro";
import WorkflowStepList from "~/components/WorkflowStepList.astro";
import FleetTile from "~/components/FleetTile.astro";
import WorkflowCard from "~/components/WorkflowCard.astro";
import OnboardingPath from "~/components/OnboardingPath.astro";
import KillSwitchButton from "~/components/KillSwitchButton.astro";
import BriefingPlayer from "~/components/BriefingPlayer.astro";
import AgentConfigCard from "~/components/AgentConfigCard.astro";
import MemoryViewer from "~/components/MemoryViewer.astro";

const primaryColors = [
  { name: "Midnight", hex: "#041E42", var: "--color-midnight" },
  { name: "Moonlight", hex: "#68D2DF", var: "--color-moonlight" },
  { name: "White", hex: "#FFFFFF", var: "--color-white" },
];

const moonlightTints = [
  { name: "Midnight Deep", hex: "#133465" },
  { name: "Midnight Soft", hex: "#0F1C40" },
  { name: "Moonlight Deep", hex: "#0A9AAE" },
  { name: "Moonlight Ice", hex: "#C9F8FE" },
  { name: "Moonlight Tint", hex: "#E8FCFF" },
];

const neutrals = [
  { name: "White", hex: "#FFFFFF" },
  { name: "Soft Paper", hex: "#FBFDFE" },
  { name: "Cloud Lilac", hex: "#F2F3FA" },
  { name: "Periwinkle Mist", hex: "#E7EBF8" },
  { name: "Lunar Lavender", hex: "#D6D3E9" },
  { name: "Pebble Blue", hex: "#BAC4D9" },
  { name: "Slate", hex: "#7A8892" },
];

const inkScale = [
  { name: "Ink", hex: "#041E42" },
  { name: "Graphite", hex: "#535D65" },
  { name: "Slate", hex: "#7A8892" },
  { name: "Disabled", hex: "#BAC4D9" },
  { name: "On-dark sub", hex: "#ACC1DF" },
];

const alerts = [
  { level: "success", text: "You're on the early-access list. We'll email you when a device is ready." },
  { level: "info", text: "Luna is FDA-pending. Shipping to limited pilot sites only." },
  { level: "warning", text: "Your reservoir runs out in about 2 hours." },
  { level: "critical", text: "That email isn't valid — please check and try again." },
] as const;
---

<BaseLayout title="Styleguide" description="Visual QA for the Luna design system" heroIsDark={true}>
  <Hero eyebrow="QA · Not linked" size="compact">
    <Fragment slot="headline">Styleguide.</Fragment>
    <Fragment slot="subcopy">
      Every component, every variant, keyed to the Luna Design System v1.0 handoff.
      If anything here drifts from the PDF, the code is wrong — not the PDF.
    </Fragment>
  </Hero>

  <WhiteSection size="tall">
    {/* Typography scale */}
    <h2 class="font-body text-[28px] font-bold text-ink">Typography</h2>
    <p class="mt-2 text-graphite">Display = D-DIN. Everything else = Inter.</p>
    <MoonlightRule width={40} color="midnight" class="mt-4" />

    <div class="mt-10 space-y-6">
      <div>
        <p class="eyebrow mb-2">Display · D-DIN 96</p>
        <p class="font-display text-ink" style="font-size: 96px; line-height: 1.05; letter-spacing: -0.025em;">Luna</p>
      </div>
      <div>
        <p class="eyebrow mb-2">Page title · D-DIN 48</p>
        <p class="font-display text-ink" style="font-size: 48px; line-height: 1.1; letter-spacing: -0.02em;">How it works.</p>
      </div>
      <div>
        <p class="eyebrow mb-2">H1 · Inter 32 / 700</p>
        <p class="text-ink" style="font-size: 32px; line-height: 1.15; font-weight: 700;">Screen title</p>
      </div>
      <div>
        <p class="eyebrow mb-2">H2 · Inter 28 / 700</p>
        <p class="text-ink" style="font-size: 28px; line-height: 1.2; font-weight: 700;">Section heading</p>
      </div>
      <div>
        <p class="eyebrow mb-2">H3 · Inter 20 / 600</p>
        <p class="text-ink" style="font-size: 20px; line-height: 1.3; font-weight: 600;">Card title</p>
      </div>
      <div>
        <p class="eyebrow mb-2">Body · Inter 17 / 1.6</p>
        <p class="text-graphite max-w-[65ch]">The quick brown fox jumps over the lazy dog. 0123456789.</p>
      </div>
    </div>

    {/* Colors */}
    <h2 class="mt-20 font-body text-[28px] font-bold text-ink">Primary colors</h2>
    <MoonlightRule width={40} color="midnight" class="mt-4" />
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {primaryColors.map((c) => (
        <div class="rounded-[16px] border border-border-subtle overflow-hidden">
          <div class="h-32" style={`background:${c.hex}`}></div>
          <div class="p-5">
            <p class="text-ink font-semibold">{c.name}</p>
            <p class="mt-1 text-slate text-[13px] font-mono">{c.hex}</p>
          </div>
        </div>
      ))}
    </div>

    <h3 class="mt-14 eyebrow">Moonlight tints · use sparingly</h3>
    <div class="mt-4 grid gap-4 grid-cols-2 md:grid-cols-5">
      {moonlightTints.map((c) => (
        <div class="rounded-[12px] border border-border-subtle overflow-hidden">
          <div class="h-20" style={`background:${c.hex}`}></div>
          <div class="p-3">
            <p class="text-ink text-[14px] font-semibold">{c.name}</p>
            <p class="text-slate text-[12px] font-mono">{c.hex}</p>
          </div>
        </div>
      ))}
    </div>

    <h3 class="mt-14 eyebrow">Neutral scale · supporting cast</h3>
    <div class="mt-4 grid gap-3 grid-cols-2 md:grid-cols-7">
      {neutrals.map((c) => (
        <div class="rounded-[8px] border border-border-subtle overflow-hidden">
          <div class="h-16" style={`background:${c.hex}`}></div>
          <div class="p-2">
            <p class="text-ink text-[12px] font-semibold">{c.name}</p>
            <p class="text-slate text-[11px] font-mono">{c.hex}</p>
          </div>
        </div>
      ))}
    </div>

    <h3 class="mt-14 eyebrow">Text & ink · default on white</h3>
    <div class="mt-4 grid gap-3 grid-cols-2 md:grid-cols-5">
      {inkScale.map((c) => (
        <div class="rounded-[8px] border border-border-subtle overflow-hidden">
          <div class="h-16" style={`background:${c.hex}`}></div>
          <div class="p-2">
            <p class="text-ink text-[12px] font-semibold">{c.name}</p>
            <p class="text-slate text-[11px] font-mono">{c.hex}</p>
          </div>
        </div>
      ))}
    </div>

    {/* Buttons */}
    <h2 class="mt-20 font-body text-[28px] font-bold text-ink">Buttons</h2>
    <p class="mt-2 text-graphite">Pill, 58px radius. 44px min on mobile, 40px on web.</p>
    <MoonlightRule width={40} color="midnight" class="mt-4" />

    <div class="mt-8 p-8 rounded-[16px] bg-white border border-border-subtle flex flex-wrap items-center gap-4">
      <CTAButton variant="primary-light">Get early access</CTAButton>
      <CTAButton variant="secondary">Learn more</CTAButton>
      <CTAButton variant="ghost">Skip</CTAButton>
      <CTAButton variant="primary-light" disabled button>Continue</CTAButton>
    </div>

    <div class="mt-4 p-8 rounded-[16px] bg-midnight flex flex-wrap items-center gap-4">
      <CTAButton variant="primary-dark">Continue</CTAButton>
      <CTAButton variant="secondary" class="!border-white !text-white">Pair again</CTAButton>
    </div>

    {/* Status chips */}
    <h2 class="mt-20 font-body text-[28px] font-bold text-ink">Status chips</h2>
    <MoonlightRule width={40} color="midnight" class="mt-4" />
    <div class="mt-6 flex flex-wrap gap-3">
      <StatusChip status="live" />
      <StatusChip status="coming-soon" />
      <StatusChip status="by-request" />
      <StatusChip status="neutral" label="Paired" />
    </div>

    {/* Alerts */}
    <h2 class="mt-20 font-body text-[28px] font-bold text-ink">Alerts</h2>
    <p class="mt-2 text-graphite">Show one at a time. Critical is plum, not red.</p>
    <MoonlightRule width={40} color="midnight" class="mt-4" />
    <div class="mt-6 space-y-4">
      {alerts.map((a) => (
        <Alert level={a.level}>{a.text}</Alert>
      ))}
    </div>

    {/* Moon phases */}
    <h2 class="mt-20 font-body text-[28px] font-bold text-ink">Moon phases</h2>
    <MoonlightRule width={40} color="midnight" class="mt-4" />
    <div class="mt-6 flex flex-wrap items-center gap-8 p-6 rounded-[16px] border border-border-subtle bg-white">
      <MoonPhases size={18} class="text-midnight" />
      <MoonPhases size={28} class="text-moonlight" />
      <MoonPhases size={44} class="text-midnight" animate />
    </div>

    {/* Prose */}
    <h2 class="mt-20 font-body text-[28px] font-bold text-ink">Prose</h2>
    <MoonlightRule width={40} color="midnight" class="mt-4" />
    <div class="mt-8">
      <Prose>
        <h1>The quick brown fox</h1>
        <p>Paragraph text at Inter 17 with 1.6 leading. Graphite on white. <a href="#">Links look like this</a> and hover changes color.</p>
        <h2>Section heading</h2>
        <p>A second paragraph so the vertical rhythm is visible.</p>
        <ul>
          <li>Bulleted list item with a Moonlight dot.</li>
          <li>Another item to show spacing.</li>
        </ul>
        <h3>Subheading</h3>
        <blockquote>A block quote with the Moonlight bar on the left.</blockquote>
      </Prose>
    </div>
  </WhiteSection>

  {/* AI-platform components — added with the AI workplace expansion. */}
  <WhiteSection size="tall" class="bg-soft-paper">
    <p class="eyebrow">AI Platform · v0.3</p>
    <h2 class="mt-2 font-body text-[28px] font-bold text-ink">Platform components</h2>
    <MoonlightRule width={40} color="midnight" class="mt-4" />

    {/* Role badges */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Role badges</h3>
    <div class="mt-3 flex flex-wrap gap-3">
      <RoleBadge role="employee" />
      <RoleBadge role="manager" />
      <RoleBadge role="ai-admin" />
      <RoleBadge role="phi-authorized" />
    </div>

    {/* Fear-and-answer */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Fear-and-answer</h3>
    <div class="mt-3 bg-white rounded-[20px] border border-border-subtle p-6 md:p-8">
      <FearAndAnswer
        fear="Will my manager see when I use AI and when I don't?"
        answer="No. /fleet aggregates by team only. Per-employee usage is never shown to anyone — including managers and including AI admins on this page."
        enforcedBy="Server-side query layer; no per-employee column is selected."
      />
      <FearAndAnswer
        fear="What if the agent gets it wrong?"
        answer="The human whose name is on the work takes the call. Agents draft; you sign off. The audit log records when a regulated artifact was reviewed by a person."
      />
    </div>

    {/* Cost meter */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Cost meter</h3>
    <div class="mt-3 grid sm:grid-cols-3 gap-4">
      <div class="bg-white border border-border-subtle rounded-[16px] p-5"><CostMeter label="Below threshold" spentUsd={12} capUsd={50} /></div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5"><CostMeter label="Approaching cap (80%)" spentUsd={42} capUsd={50} /></div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5"><CostMeter label="Over cap" spentUsd={56} capUsd={50} /></div>
    </div>

    {/* Audit row table */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Audit log row</h3>
    <div class="mt-3 bg-white border border-border-subtle rounded-[16px] overflow-hidden">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-soft-paper text-slate text-[12px] font-semibold uppercase tracking-[0.06em]">
            <th class="py-3 pl-5 pr-4">When</th>
            <th class="py-3 pr-4">Agent</th>
            <th class="py-3 pr-4">Actor</th>
            <th class="py-3 pr-4">Model</th>
            <th class="py-3 pr-4 text-right">Tokens</th>
            <th class="py-3 pr-5 text-right">Cost</th>
          </tr>
        </thead>
        <tbody>
          <AuditRow ts="2026-05-10 14:22" agent="Basal" actor="you" model="claude-opus-4-7" tokens={4128} costUsd={0.082} />
          <AuditRow ts="2026-05-10 09:14" agent="Basal" actor="you" model="claude-opus-4-7" tokens={920} costUsd={0.018} workflow="Morning briefing" />
        </tbody>
      </table>
    </div>

    {/* Workflow run row */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Workflow run row · status variants</h3>
    <div class="mt-3 bg-white border border-border-subtle rounded-[16px] overflow-hidden">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-soft-paper text-slate text-[12px] font-semibold uppercase tracking-[0.06em]">
            <th class="py-3 pl-5 pr-4">When</th>
            <th class="py-3 pr-4">Status</th>
            <th class="py-3 pr-4">Duration</th>
            <th class="py-3 pr-4">Triggered by</th>
            <th class="py-3 pr-4">Version</th>
            <th class="py-3 pr-5 text-right">Cost</th>
          </tr>
        </thead>
        <tbody>
          <WorkflowRunRow ts="2026-05-10 07:00" status="success"   durationMs={14200} triggeredBy="cron" costUsd={0.084} version="v3" />
          <WorkflowRunRow ts="2026-05-10 07:00" status="running"   durationMs={4200}  triggeredBy="manual" costUsd={0} version="v3" />
          <WorkflowRunRow ts="2026-05-09 07:00" status="failed"    durationMs={1700}  triggeredBy="cron" costUsd={0.012} version="v3" />
          <WorkflowRunRow ts="2026-05-08 07:00" status="cancelled" durationMs={9000}  triggeredBy="manual" costUsd={0.05} version="v3" />
        </tbody>
      </table>
    </div>

    {/* Workflow step list */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Workflow step list</h3>
    <div class="mt-3 bg-white border border-border-subtle rounded-[16px] p-6">
      <WorkflowStepList
        steps={[
          { name: "Pull mail since yesterday", kind: "fetch", summary: "Read Gmail since 6pm prior business day." },
          { name: "Classify", kind: "decision", summary: "Sort signal vs newsletter." },
          { name: "Compose briefing", kind: "agent", agent: "basal", summary: "Two paragraphs, three actions." },
          { name: "Manager approval", kind: "human-approval", summary: "Required for outbound regulated content." },
          { name: "Render Markdown", kind: "transform", summary: "Format for delivery." },
          { name: "Deliver to Slack DM", kind: "deliver", summary: "Post at 7am local." },
        ]}
      />
    </div>

    {/* Fleet tile */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Fleet tile · health variants</h3>
    <div class="mt-3 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <FleetTile slug="basal" name="Basal" status="live" invocations7d={318} uniqueUsers7d={7} costUsd7d={12.4} health="ok" />
      <FleetTile slug="basal-warn" name="Basal · warn" status="live" invocations7d={28} uniqueUsers7d={2} costUsd7d={1.2} health="warn" />
      <FleetTile slug="basal-crit" name="Basal · crit" status="live" invocations7d={4} uniqueUsers7d={1} costUsd7d={0.5} health="crit" />
      <FleetTile slug="basal-killed" name="Basal · killed" status="live" killed={true} invocations7d={0} uniqueUsers7d={0} costUsd7d={0} />
    </div>

    {/* Workflow card */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Workflow catalog card</h3>
    <div class="mt-3 grid md:grid-cols-2 gap-4">
      <WorkflowCard id="example" name="Morning briefing" summary="Per-person summary of inbox, calendar, and pending decisions." trigger="scheduled" schedule="0 7 * * 1-5" status="active" owner="john" stepCount={5} lastRun="today, 7:00" successRatePct={100} />
      <WorkflowCard id="example2" name="Monthly platform audit" summary="Adversarial review of every Worker, agent, and Workflow." trigger="scheduled" schedule="0 9 1 * *" status="drafting" owner="devops" stepCount={6} />
    </div>

    {/* Onboarding path */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Onboarding path tile</h3>
    <div class="mt-3 grid md:grid-cols-2 gap-4">
      <OnboardingPath role="engineering" title="Engineering at Luna with AI alongside" summary="Where to put agents in your loop, how to give them context safely, and what's still your call." moduleCount={5} href="/onboarding/eng" />
      <OnboardingPath role="ops" title="Operations at Luna with AI alongside" summary="Support, customer ops, vendor coordination — where agents land first, and what stays human." moduleCount={5} href="/onboarding/ops" />
    </div>

    {/* Kill switch */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Kill-switch button</h3>
    <div class="mt-3 flex flex-wrap gap-3">
      <KillSwitchButton agentSlug="basal" agentName="Basal" killed={false} canAdmin={true} />
      <KillSwitchButton agentSlug="basal" agentName="Basal" killed={true} canAdmin={true} />
      <KillSwitchButton agentSlug="basal" agentName="Basal" killed={false} canAdmin={false} />
    </div>

    {/* Briefing player */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Briefing player</h3>
    <div class="mt-3 max-w-[640px]">
      <BriefingPlayer cadence="daily" date="Saturday, May 10, 2026" durationLabel="3 min" />
    </div>

    {/* Agent config card */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Agent config card</h3>
    <div class="mt-3 space-y-4">
      <AgentConfigCard slug="basal" name="Basal" status="live" agentClass="A" summary="General-purpose chat assistant." enabled={true} memoryEnabled={true} customInstructionLength={142} />
      <AgentConfigCard slug="data-agent" name="Data Agent" status="coming-soon" agentClass="A" summary="Answers questions about Luna's data warehouse." enabled={false} memoryEnabled={false} customInstructionLength={0} />
    </div>

    {/* Memory viewer */}
    <h3 class="mt-12 text-ink font-body text-[16px] font-semibold uppercase tracking-[0.06em]">Memory viewer</h3>
    <div class="mt-3 max-w-[760px]">
      <MemoryViewer
        agent="Basal"
        memoryEnabled={true}
        facts={[
          { ts: "2026-05-08", fact: "Prefers concise responses without bullets unless asked.", source: "basal" },
          { ts: "2026-05-06", fact: "Working on the AI platform website expansion.", source: "basal" },
        ]}
      />
    </div>
  </WhiteSection>

  <MidnightBand size="compact">
    <p class="eyebrow eyebrow-on-dark">On dark</p>
    <h2 class="mt-4 font-display text-white" style="font-size: clamp(40px, 5vw, 64px); line-height: 1.05;">
      Midnight surfaces.
    </h2>
    <MoonlightRule width={48} class="mt-6" />
    <p class="mt-8 text-white/72 max-w-[62ch]">
      Text on Midnight is White for headlines and body, On-dark sub (#ACC1DF) for
      quiet copy. Card shadows are replaced with a 1px Midnight Soft hairline.
    </p>
  </MidnightBand>
</BaseLayout>
