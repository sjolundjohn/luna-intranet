---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import SectionCard from "~/components/SectionCard.astro";
---

<BaseLayout
  title="Company"
  description="Onboarding, the org, why we're building this, the roadmap, and how to use the platform."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Company" size="compact" animateMoons={false}>
    <Fragment slot="headline">
      Company &amp; context.
    </Fragment>
    <Fragment slot="subcopy">
      Where the company shows up: how to get started, who works on what, why we're
      building this, where it's going, and how to use it. Reference material —
      read what's relevant.
    </Fragment>
  </Hero>

  <WhiteSection size="tall">
    <div class="max-w-[760px] mb-10">
      <p class="eyebrow mb-3">The basics</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 38px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Read in any order.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
    </div>

    <div class="grid gap-6 md:gap-7 md:grid-cols-2 auto-rows-fr">
      <SectionCard
        href="/company/onboarding"
        eyebrow="01 · Onboarding"
        title="Pick your path."
        description="Five role-specific tracks. The first module on every track is the same: what we're not asking you to do."
      />
      <SectionCard
        href="/company/org"
        eyebrow="02 · Org chart"
        title="Who works on what."
        description="Agents and people by team and by person. Which agents each function uses, and who owns each one."
      />
      <SectionCard
        href="/company/vision"
        eyebrow="03 · Vision"
        title="Why we're building this."
        description="The principle behind Luna's AI workplace, what's changing, what isn't, and the fears we're tackling."
      />
      <SectionCard
        href="/company/roadmap"
        eyebrow="04 · Roadmap"
        title="Shipped, next, deferred."
        description="The honest view: what's in flight, what's queued, and what we're parking on purpose."
      />
      <SectionCard
        href="/company/help"
        eyebrow="05 · Help"
        title="How to use it."
        description="The user guide. How to chat with an agent, configure yours, request a new one, watch the fleet, read the briefing — and where to find everything."
      />
    </div>
  </WhiteSection>
</BaseLayout>
