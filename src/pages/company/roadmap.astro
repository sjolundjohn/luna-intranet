---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";

interface Item {
  title: string;
  detail: string;
  ref?: string;
}

const phases: { name: string; status: "shipped" | "now" | "next" | "later" | "deferred"; goal: string; items: Item[] }[] = [
  {
    name: "Operating system · domains, Tools, and two new tools",
    status: "shipped",
    goal: "Reorganized the intranet from an AI-tools test bed into a company operating system — a small set of top-level domains, an extensible Tools section, and strict 'don't show it until it works' gating.",
    items: [
      { title: "Four domains + Dashboard", detail: "AI System (/ai), Tools (/tools), Workflows (/workflows), Company (/company), each with a hub landing page; Dashboard is the launcher. Pre-launch, so URLs were re-pathed fresh." },
      { title: "Tools registry", detail: "A `tools` content collection — add a tool by dropping one MDX file. The hub renders live tools only. Chat, UX Review, Telescope (external subdomain) and Kegerator are live today." },
      { title: "UX Review tool", detail: "Review the Luna iOS wireframes screen-by-screen with anchored, threaded, resolvable comments + a notifications bell. Cloudflare Pages Functions + D1." },
      { title: "Kegerator", detail: "Office keg reorder — vote the next cold brew + kombucha up/down; a one-click admin 'Make Order' opens the Kegjoy email and clears the queue. D1-backed." },
      { title: "Strict hide-until-live", detail: "One helper (src/lib/content.ts) gates every surface; non-live agents and drafting workflows never build." },
      { title: "Deploy CI", detail: "GitHub Actions — typecheck + build on every PR; on main, apply D1 migrations then wrangler pages deploy." },
    ],
  },
  {
    name: "Phase 1 · IA, copy, and the front door",
    status: "shipped",
    goal: "Every page exists with reviewed copy. Welcome / onboarding is the front door; daily dashboard is one click. The site reads as the operating system for AI at Luna, not as marketing.",
    items: [
      { title: "/ Welcome + 5-step onboarding flow", detail: "First-run experience plus a returning-user bypass to the dashboard. Linked to the role tracks below." },
      { title: "AI System home with your-agents grid", detail: "Your agents, today's briefing, fleet-at-a-glance, and recent activity — folded onto /ai (the standalone /dashboard was retired)." },
      { title: "/company/vision · /ai/governance · /company/roadmap · /company/help", detail: "Fear-and-answer pattern; roles + permissions + kill-switch + audit + PHI scope documented; user-guide written." },
      { title: "/ai/agents with Yours + full catalog + scope/PHI badges", detail: "Five live Workforce agents (non-live agents stay hidden); 1:1 owner agents called out; /ai/agents/new flow with intake template." },
      { title: "/ai/fleet with By-team / By-owner / Flat groupings", detail: "Scales to 50+ agents without layout reflow. Empty departments render a 'request one' CTA." },
      { title: "Nav with hover dropdowns + active-bar fix", detail: "Domain-grouped nav; every sub-page reachable in two clicks." },
    ],
  },
  {
    name: "Phase 2 · Kill-switch + audit log (backend foundation)",
    status: "shipped",
    goal: "Two foundational Workers — per-agent kill switch and granular per-invocation audit log. Every Basal chat now passes through both.",
    items: [
      { title: "luna-killswitch Worker", detail: "DO-SQLite, per-agent state + append-only history. checkKillSwitch() runs on every /invoke. Fails-closed for PHI agents on KV unreachable. Sensor caught a same-ms PK-collision bug; fixed before deploy." },
      { title: "luna-audit-log Worker", detail: "DO-SQLite, one row per invocation. SHA-256 hashes only; never prompt/response bodies. Sensor caught 7 validation gaps; fixed before deploy." },
      { title: "AgentWorker.handle() wired", detail: "checkKillSwitch after bearer auth; writeAudit via ctx.waitUntil after the response (never blocks the user)." },
      { title: "agent-basal redeployed", detail: "KILL_SWITCH + AUDIT_LOG service bindings live. Every DM through @Basal exercises the full chain." },
    ],
  },
  {
    name: "Phase 3 · Read-side aggregates + per-user writes",
    status: "shipped",
    goal: "Fleet aggregates and per-user config persist for real. The 'Preview · not yet saving' pill on /ai/agents/me goes away.",
    items: [
      { title: "luna-fleet-api at fleet-api.nightluna.com", detail: "GET /summary, /agent/:slug, /me/activity, POST /admin/kill. Non-admins see rows with user_email scrubbed at the query layer." },
      { title: "luna-config-api at config-api.nightluna.com", detail: "GET /me, PUT /me/agents/:slug (enabled, memory, custom instructions, notifications), DELETE memory wipe queue. One DO per user_email." },
      { title: "Intranet Pages Functions proxy with CF Access service tokens", detail: "/api/me/activity, /api/me/config, /api/me/memory, /api/fleet/*, /api/admin/kill. Same pattern /api/chat uses for ai-proxy." },
      { title: "/ai/agents/me client-side enhancement", detail: "Mock renders first (never empty); /api/me/activity replaces with real audit rows; toggles persist via PUT on change." },
    ],
  },
  {
    name: "Up next · tools polish + deploy",
    status: "next",
    goal: "Small, known follow-ups on the new tools and the deploy pipeline — none blocking, all worth closing.",
    items: [
      { title: "Fix the CI deploy token", detail: "Set a valid CLOUDFLARE_API_TOKEN GitHub Actions secret (Pages: Edit, D1: Edit, Account: Read) so pushes to main self-deploy. Until then, deploys are run manually." },
      { title: "Telescope preview thumbnail", detail: "Drop public/tools/telescope.png and add `screenshot:` to the tool entry so the Tools hub shows a live preview card." },
      { title: "Kegerator flavor granularity", detail: "If we want per-flavor voting, scrape each Kegjoy brand's lineup and split catalog rows (e.g. 'GT's · Gingerade'). Brand-level voting works today." },
    ],
  },
  {
    name: "Phase 4 · Demo polish + per-agent rollout",
    status: "next",
    goal: "Today's chain (Basal → kill-switch → audit-log → fleet-api → Intranet) extended to every agent. Briefing comes off mock when there are enough real rows to summarize.",
    items: [
      { title: "Wire KILL_SWITCH + AUDIT_LOG bindings into the other 5 agents", detail: "agent-pen, clara, data (with getPiiScope() = 'phi'), pump, sensor. One-line wrangler.toml addition each + secret set." },
      { title: "Real fleet metrics on /ai/fleet", detail: "Replace the per-tile mock numbers with /summary reads. Today the data is sparse; the wire is already there." },
      { title: "Live kill-switch button on /ai/fleet/[agent]", detail: "Admin can flip a switch from the Intranet UI; fleet-api forwards to luna-killswitch." },
      { title: "End-to-end test with the team", detail: "DM Basal; check /ai/agents/me activity; toggle memory; flip kill-switch and confirm 503 + auto-resume." },
    ],
  },
  {
    name: "Phase 5 · Briefing pipeline + workflows runtime",
    status: "later",
    goal: "Daily and weekly fleet briefings generated from the audit data — written report and podcast feed. Cloudflare Workflows for long-running multi-step tasks.",
    items: [
      { title: "BriefingWorkflow on Cloudflare Workflows", detail: "Cron-triggered. Fans out per-team summaries via Queues, composes the master briefing, writes Markdown + R2 audio." },
      { title: "Briefing TTS pipeline + RSS feed", detail: "Audio MP3s in R2; subscribable podcast feed at /ai/fleet/briefing/feed.xml." },
      { title: "Real /ai/fleet/briefing instead of hand-written placeholder", detail: "Reads from briefing_episodes; renders the latest." },
    ],
  },
  {
    name: "Phase 6 · Memory wipe runner + chat persistence",
    status: "later",
    goal: "Close the loop on /ai/agents/me memory controls and persist chat threads across reloads.",
    items: [
      { title: "Memory-wipe runner", detail: "A worker reads luna-config-api memory_wipes and clears the user's history in luna-facet-memory." },
      { title: "/tools/chat persisted threads + R2 attachments", detail: "Per-user DO threads + signed-URL upload to R2." },
      { title: "Vectorize index for cross-conversation memory", detail: "Save/recall round-trip; 'show what this agent remembers about me' surface real." },
    ],
  },
  {
    name: "Deferred · California employment-law guardrails",
    status: "deferred",
    goal: "Important, real, scoped — and parked until we're ready to ship them with counsel review rather than as filler.",
    items: [
      { title: "CCPA employee data export endpoint", detail: "Self-serve 'export everything stored about me.' Hooks are in the schema; export endpoint awaits counsel pass." },
      { title: "AB 2930 automated-decision flag", detail: "Mandatory human-in-the-loop documentation for any agent that affects employment decisions. We don't run any such agents today." },
      { title: "Surveillance policy text", detail: "Explicit, written-down policy on what the Fleet view is and isn't. Drafted; needs counsel review." },
    ],
  },
];

const statusStyle: Record<typeof phases[number]["status"], string> = {
  "shipped": "bg-success-bg text-success-ink",
  "now": "bg-info-bg text-info-ink",
  "next": "bg-moonlight-tint text-info-ink",
  "later": "bg-periwinkle-mist text-graphite",
  "deferred": "bg-warning-bg text-warning-ink",
};

const statusLabel: Record<typeof phases[number]["status"], string> = {
  "shipped": "Shipped",
  "now": "In flight",
  "next": "Up next",
  "later": "Later",
  "deferred": "Deferred",
};
---

<BaseLayout
  title="Roadmap"
  description="What's shipping, what's next, and what we're explicitly deferring."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Roadmap" size="compact" animateMoons={false}>
    <Fragment slot="headline">
      Show, don't promise.
    </Fragment>
    <Fragment slot="subcopy">
      What's shipping, what's queued, and what we're deferring on purpose.
      If a control isn't here, it isn't shipped — and we'd rather say so
      than fake it.
    </Fragment>
  </Hero>

  <WhiteSection size="tall">
    <div class="space-y-12">
      {
        phases.map((p) => (
          <article>
            <div class="flex items-center gap-3 flex-wrap mb-3">
              <span class={`inline-flex items-center h-[24px] px-3 rounded-full font-body text-[12px] font-semibold ${statusStyle[p.status]}`}>
                {statusLabel[p.status]}
              </span>
              <h2 class="font-display text-ink font-normal text-[24px] md:text-[32px] leading-tight">
                {p.name}
              </h2>
            </div>
            <p class="mt-2 text-graphite text-[16px] leading-[1.6] max-w-[64ch]">{p.goal}</p>
            <div class="mt-5"><MoonlightRule width={40} color="midnight" /></div>

            <ul class="mt-6 grid md:grid-cols-2 gap-x-10 gap-y-4">
              {p.items.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 block h-[6px] w-[6px] rounded-full bg-moonlight flex-shrink-0" aria-hidden="true" />
                  <div>
                    <p class="text-ink text-[15px] font-semibold leading-snug">{item.title}</p>
                    <p class="mt-1 text-graphite text-[14px] leading-[1.55]">{item.detail}</p>
                  </div>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </WhiteSection>

  <WhiteSection size="compact" class="bg-soft-paper">
    <div class="max-w-[720px]">
      <p class="eyebrow mb-3">If you don't see something here</p>
      <h2 class="font-display text-ink font-normal text-[26px] md:text-[32px] leading-[1.1]">
        We probably haven't decided yet.
      </h2>
      <p class="mt-4 text-graphite text-[16px] leading-[1.6] max-w-[60ch]">
        The roadmap is a living artifact, not a contract. If a thing you
        need is missing — or a thing here is in the wrong column — say so
        in <span class="font-mono text-[14px]">#ai-platform</span>. The
        bar is "would someone on the team be better off if this existed today?" If
        yes, it moves up.
      </p>
    </div>
  </WhiteSection>
</BaseLayout>
