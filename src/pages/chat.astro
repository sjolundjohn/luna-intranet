---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ChatLayout from "~/components/ChatLayout.astro";

const allAgents = (await getCollection("agents")).sort(
  (a, b) => a.data.order - b.data.order,
);

const agents = allAgents.map((a) => ({
  slug: a.id,
  name: a.data.name,
  status: a.data.status,
}));

// SSG: defaultAgent is the first live agent in the catalog. `?agent=` is
// a Phase 3 enhancement (server-rendered chat with thread persistence);
// today the picker switches via client-side navigation only.
const defaultAgent =
  agents.find((a) => a.status === "live")?.slug ?? agents[0]?.slug ?? "basal";

// Phase 1 mock recent threads. Phase 3 reads from D1 chat_threads.
const recentThreads = [
  { id: "t-1011", title: "Drafting board update on Q2 milestones",  agent: "Basal", ts: "today, 14:22" },
  { id: "t-1010", title: "Summarize regulatory feedback letter",     agent: "Basal", ts: "today, 11:08" },
  { id: "t-1009", title: "Compare two protocol synopses",            agent: "Basal", ts: "yesterday" },
  { id: "t-1008", title: "Why is our deploy failing?",               agent: "Basal", ts: "Wed" },
];
---

<BaseLayout
  title="Chat"
  description="Full-page chat with any Luna agent you have access to."
  heroIsDark={false}
>
  <ChatLayout
    agents={agents}
    defaultAgent={defaultAgent}
    recentThreads={recentThreads}
  />
</BaseLayout>
