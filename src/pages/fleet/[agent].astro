---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import StatusChip from "~/components/StatusChip.astro";
import KillSwitchButton from "~/components/KillSwitchButton.astro";
import CostMeter from "~/components/CostMeter.astro";
import RoleBadge from "~/components/RoleBadge.astro";

export async function getStaticPaths() {
  const agents = await getCollection("agents");
  return agents.map((a) => ({
    params: { agent: a.id },
    props: { agent: a },
  }));
}

const { agent } = Astro.props;
const data = agent.data;

// Phase 1 mock — Phase 3 reads from D1 + Analytics Engine.
const metrics = {
  invocations7d: 318,
  uniqueUsers7d: 7,
  costUsd7d: 12.4,
  costUsdMTD: 48.7,
  capUsdMonth: 150,
  p50LatencyMs: 1820,
  p95LatencyMs: 4240,
  killed: false,
};

const recentInvocations = [
  { ts: "2026-05-10 14:22", team: "Software", model: "claude-opus-4-7", durationMs: 1840 },
  { ts: "2026-05-10 13:18", team: "Exec",     model: "claude-opus-4-7", durationMs: 2310 },
  { ts: "2026-05-10 11:50", team: "Software", model: "claude-opus-4-7", durationMs: 1620 },
  { ts: "2026-05-10 09:14", team: "Exec",     model: "claude-opus-4-7", durationMs: 920 },
  { ts: "2026-05-10 08:42", team: "Clinical", model: "claude-opus-4-7", durationMs: 1180 },
];
---

<BaseLayout
  title={`Fleet · ${data.name}`}
  description={`Live status, cost, and kill-switch control for ${data.name}.`}
  heroIsDark={true}
>
  <Hero eyebrow="Fleet · Per-agent view" size="compact" animateMoons={false}>
    <Fragment slot="headline">{data.name}</Fragment>
    <Fragment slot="subcopy">
      Status, recent activity, and the kill-switch — for {data.name}.
      Aggregate-only views; no per-employee usage shown.
    </Fragment>
  </Hero>

  {/* Header card with kill switch. */}
  <WhiteSection size="compact">
    <div class="bg-white border border-border-subtle rounded-[20px] p-6 md:p-8 flex items-start justify-between gap-6 flex-wrap">
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h2 class="text-ink font-body text-[22px] font-semibold leading-tight">{data.name}</h2>
          <StatusChip status={data.status} />
          {metrics.killed && (
            <span class="inline-flex items-center h-[22px] px-3 rounded-full bg-critical-bg text-critical-ink font-body text-[12px] font-semibold">
              Kill-switch engaged
            </span>
          )}
        </div>
        <p class="mt-3 text-graphite text-[15px] leading-[1.6] max-w-[60ch]">{data.summary}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-slate text-[13px]">Invokable by:</span>
          <RoleBadge role="employee" />
          <span class="text-slate text-[13px] ml-2">Configure:</span>
          <RoleBadge role="ai-admin" />
        </div>
      </div>
      <KillSwitchButton
        agentSlug={agent.id}
        agentName={data.name}
        killed={metrics.killed}
        canAdmin={false}
      />
    </div>
    <p class="mt-3 text-slate text-[13px] italic">
      The kill-switch UI renders disabled in Phase 1. Phase 3 wires it to
      a KV flag checked at both the agent-router and the agent Worker.
    </p>
  </WhiteSection>

  {/* Metrics. */}
  <WhiteSection size="compact" class="bg-soft-paper">
    <div class="max-w-[760px] mb-8">
      <p class="eyebrow mb-3">Last 7 days · aggregate</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Health and load.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">Invocations</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">{metrics.invocations7d.toLocaleString()}</p>
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">People</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">{metrics.uniqueUsers7d}</p>
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">P50 latency</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">{(metrics.p50LatencyMs / 1000).toFixed(1)}s</p>
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">P95 latency</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">{(metrics.p95LatencyMs / 1000).toFixed(1)}s</p>
      </div>
    </div>

    <div class="mt-6 bg-white border border-border-subtle rounded-[16px] p-6">
      <CostMeter
        label={`${data.name} · monthly cap`}
        spentUsd={metrics.costUsdMTD}
        capUsd={metrics.capUsdMonth}
        period="this month"
      />
    </div>
  </WhiteSection>

  {/* Recent invocations — anonymized to team. */}
  <WhiteSection size="compact">
    <div class="max-w-[760px] mb-8">
      <p class="eyebrow mb-3">Recent invocations</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Reported by team.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
      <p class="mt-5 text-graphite text-[15px] leading-[1.6] max-w-[60ch]">
        Individual employee identifiers are not shown on this page. AI
        admins viewing the full audit log on a separate route see emails;
        managers and other team members do not.
      </p>
    </div>

    <div class="bg-white border border-border-subtle rounded-[16px] overflow-hidden">
      <table class="w-full text-left">
        <thead>
          <tr class="bg-soft-paper text-slate text-[12px] font-semibold uppercase tracking-[0.06em]">
            <th class="py-3 pl-5 pr-4">When</th>
            <th class="py-3 pr-4">Team</th>
            <th class="py-3 pr-4">Model</th>
            <th class="py-3 pr-5 text-right">Duration</th>
          </tr>
        </thead>
        <tbody>
          {
            recentInvocations.map((inv) => (
              <tr class="border-t border-border-subtle">
                <td class="py-3 pl-5 pr-4 font-mono text-[12px] text-slate whitespace-nowrap">{inv.ts}</td>
                <td class="py-3 pr-4 text-ink text-[14px]">{inv.team}</td>
                <td class="py-3 pr-4 font-mono text-[12px] text-slate">{inv.model}</td>
                <td class="py-3 pr-5 text-right font-mono text-[13px] text-graphite tabular-nums">
                  {(inv.durationMs / 1000).toFixed(1)}s
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </WhiteSection>
</BaseLayout>
