---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import StatusChip from "~/components/StatusChip.astro";
import AgentAvatar from "~/components/AgentAvatar.astro";

// Phase 1 dashboard: filter "Yours" by John's email. Block 6 reads the
// signed-in email from CF Access.
const SIGNED_IN_EMAIL = "john@lunadiabetes.com";

const all = (await getCollection("agents")).sort(
  (a, b) => a.data.order - b.data.order,
);

const yours = all.filter((a) => a.data.allowedUsers.includes(SIGNED_IN_EMAIL));
---

<BaseLayout
  title="Agents"
  description="Every Luna agent — yours plus the rest of the catalog."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Agents" size="compact" animateMoons={false}>
    <Fragment slot="headline">
      Your team's agents.
    </Fragment>
    <Fragment slot="subcopy">
      Each agent is a teammate built on Claude, gated to the right people,
      and wired into Luna's tools. Your agents are at the top; the full
      catalog is below.
    </Fragment>
    <Fragment slot="cta">
      <div class="flex flex-wrap gap-3">
        <a
          href="/agents/me"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-moonlight text-midnight font-body text-[14px] font-semibold hover:opacity-90 transition-opacity"
        >
          Configure mine
        </a>
        <a
          href="/agents/new"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-white/30 text-white font-body text-[14px] font-medium hover:bg-white/10 transition-colors"
        >
          Request a new agent
        </a>
      </div>
    </Fragment>
  </Hero>

  {/* Yours */}
  <WhiteSection size="compact">
    <div class="mb-6">
      <p class="eyebrow mb-2">Yours</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(26px, 3.2vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        {yours.length === 0 ? "No agents available to you yet" : `${yours.length} agents available to you`}
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
    </div>

    {yours.length === 0 ? (
      <p class="text-graphite text-[15px] max-w-[60ch]">
        You don't have any agents available yet. <a href="/agents/new" class="text-ink underline decoration-moonlight decoration-2 underline-offset-4">Request one</a> or DM <span class="font-mono">@pen</span> in Slack to start.
      </p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {yours.map((a) => (
          <article class="bg-white border border-border-subtle rounded-[16px] p-5 transition-shadow hover:shadow-[0_8px_32px_rgba(4,30,66,0.06)]">
            <div class="flex items-start gap-3">
              <AgentAvatar slug={a.id} name={a.data.name} size={40} src={a.data.avatar} />
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-body text-[16px] font-semibold text-ink leading-tight">{a.data.name}</h3>
                  <StatusChip status={a.data.status} />
                </div>
                <p class="mt-1 text-slate text-[13px] line-clamp-2">{a.data.summary}</p>
              </div>
            </div>
            <div class="mt-4 flex items-center gap-2">
              {a.data.status === "live" && (
                <a href={`/chat?agent=${a.id}`} class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-midnight text-white text-[12px] font-semibold hover:bg-midnight-deep transition-colors">Chat</a>
              )}
              <a href={`/agents/${a.id}`} class="text-graphite text-[12px] hover:text-ink transition-colors">About</a>
              <a href={`/agents/me#${a.id}`} class="text-graphite text-[12px] hover:text-ink transition-colors ml-auto">Configure</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </WhiteSection>

  {/* All agents — the catalog */}
  <WhiteSection size="compact" class="bg-soft-paper">
    <div class="mb-6">
      <p class="eyebrow mb-2">All agents</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(26px, 3.2vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        The full catalog.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
      <p class="mt-5 text-graphite text-[15px] leading-[1.55] max-w-[60ch]">
        Every agent on the Luna AI Workforce, including the ones you don't
        have access to today. Click an agent to see what it does and how
        it's scoped.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {all.map((a) => {
        const isYours = a.data.allowedUsers.includes(SIGNED_IN_EMAIL);
        return (
          <a
            href={`/agents/${a.id}`}
            class="group bg-white border border-border-subtle rounded-[16px] p-5 hover:border-ink transition-all"
          >
            <div class="flex items-start gap-3">
              <AgentAvatar slug={a.id} name={a.data.name} size={40} src={a.data.avatar} />
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-body text-[15px] font-semibold text-ink leading-tight">{a.data.name}</h3>
                  <StatusChip status={a.data.status} />
                  {a.data.scope === "1:1" && (
                    <span class="inline-flex items-center h-[18px] px-2 rounded-full bg-periwinkle-mist text-ink font-body text-[10px] font-semibold tracking-[0.04em]">1:1</span>
                  )}
                  {a.data.piiScope === "phi" && (
                    <span class="inline-flex items-center h-[18px] px-2 rounded-full bg-critical-bg text-critical-ink font-body text-[10px] font-semibold tracking-[0.04em]">PHI</span>
                  )}
                </div>
                <p class="mt-1 text-slate text-[13px] line-clamp-2">{a.data.summary}</p>
                {!isYours && (
                  <p class="mt-2 text-slate text-[11px]">Not available to you · open to see how it's scoped</p>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </WhiteSection>

  {/* Need a new one? */}
  <WhiteSection size="compact">
    <div class="bg-white border border-border-subtle rounded-[20px] p-6 md:p-8 grid md:grid-cols-[1.5fr_1fr] gap-6 items-center">
      <div>
        <p class="eyebrow mb-2">Don't see what you need?</p>
        <h3 class="font-display text-ink font-normal text-[24px] md:text-[28px] leading-tight">
          Spin up a new agent.
        </h3>
        <p class="mt-3 text-graphite text-[15px] leading-[1.55] max-w-[60ch]">
          The intake takes 5 minutes. Pen runs the interview, John approves, Pump scaffolds the Worker, Sensor reviews. You get a working agent in a few days.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <a href="/agents/new" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-midnight text-white font-body text-[14px] font-semibold hover:bg-midnight-deep transition-colors">Request a new agent</a>
        <a href="/help/how-to#requesting-new-agents" class="inline-flex items-center gap-2 px-5 py-3 rounded-full border border-border-default text-ink font-body text-[14px] font-medium hover:border-ink transition-colors">How it works</a>
      </div>
    </div>
  </WhiteSection>
</BaseLayout>
