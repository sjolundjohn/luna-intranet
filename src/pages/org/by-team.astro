---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import StatusChip from "~/components/StatusChip.astro";
import AgentAvatar from "~/components/AgentAvatar.astro";
import CTAButton from "~/components/CTAButton.astro";
import { TEAM_LABELS, TEAM_ORDER } from "~/content.config";

const agents = await getCollection("agents");
const people = await getCollection("people");

/**
 * Split agents into the team's shared (1:many) agents and the team's
 * owner (1:1) agents. Owner agents are scoped to a single person —
 * they should NOT be presented as "available to everyone on this team."
 */
const agentsForTeam = (team: string) => {
  const ofTeam = agents.filter((a) => a.data.department === team);
  return {
    shared: ofTeam.filter((a) => a.data.scope === "1:many"),
    owner: ofTeam.filter((a) => a.data.scope === "1:1"),
  };
};

const peopleById = new Map(people.map((p) => [p.id, p.data]));

const peopleForTeam = (team: string) =>
  people
    .filter((p) => p.data.team === team)
    .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Org chart · By team"
  description="Luna's seven functions and the agents available to each."
  heroIsDark={true}
>
  <Hero eyebrow="Org chart · Teams" size="compact">
    <Fragment slot="headline">By team.</Fragment>
    <Fragment slot="subcopy">
      The seven functions at Luna. Each card shows who's on the team and
      which agents they have access to today.
    </Fragment>
  </Hero>

  <WhiteSection size="tall">
    <div class="mb-8">
      <CTAButton href="/org" variant="ghost">← Org chart</CTAButton>
    </div>

    <div class="space-y-14">
      {
        TEAM_ORDER.map((team) => {
          const teamAgents = agentsForTeam(team);
          const totalAgents = teamAgents.shared.length + teamAgents.owner.length;
          const teamPeople = peopleForTeam(team);
          return (
            <section>
              <div class="flex items-end justify-between gap-6 border-b border-border-subtle pb-4">
                <h2
                  class="font-display text-ink font-normal"
                  style="font-size: clamp(28px, 3.2vw, 40px); line-height: 1.1; letter-spacing: -0.02em;"
                >
                  {TEAM_LABELS[team]}
                </h2>
                <p class="text-slate font-body text-[14px]">
                  {teamPeople.length} {teamPeople.length === 1 ? "person" : "people"} · {totalAgents}{" "}
                  {totalAgents === 1 ? "agent" : "agents"}
                </p>
              </div>

              <div class="mt-8 grid gap-10 md:grid-cols-[1fr_1.5fr]">
                {/* People */}
                <div>
                  <p class="eyebrow mb-4">People</p>
                  {teamPeople.length === 0 ? (
                    <p class="text-slate text-[15px]">Coming soon.</p>
                  ) : (
                    <ul class="space-y-3">
                      {teamPeople.map((p) => (
                        <li class="flex items-center gap-3">
                          <AgentAvatar
                            name={p.data.name}
                            slug={p.id}
                            src={p.data.avatar}
                            size={36}
                          />
                          <div>
                            <p class="text-ink font-medium text-[15px]" id={p.id}>{p.data.name}</p>
                            <p class="text-slate text-[13px]">{p.data.role}</p>
                          </div>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>

                {/* Agents — split shared (team-wide) vs owner (scoped to one person) */}
                <div class="space-y-6">
                  {totalAgents === 0 ? (
                    <p class="text-slate text-[15px]">Coming soon.</p>
                  ) : null}

                  {teamAgents.shared.length > 0 && (
                    <div>
                      <p class="eyebrow mb-4">Shared with the team (1:many)</p>
                      <ul class="space-y-3">
                        {teamAgents.shared.map((a) => (
                          <li>
                            <a
                              href={`/agents/${a.id}`}
                              class="group flex items-center gap-4 p-3 -m-3 rounded-[12px] hover:bg-cloud-lilac transition-colors"
                            >
                              <AgentAvatar name={a.data.name} slug={a.id} src={a.data.avatar} size={44} />
                              <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 flex-wrap">
                                  <p class="text-ink font-medium text-[15px]">{a.data.name}</p>
                                  <StatusChip status={a.data.status} />
                                </div>
                                <p class="text-slate text-[13px] mt-0.5 line-clamp-2">{a.data.summary}</p>
                              </div>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {teamAgents.owner.length > 0 && (
                    <div>
                      <p class="eyebrow mb-4">Owner agents (1:1)</p>
                      <ul class="space-y-3">
                        {teamAgents.owner.map((a) => {
                          const ownerName = a.data.owner
                            ? peopleById.get(a.data.owner)?.name
                            : undefined;
                          return (
                            <li>
                              <a
                                href={`/agents/${a.id}`}
                                class="group flex items-center gap-4 p-3 -m-3 rounded-[12px] hover:bg-cloud-lilac transition-colors"
                              >
                                <AgentAvatar name={a.data.name} slug={a.id} src={a.data.avatar} size={44} />
                                <div class="flex-1 min-w-0">
                                  <div class="flex items-center gap-2 flex-wrap">
                                    <p class="text-ink font-medium text-[15px]">{a.data.name}</p>
                                    <StatusChip status={a.data.status} />
                                    {ownerName && (
                                      <span class="inline-flex items-center h-[18px] px-2 rounded-full bg-periwinkle-mist text-ink font-body text-[10px] font-semibold tracking-[0.04em]">
                                        for {ownerName}
                                      </span>
                                    )}
                                  </div>
                                  <p class="text-slate text-[13px] mt-0.5 line-clamp-2">{a.data.summary}</p>
                                </div>
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                      <p class="mt-2 text-slate text-[12px] italic">
                        1:1 agents serve only the person they're scoped to — they're not available to the rest of the team.
                      </p>
                    </div>
                  )}
                </div>
              </div>
            </section>
          );
        })
      }
    </div>
  </WhiteSection>
</BaseLayout>
