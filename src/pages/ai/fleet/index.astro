---
import { getCollection } from "astro:content";
import { liveAgents } from "~/lib/content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MidnightBand from "~/components/MidnightBand.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import FleetTile from "~/components/FleetTile.astro";
import CostMeter from "~/components/CostMeter.astro";
import { TEAM_LABELS, TEAM_ORDER } from "~/content.config";

const agents = await liveAgents();
const people = await getCollection("people");

// Phase 1 mock metrics — Block 4 reads from the fleet-api Worker.
const fleetMetrics: Record<
  string,
  { invocations7d: number; uniqueUsers7d: number; costUsd7d: number; killed?: boolean; health?: "ok" | "warn" | "crit" }
> = {
  basal:   { invocations7d: 142, uniqueUsers7d: 2, costUsd7d: 6.8,  health: "ok" },
  pen:     { invocations7d: 16,  uniqueUsers7d: 1, costUsd7d: 1.1,  health: "ok" },
  clara:   { invocations7d: 0,   uniqueUsers7d: 0, costUsd7d: 0,    health: "ok" },
  data:    { invocations7d: 0,   uniqueUsers7d: 0, costUsd7d: 0,    health: "ok" },
  pump:    { invocations7d: 38,  uniqueUsers7d: 1, costUsd7d: 4.4,  health: "ok" },
  sensor:  { invocations7d: 27,  uniqueUsers7d: 1, costUsd7d: 3.8,  health: "ok" },
};

const metricsOf = (slug: string) =>
  fleetMetrics[slug] ?? { invocations7d: 0, uniqueUsers7d: 0, costUsd7d: 0 };

// --- Grouping --------------------------------------------------------------
// "By department" — every team, with its 1:many agents and 1:1 owner agents
// owned by people in that team. Departments with zero agents render an empty
// state with a "request" CTA, so the structure scales to 50+ agents without
// reflowing the layout.
const peopleById = new Map(people.map((p) => [p.id, p.data]));

const agentsByDepartment = TEAM_ORDER.map((team) => {
  const ofTeam = agents.filter((a) => a.data.department === team);
  return {
    team,
    label: TEAM_LABELS[team],
    shared: ofTeam.filter((a) => a.data.scope === "1:many"),
    owner: ofTeam.filter((a) => a.data.scope === "1:1"),
    invocations7d: ofTeam.reduce((s, a) => s + metricsOf(a.id).invocations7d, 0),
    costUsd7d: ofTeam.reduce((s, a) => s + metricsOf(a.id).costUsd7d, 0),
    activeCount: ofTeam.filter((a) => metricsOf(a.id).invocations7d > 0).length,
  };
}).filter((d) => d.shared.length + d.owner.length > 0 || ["software", "hardware", "regulatory", "clinical", "electrical-engineering"].includes(d.team));

// "By owner" — first the company-wide shared agents, then a section per owner.
const sharedAgents = agents.filter((a) => a.data.scope === "1:many");
const ownerAgents = agents.filter((a) => a.data.scope === "1:1");
const ownerAgentsByOwner = ownerAgents.reduce<Record<string, typeof ownerAgents>>((acc, a) => {
  const owner = a.data.owner ?? "unowned";
  if (!acc[owner]) acc[owner] = [];
  acc[owner].push(a);
  return acc;
}, {});

const ownerSections = Object.entries(ownerAgentsByOwner).map(([id, list]) => ({
  id,
  person: peopleById.get(id),
  agents: list,
}));

// --- Fleet-wide rollup -----------------------------------------------------
const totalAgents = agents.length;
const totalInvocations = Object.values(fleetMetrics).reduce(
  (s, m) => s + m.invocations7d,
  0,
);
const totalCost = Object.values(fleetMetrics).reduce((s, m) => s + m.costUsd7d, 0);
---

<BaseLayout
  title="Fleet"
  description="Live status of every Luna agent — organized by team and by owner. Aggregates only."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Fleet" size="compact" animateMoons={false}>
    <Fragment slot="headline">
      What the fleet<br />is working on.
    </Fragment>
    <Fragment slot="subcopy">
      Status, usage, and cost across every Luna agent — grouped by the
      team that owns them or by the person who owns them. Aggregates
      only; never per individual employee.
    </Fragment>
  </Hero>

  {/* Privacy framing band */}
  <WhiteSection size="compact">
    <div class="bg-soft-paper border border-border-subtle rounded-[20px] p-6 md:p-8">
      <p class="eyebrow mb-3">A note on what this page is, and isn't</p>
      <div class="grid md:grid-cols-2 gap-6 md:gap-10">
        <div>
          <p class="text-ink text-[15px] font-semibold">This page is for</p>
          <ul class="mt-2 space-y-2 text-graphite text-[14px] leading-[1.55]">
            <li class="flex gap-2"><span class="mt-1.5 h-[5px] w-[5px] rounded-full bg-success-ink flex-shrink-0"></span>Knowing what the fleet is doing right now</li>
            <li class="flex gap-2"><span class="mt-1.5 h-[5px] w-[5px] rounded-full bg-success-ink flex-shrink-0"></span>Spotting cost or reliability issues before they hit prod</li>
            <li class="flex gap-2"><span class="mt-1.5 h-[5px] w-[5px] rounded-full bg-success-ink flex-shrink-0"></span>Understanding which workflows are paying off — at the team level</li>
          </ul>
        </div>
        <div>
          <p class="text-ink text-[15px] font-semibold">This page isn't for</p>
          <ul class="mt-2 space-y-2 text-graphite text-[14px] leading-[1.55]">
            <li class="flex gap-2"><span class="mt-1.5 h-[5px] w-[5px] rounded-full bg-critical-ink flex-shrink-0"></span>Per-employee leaderboards or rankings</li>
            <li class="flex gap-2"><span class="mt-1.5 h-[5px] w-[5px] rounded-full bg-critical-ink flex-shrink-0"></span>Manager visibility into individual usage</li>
            <li class="flex gap-2"><span class="mt-1.5 h-[5px] w-[5px] rounded-full bg-critical-ink flex-shrink-0"></span>Performance evaluation of any kind</li>
          </ul>
        </div>
      </div>
      <p class="mt-6 pt-5 border-t border-border-subtle text-slate text-[13px] leading-[1.55]">
        These constraints are enforced in the query layer, not just in
        policy. See <a href="/ai/governance" class="text-graphite underline decoration-moonlight decoration-2 underline-offset-4 hover:decoration-ink transition-colors">/governance</a> for how.
      </p>
    </div>
  </WhiteSection>

  {/* Fleet-wide stat strip */}
  <WhiteSection size="compact">
    <div class="grid sm:grid-cols-3 gap-4">
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">Agents in fleet</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">{totalAgents}</p>
        <p class="mt-1 text-slate text-[12px]">{sharedAgents.length} shared · {ownerAgents.length} owner</p>
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">Invocations · 7d</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">{totalInvocations.toLocaleString()}</p>
        <p class="mt-1 text-slate text-[12px]">across all agents</p>
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-5">
        <p class="eyebrow mb-2">Spend · 7d</p>
        <p class="text-ink font-mono tabular-nums text-[28px]">${totalCost.toFixed(2)}</p>
        <p class="mt-1 text-slate text-[12px]">below caps</p>
      </div>
    </div>
  </WhiteSection>

  {/* View toggle: by-department vs by-owner */}
  <WhiteSection size="compact" class="bg-soft-paper">
    <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
      <div>
        <p class="eyebrow mb-2">Organized view</p>
        <h2
          class="font-display text-ink font-normal"
          style="font-size: clamp(28px, 3.6vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
        >
          Pick your grouping.
        </h2>
        <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
        <p class="mt-5 text-graphite text-[15px] leading-[1.6] max-w-[60ch]">
          When the fleet grows past a flat grid, two groupings make this
          page navigable. "By team" sees agents through the org chart;
          "By owner" sees them through who runs them.
        </p>
      </div>
      <div
        class="inline-flex items-center bg-white border border-border-subtle rounded-full p-1 shadow-[0_2px_8px_rgba(4,30,66,0.04)]"
        role="tablist"
        aria-label="Group fleet by"
        data-fleet-toggle
      >
        <button
          type="button"
          role="tab"
          aria-selected="true"
          data-view="department"
          class="px-4 py-1.5 rounded-full font-body text-[13px] font-semibold transition-colors bg-midnight text-white"
        >
          By team
        </button>
        <button
          type="button"
          role="tab"
          aria-selected="false"
          data-view="owner"
          class="px-4 py-1.5 rounded-full font-body text-[13px] font-medium text-graphite transition-colors"
        >
          By owner
        </button>
        <button
          type="button"
          role="tab"
          aria-selected="false"
          data-view="all"
          class="px-4 py-1.5 rounded-full font-body text-[13px] font-medium text-graphite transition-colors"
        >
          Flat
        </button>
      </div>
    </div>

    {/* === By team view (default) === */}
    <div data-fleet-view="department" class="space-y-12">
      {
        agentsByDepartment.map((d) => (
          <section>
            <header class="flex items-end justify-between gap-4 flex-wrap pb-3 border-b border-border-subtle mb-5">
              <div>
                <p class="eyebrow mb-1.5">{d.label}</p>
                <h3 class="font-body text-ink text-[20px] font-semibold leading-tight">
                  {d.shared.length + d.owner.length === 0
                    ? "No agents yet"
                    : `${d.shared.length + d.owner.length} ${d.shared.length + d.owner.length === 1 ? "agent" : "agents"}`}
                </h3>
              </div>
              {d.shared.length + d.owner.length > 0 && (
                <p class="text-slate text-[12px] font-mono tabular-nums">
                  <span class="text-graphite">{d.invocations7d.toLocaleString()}</span> invocations · <span class="text-graphite">${d.costUsd7d.toFixed(2)}</span> · 7d
                </p>
              )}
            </header>

            {d.shared.length + d.owner.length === 0 ? (
              <div class="bg-white border border-border-subtle rounded-[16px] p-6">
                <p class="text-graphite text-[15px]">
                  No agents serving {d.label} yet.{" "}
                  <a href="/ai/agents/new" class="text-ink underline decoration-moonlight decoration-2 underline-offset-4 hover:decoration-ink transition-colors">Request one</a>
                  {" "}if your team needs one.
                </p>
              </div>
            ) : (
              <div class="space-y-6">
                {d.shared.length > 0 && (
                  <div>
                    <p class="eyebrow mb-3">Shared (1:many)</p>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                      {d.shared.map((a) => {
                        const m = metricsOf(a.id);
                        return (
                          <FleetTile
                            slug={a.id}
                            name={a.data.name}
                            status={a.data.status}
                            killed={m.killed}
                            invocations7d={m.invocations7d}
                            uniqueUsers7d={m.uniqueUsers7d}
                            costUsd7d={m.costUsd7d}
                            health={m.health}
                          />
                        );
                      })}
                    </div>
                  </div>
                )}
                {d.owner.length > 0 && (
                  <div>
                    <p class="eyebrow mb-3">Owner agents (1:1)</p>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                      {d.owner.map((a) => {
                        const m = metricsOf(a.id);
                        const ownerName = a.data.owner ? peopleById.get(a.data.owner)?.name : undefined;
                        return (
                          <FleetTile
                            slug={a.id}
                            name={ownerName ? `${a.data.name} · ${ownerName}` : a.data.name}
                            status={a.data.status}
                            killed={m.killed}
                            invocations7d={m.invocations7d}
                            uniqueUsers7d={m.uniqueUsers7d}
                            costUsd7d={m.costUsd7d}
                            health={m.health}
                          />
                        );
                      })}
                    </div>
                  </div>
                )}
              </div>
            )}
          </section>
        ))
      }
    </div>

    {/* === By owner view === */}
    <div data-fleet-view="owner" class="space-y-12 hidden">
      <section>
        <header class="flex items-end justify-between gap-4 flex-wrap pb-3 border-b border-border-subtle mb-5">
          <div>
            <p class="eyebrow mb-1.5">Company-wide</p>
            <h3 class="font-body text-ink text-[20px] font-semibold leading-tight">
              {sharedAgents.length} shared {sharedAgents.length === 1 ? "agent" : "agents"} (1:many)
            </h3>
            <p class="mt-1 text-slate text-[13px]">
              Available to multiple people across the team. Anyone in <span class="font-mono text-[12px]">allowedUsers</span> can invoke them.
            </p>
          </div>
        </header>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {
            sharedAgents.map((a) => {
              const m = metricsOf(a.id);
              return (
                <FleetTile
                  slug={a.id}
                  name={a.data.name}
                  status={a.data.status}
                  killed={m.killed}
                  invocations7d={m.invocations7d}
                  uniqueUsers7d={m.uniqueUsers7d}
                  costUsd7d={m.costUsd7d}
                  health={m.health}
                />
              );
            })
          }
        </div>
      </section>

      {
        ownerSections.map((sec) => (
          <section>
            <header class="flex items-end justify-between gap-4 flex-wrap pb-3 border-b border-border-subtle mb-5">
              <div>
                <p class="eyebrow mb-1.5">Owner</p>
                <h3 class="font-body text-ink text-[20px] font-semibold leading-tight">
                  {sec.person?.name ?? sec.id}
                  {sec.person?.role && (
                    <span class="text-slate text-[15px] font-normal"> · {sec.person.role}</span>
                  )}
                </h3>
                <p class="mt-1 text-slate text-[13px]">
                  {sec.agents.length} {sec.agents.length === 1 ? "agent" : "agents"} (1:1) — serving only {sec.person?.name ?? "this person"}.
                </p>
              </div>
            </header>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {sec.agents.map((a) => {
                const m = metricsOf(a.id);
                return (
                  <FleetTile
                    slug={a.id}
                    name={a.data.name}
                    status={a.data.status}
                    killed={m.killed}
                    invocations7d={m.invocations7d}
                    uniqueUsers7d={m.uniqueUsers7d}
                    costUsd7d={m.costUsd7d}
                    health={m.health}
                  />
                );
              })}
            </div>
          </section>
        ))
      }

      {ownerSections.length === 0 && (
        <p class="text-graphite text-[15px]">
          No 1:1 owner agents yet. <a href="/ai/agents/new" class="text-ink underline decoration-moonlight decoration-2 underline-offset-4">Request one</a> if you'd like a personal agent.
        </p>
      )}
    </div>

    {/* === Flat view (the original grid, useful when you just want to scan) === */}
    <div data-fleet-view="all" class="hidden">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          agents.map((a) => {
            const m = metricsOf(a.id);
            return (
              <FleetTile
                slug={a.id}
                name={a.data.name}
                status={a.data.status}
                killed={m.killed}
                invocations7d={m.invocations7d}
                uniqueUsers7d={m.uniqueUsers7d}
                costUsd7d={m.costUsd7d}
                health={m.health}
              />
            );
          })
        }
      </div>
    </div>
  </WhiteSection>

  {/* Cost panel */}
  <WhiteSection size="compact">
    <div class="max-w-[760px] mb-8">
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <p class="eyebrow">Cost</p>
        <span
          class="inline-flex items-center h-[20px] px-[10px] rounded-full font-body text-[10px] font-semibold tracking-[0.04em] bg-warning-bg text-warning-ink"
        >
          Mock data
        </span>
      </div>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Per-agent budgets, enforced at the gateway.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
      <p class="mt-5 text-graphite text-[15px] leading-[1.6] max-w-[60ch]">
        Each agent has a daily and monthly cap configured at the AI Gateway.
        Crossing 80% goes amber; crossing 100% trips the cap and the agent
        starts refusing new requests until the cap resets or an admin lifts it.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <div class="bg-white border border-border-subtle rounded-[16px] p-6">
        <CostMeter label="Basal · monthly" spentUsd={48.7} capUsd={150} period="this month" />
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-6">
        <CostMeter label="Clara · monthly" spentUsd={6.8} capUsd={50} period="this month" />
      </div>
      <div class="bg-white border border-border-subtle rounded-[16px] p-6">
        <CostMeter label="Total fleet · monthly" spentUsd={61.0} capUsd={500} period="this month" />
      </div>
    </div>
  </WhiteSection>

  <MidnightBand size="compact">
    <div class="max-w-[720px]">
      <p class="eyebrow eyebrow-on-dark mb-3">The briefing</p>
      <h2
        class="font-display text-white font-normal"
        style="font-size: clamp(28px, 4vw, 40px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Read or listen to today's fleet briefing.
      </h2>
      <p class="mt-5 text-white/72 text-[16px] leading-[1.6] max-w-[56ch]">
        A daily and weekly summary of what the fleet has been working on.
        Same content as a Markdown report or a 3-minute podcast — pick
        your channel.
      </p>
      <div class="mt-7">
        <a
          href="/ai/fleet/briefing"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-moonlight text-midnight font-body text-[15px] font-semibold shadow-[0_3px_10px_rgba(104,210,223,0.4)] hover:shadow-[0_6px_20px_rgba(104,210,223,0.5)] transition-shadow"
        >
          Today's briefing
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </MidnightBand>
</BaseLayout>

<script>
  // View toggle: switches between By team / By owner / Flat. CSS-free
  // because the views are siblings with `hidden` class — fastest UX and
  // works with Astro's view transitions.
  function setupFleetToggle() {
    const toggle = document.querySelector<HTMLElement>("[data-fleet-toggle]");
    if (!toggle) return;
    const buttons = toggle.querySelectorAll<HTMLButtonElement>("[data-view]");
    const views = document.querySelectorAll<HTMLElement>("[data-fleet-view]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.view;
        if (!target) return;

        buttons.forEach((b) => {
          const active = b.dataset.view === target;
          b.setAttribute("aria-selected", active ? "true" : "false");
          if (active) {
            b.classList.add("bg-midnight", "text-white", "font-semibold");
            b.classList.remove("text-graphite", "font-medium");
          } else {
            b.classList.remove("bg-midnight", "text-white", "font-semibold");
            b.classList.add("text-graphite", "font-medium");
          }
        });

        views.forEach((v) => {
          v.classList.toggle("hidden", v.dataset.fleetView !== target);
        });
      });
    });
  }

  setupFleetToggle();
  document.addEventListener("astro:page-load", setupFleetToggle);
</script>
