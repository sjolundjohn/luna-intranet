---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MidnightBand from "~/components/MidnightBand.astro";
import SectionCard from "~/components/SectionCard.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import ChatBox from "~/components/ChatBox.astro";
---

<BaseLayout
  title="Luna, internal."
  description="Luna's internal home — agents, people, platform, and everything we're building."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Internal" size="compact" animateMoons={true}>
    <Fragment slot="headline">Luna, internal.</Fragment>
    <Fragment slot="subcopy">
      The place to find what we're building, who's building it, and how to use it.
    </Fragment>
  </Hero>

  {/* Four-tile grid — less agent-focused, more intranet. */}
  <WhiteSection size="compact">
    <div class="max-w-[720px] mb-6 md:mb-8">
      <p class="eyebrow mb-3">What's here</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 40px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Four places to start.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
    </div>

    <div class="grid gap-6 md:gap-7 md:grid-cols-2 auto-rows-fr">
      <SectionCard
        href="/agents"
        eyebrow="01 · Agents"
        title="AI agents."
        description="The AI assistants Luna is building for the team — starting with Basal."
      />
      <SectionCard
        href="#playground"
        eyebrow="02 · Playground"
        title="Try it."
        description="Chat with Basal right here — no Slack needed. Test drive how it responds."
      />
      <SectionCard
        href="/org"
        eyebrow="03 · Org chart"
        title="Who does what."
        description="Agents and teammates, by function and by person. See who owns what."
      />
      <SectionCard
        href="/platform"
        eyebrow="04 · Platform"
        title="Under the hood."
        description="How it actually works — Cloudflare, Claude, and why your data stays private."
      />
    </div>
  </WhiteSection>

  {/* Inline playground — chat with Basal without leaving the site. */}
  <WhiteSection size="compact" id="playground" class="bg-soft-paper">
    <div class="max-w-[720px] mb-10">
      <p class="eyebrow mb-4">Playground · Try Basal</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.6vw, 42px); line-height: 1.1; letter-spacing: -0.02em;"
      >
        Ask Basal anything.
      </h2>
      <p class="mt-4 text-graphite text-[17px] leading-[1.55] max-w-[56ch]">
        Same model and guardrails as the Slack experience. Conversations here aren't saved
        to your Slack history — this is for quick trials.
      </p>
    </div>
    <ChatBox agent="basal" placeholder="Ask Basal something..." />
  </WhiteSection>

  <MidnightBand size="compact" class="text-center">
    <p class="eyebrow eyebrow-on-dark mb-6">Our brand promise</p>
    <h2
      class="font-display text-white font-normal"
      style="font-size: clamp(48px, 6vw, 80px); line-height: 1; letter-spacing: -0.03em;"
    >
      true to you.
    </h2>
    <div class="mt-8 flex justify-center"><MoonlightRule width={64} /></div>
    <p class="mt-10 max-w-[540px] mx-auto text-white/72 text-[17px] leading-[1.6]">
      Internal tools should feel as considered as the products we ship. This site is our first pass.
    </p>
  </MidnightBand>
</BaseLayout>
