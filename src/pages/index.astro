---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import WhiteSection from "~/components/WhiteSection.astro";
import MidnightBand from "~/components/MidnightBand.astro";
import MoonlightRule from "~/components/MoonlightRule.astro";
import SectionCard from "~/components/SectionCard.astro";
import OnboardingPath from "~/components/OnboardingPath.astro";

const tracks = (await getCollection("onboarding")).sort(
  (a, b) => a.data.order - b.data.order,
);

// The four top-level domains — the shape of the operating system.
const domains = [
  {
    href: "/ai",
    eyebrow: "AI System",
    title: "The AI workforce.",
    description:
      "Teammates built on Claude — scoped, named, accountable. Meet them, see what they're doing, or request one of your own.",
  },
  {
    href: "/tools",
    eyebrow: "Tools",
    title: "Things you can open.",
    description:
      "Hands-on apps built on the platform — chat, design review, clinical reporting, the odd office utility. Open one and go.",
  },
  {
    href: "/workflows",
    eyebrow: "Workflows",
    title: "Work that runs itself.",
    description:
      "The repeatable, multi-step jobs we've handed to the system — running quietly in the background so you don't have to.",
  },
  {
    href: "/company",
    eyebrow: "Company",
    title: "How we work.",
    description:
      "Onboarding, the org, why we're building this, and how to use it — the human context around everything else.",
  },
];
---

<BaseLayout
  title="Luna, internal."
  description="Luna's internal operating system — the tools, agents, and workflows we're building to do our best work."
  heroIsDark={true}
>
  <Hero eyebrow="Luna · Internal" size="full" animateMoons={true}>
    <Fragment slot="headline">
      Human-led. <span class="text-moonlight">AI-centric.</span>
    </Fragment>
    <Fragment slot="subcopy">
      Developing tools and capabilities to let us do our best work.
    </Fragment>
    <Fragment slot="cta">
      <div class="flex flex-wrap gap-3">
        <a
          href="/ai"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-moonlight text-midnight font-body text-[15px] font-semibold shadow-[0_3px_10px_rgba(104,210,223,0.4)] hover:shadow-[0_6px_20px_rgba(104,210,223,0.5)] transition-shadow"
        >
          Open AI System
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
        <a
          href="#explore"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/30 text-white font-body text-[15px] font-medium hover:bg-white/10 transition-colors"
        >
          Look around
        </a>
      </div>
    </Fragment>
  </Hero>

  {/* Gentle warmup — what this is, in plain language. */}
  <WhiteSection size="tall" id="explore">
    <div class="max-w-[760px]">
      <p class="eyebrow mb-3">What this is</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(28px, 3.8vw, 42px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        An operating system for how Luna works.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
      <p class="mt-6 text-graphite text-[17px] leading-[1.65] max-w-[62ch]">
        People lead; the technology amplifies. This is the one place the
        team and our AI work side by side — and where everything we build
        to do our best work comes together. No rush, nothing to set up.
        Have a look around.
      </p>
    </div>

    {/* The four domains. */}
    <div class="grid gap-6 md:gap-7 md:grid-cols-2 auto-rows-fr mt-10">
      {
        domains.map((d) => (
          <SectionCard
            href={d.href}
            eyebrow={d.eyebrow}
            title={d.title}
            description={d.description}
          />
        ))
      }
    </div>
  </WhiteSection>

  {/* New here? — onboarding kept as a soft invitation, not the whole page. */}
  <WhiteSection size="tall" class="bg-soft-paper" id="new-here">
    <div class="max-w-[760px] mb-10">
      <p class="eyebrow mb-3">New here?</p>
      <h2
        class="font-display text-ink font-normal"
        style="font-size: clamp(26px, 3.2vw, 36px); line-height: 1.05; letter-spacing: -0.02em;"
      >
        Find your footing.
      </h2>
      <div class="mt-4"><MoonlightRule width={40} color="midnight" /></div>
      <p class="mt-6 text-graphite text-[16px] leading-[1.65] max-w-[60ch]">
        Short role-specific tracks, about 20 minutes each. The first
        module on every one is the same — <em>what we're not asking you
        to do.</em> That's the boundary, written down. Take the track that
        fits your work whenever you're ready.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {
        tracks.map((track) => (
          <OnboardingPath
            role={track.data.role}
            title={track.data.title}
            summary={track.data.summary}
            moduleCount={track.data.modules.length}
            href={`/company/onboarding/${track.id}`}
          />
        ))
      }
    </div>
  </WhiteSection>

  {/* Quiet close. */}
  <MidnightBand size="compact">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <p class="eyebrow eyebrow-on-dark mb-3">Day to day</p>
        <h3 class="font-display text-white font-normal text-[24px] md:text-[28px] leading-tight">
          AI System is your home base.
        </h3>
        <p class="mt-3 text-on-dark-sub text-[15px] leading-[1.6] max-w-[52ch]">
          Your agents, what they've been doing, what's running, and the
          daily briefing — all in one place.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <a
          href="/ai"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-moonlight text-midnight font-body text-[14px] font-semibold hover:opacity-90 transition-opacity"
        >
          Open AI System
        </a>
        <a
          href="/company"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-full border border-white/30 text-white font-body text-[14px] font-medium hover:bg-white/10 transition-colors"
        >
          Company &amp; context
        </a>
      </div>
    </div>
  </MidnightBand>
</BaseLayout>
