---
/**
 * Index card for one onboarding role track. Used on /onboarding to
 * point employees to the right path for their work.
 */
interface Props {
  role: string;
  title: string;
  summary: string;
  moduleCount: number;
  href: string;
}

const { role, title, summary, moduleCount, href } = Astro.props;
---

<a
  href={href}
  class="group block bg-white border border-border-subtle rounded-[16px] p-6 md:p-7 transition-all hover:border-ink hover:shadow-[0_8px_32px_rgba(4,30,66,0.08)]"
>
  <p class="eyebrow mb-3">For {role}</p>
  <h3 class="text-ink font-body text-[20px] font-semibold leading-tight">{title}</h3>
  <p class="mt-3 text-graphite text-[15px] leading-[1.55] max-w-[58ch]">{summary}</p>
  <p class="mt-5 text-slate text-[13px]">
    {moduleCount} modules · ~{Math.max(10, moduleCount * 5)} minutes total
  </p>
</a>
