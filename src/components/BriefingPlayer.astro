---
/**
 * Daily/weekly fleet briefing surface. Top of /fleet/briefing.
 *
 * The principle is dual-form: read it or listen to it. The audio source
 * is an R2-hosted MP3 in production; Phase 1 wires the markup but the
 * audio src defaults to empty (the player gracefully shows "audio
 * coming with Phase 4").
 */
interface Props {
  cadence: "daily" | "weekly";
  date: string;
  durationLabel?: string;
  audioSrc?: string;
  /** RSS feed URL — used by the "Subscribe in podcast" link. */
  feedUrl?: string;
}

const {
  cadence,
  date,
  durationLabel,
  audioSrc = "",
  feedUrl = "/fleet/briefing/feed.xml",
} = Astro.props;

const cadenceLabel = cadence === "daily" ? "Daily briefing" : "Weekly briefing";
---

<aside
  class="bg-white border border-border-subtle rounded-[20px] overflow-hidden shadow-[0_5px_50px_rgba(0,0,0,0.07)]"
  aria-label="Fleet briefing player"
>
  <div class="bg-midnight text-white px-6 py-5 md:px-8 md:py-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
      <p class="eyebrow eyebrow-on-dark mb-2">{cadenceLabel}</p>
      <p class="font-display font-normal text-[26px] md:text-[30px] leading-[1.1]">{date}</p>
    </div>
    {
      durationLabel && (
        <span class="inline-flex items-center h-[26px] px-3 rounded-full bg-moonlight/15 text-moonlight font-mono text-[12px] font-semibold">
          {durationLabel}
        </span>
      )
    }
  </div>

  <div class="p-6 md:p-8">
    {
      audioSrc ? (
        <audio class="w-full" controls preload="metadata" src={audioSrc}>
          Your browser doesn't support inline audio. Use the RSS feed below.
        </audio>
      ) : (
        <div class="flex items-center gap-3 px-4 py-3 rounded-[12px] bg-soft-paper border border-border-subtle">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate" aria-hidden="true">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
            <line x1="22" y1="9" x2="16" y2="15" />
            <line x1="16" y1="9" x2="22" y2="15" />
          </svg>
          <p class="text-graphite text-[14px] leading-[1.5]">
            Audio is generated by the briefing workflow on a cron schedule.
            Phase 4 wires the TTS pipeline; today the written report below
            stands in.
          </p>
        </div>
      )
    }

    <div class="mt-5 flex flex-wrap gap-3 items-center text-[13px]">
      <a
        href={feedUrl}
        class="inline-flex items-center gap-1.5 text-ink underline decoration-moonlight decoration-2 underline-offset-4 hover:decoration-ink transition-colors font-medium"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
        Subscribe in your podcast app
      </a>
      <span class="text-slate">·</span>
      <span class="text-slate">Aggregate-only · no individual employee names appear in any episode</span>
    </div>
  </div>
</aside>
