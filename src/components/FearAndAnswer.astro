---
/**
 * Recurring change-management pattern: name a fear employees actually have
 * about AI at work, then state in plain words how Luna's design responds.
 *
 * Used on /company/vision, /ai/governance, and the first module of every onboarding
 * track. Two-up grid on md+, stacks on mobile.
 *
 * The discipline of this component is structural — it forces every claim
 * to come paired with a concrete design choice that backs it up.
 */
interface Props {
  fear: string;
  answer: string;
  /** Optional one-line reference to where this is enforced. */
  enforcedBy?: string;
}

const { fear, answer, enforcedBy } = Astro.props;
---

<article
  class="grid md:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] gap-6 md:gap-10 py-7 border-t border-border-subtle first:border-t-0 first:pt-0"
>
  <div>
    <p class="eyebrow mb-3">The fear</p>
    <p class="text-ink text-[18px] leading-[1.45] font-medium">{fear}</p>
  </div>
  <div>
    <p class="eyebrow mb-3">What we built</p>
    <p class="text-graphite text-[17px] leading-[1.6]">{answer}</p>
    {
      enforcedBy && (
        <p class="mt-3 text-slate text-[14px] leading-[1.5]">
          <span class="font-semibold text-graphite">Enforced by:</span> {enforcedBy}
        </p>
      )
    }
  </div>
</article>
