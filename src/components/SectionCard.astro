---
/**
 * Big linked section tile. White fill on light, 16px radius, card shadow,
 * 30px padding. D-DIN page-title heading + Inter description + arrow on hover.
 */
import MoonPhases from "~/components/MoonPhases.astro";

interface Props {
  href: string;
  eyebrow?: string;
  title: string;
  /** Single line of body copy. */
  description: string;
  /** Render a moon-phase glyph in the top-right. */
  showMoons?: boolean;
  class?: string;
}

const {
  href,
  eyebrow,
  title,
  description,
  showMoons = true,
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative flex flex-col h-full bg-white rounded-[16px] shadow-[0_5px_50px_rgba(0,0,0,0.07)]",
    "p-8 md:p-10 transition-all duration-[160ms] ease-out",
    "hover:-translate-y-[1px] hover:shadow-[0_12px_60px_rgba(4,30,66,0.14)]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-moonlight focus-visible:ring-offset-2",
    className,
  ]}
>
  {
    showMoons && (
      <div class="absolute top-6 right-6 opacity-40 group-hover:opacity-80 transition-opacity">
        <MoonPhases size={14} gap={8} class="text-midnight" />
      </div>
    )
  }

  {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}

  <h3
    class="font-display text-ink font-normal whitespace-nowrap"
    style="font-size: clamp(30px, 2.8vw, 40px); line-height: 1.05; letter-spacing: -0.02em;"
  >
    {title}
  </h3>

  <p class="mt-4 text-graphite text-[17px] leading-[1.55] max-w-[38ch]">
    {description}
  </p>

  <div class="mt-auto pt-8 inline-flex items-center gap-2 text-ink font-body text-[15px] font-medium">
    <span class="relative">
      Explore
      <span
        class="absolute left-0 -bottom-1 h-[2px] w-full bg-moonlight origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-[220ms] ease-out"
        aria-hidden="true"
      ></span>
    </span>
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-transform duration-[220ms] group-hover:translate-x-1"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </div>
</a>
