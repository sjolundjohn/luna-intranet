---
/**
 * Agent listing card. Avatar + name + status chip + summary + arrow.
 * White fill, 16px radius, card shadow, 22–28px padding per v1.0.
 */
import StatusChip from "~/components/StatusChip.astro";
import AgentAvatar from "~/components/AgentAvatar.astro";

interface Props {
  href: string;
  slug: string;
  name: string;
  status: "live" | "coming-soon" | "by-request";
  summary: string;
  accessHint?: string;
  avatar?: string;
  class?: string;
}

const {
  href,
  slug,
  name,
  status,
  summary,
  accessHint,
  avatar,
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative block bg-white rounded-[16px] shadow-[0_5px_50px_rgba(0,0,0,0.07)]",
    "p-7 md:p-8 transition-all duration-[160ms] ease-out",
    "hover:-translate-y-[1px] hover:shadow-[0_12px_60px_rgba(4,30,66,0.14)]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-moonlight focus-visible:ring-offset-2",
    "h-full flex flex-col",
    className,
  ]}
  data-status={status}
>
  <div class="flex items-start gap-4">
    <AgentAvatar name={name} slug={slug} src={avatar} size={56} />
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 flex-wrap">
        <h3 class="font-body text-[20px] font-bold text-ink leading-tight">{name}</h3>
        <StatusChip status={status} />
      </div>
      {accessHint && (
        <p class="mt-1.5 eyebrow">{accessHint}</p>
      )}
    </div>
  </div>

  <p class="mt-5 text-graphite text-[15px] leading-[1.6] flex-1">{summary}</p>

  <div class="mt-6 inline-flex items-center gap-2 text-ink font-body text-[14px] font-medium">
    <span class="relative">
      Read more
      <span
        class="absolute left-0 -bottom-1 h-[2px] w-full bg-moonlight origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-[220ms] ease-out"
        aria-hidden="true"
      ></span>
    </span>
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-transform duration-[220ms] group-hover:translate-x-1"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </div>
</a>
