---
/**
 * Agent listing card. Composes StatusChip + MoonPhases + Inter 20/700 title +
 * Inter 13/400 Graphite tagline. 16px radius, card shadow, 22px pad.
 */
import StatusChip from "~/components/StatusChip.astro";
import MoonPhases from "~/components/MoonPhases.astro";

interface Props {
  href: string;
  name: string;
  status: "live" | "coming-soon" | "by-request";
  summary: string;
  accessHint?: string;
  class?: string;
}

const { href, name, status, summary, accessHint, class: className = "" } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative block bg-white rounded-[16px] shadow-[0_5px_50px_rgba(0,0,0,0.07)]",
    "p-6 md:p-7 transition-all duration-[160ms] ease-out",
    "hover:-translate-y-[1px] hover:shadow-[0_12px_60px_rgba(4,30,66,0.14)]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-moonlight focus-visible:ring-offset-2",
    "h-full flex flex-col",
    className,
  ]}
  data-status={status}
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-body text-[20px] font-bold text-ink leading-tight">{name}</h3>
    <StatusChip status={status} />
  </div>

  <p class="mt-3 text-graphite text-[15px] leading-[1.55] flex-1">{summary}</p>

  {
    accessHint && (
      <p class="mt-5 eyebrow">{accessHint}</p>
    )
  }

  <div class="mt-5 flex items-center justify-between">
    <span class="inline-flex items-center gap-2 text-ink font-body text-[14px] font-medium">
      Read more
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform duration-[220ms] group-hover:translate-x-1"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
    <MoonPhases size={10} gap={6} class="text-midnight opacity-25 group-hover:opacity-60 transition-opacity" />
  </div>
</a>
