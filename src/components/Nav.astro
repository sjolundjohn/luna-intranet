---
/**
 * Sticky glass nav. 72px tall. Scroll-reactive mode (Midnight glass over
 * dark heroes; White glass elsewhere). Hover dropdowns on items that
 * have sub-pages, expanded on focus-within for keyboard users.
 *
 * NOTE: this component is NOT persisted across page transitions. Astro's
 * View Transitions ClientRouter persists the rest of the layout but the
 * nav re-renders each navigation so the active underline tracks the
 * current path. Persisting it caused a stale active-bar bug.
 */
import { liveAgents, activeWorkflows, liveTools } from "~/lib/content";
import NotificationsBell from "~/components/ux/NotificationsBell.astro";

interface Props {
  heroIsDark?: boolean;
}

const { heroIsDark = true } = Astro.props;

const agents = await liveAgents();
const workflows = await activeWorkflows();
const tools = await liveTools();

interface SubLink {
  href: string;
  label: string;
  /** Optional tiny right-side annotation, e.g. status. */
  hint?: string;
  /** External link → opens in a new tab. */
  external?: boolean;
}

interface NavItem {
  href: string;
  label: string;
  sub?: { groups: { label?: string; links: SubLink[] }[] };
}

// Top-level domains: Dashboard (home) · AI System · Tools · Workflows · Company.
const navLinks: NavItem[] = [
  { href: "/dashboard", label: "Dashboard" },
  {
    href: "/ai",
    label: "AI System",
    sub: {
      groups: [
        {
          links: [
            { href: "/ai", label: "AI System overview" },
            { href: "/ai/agents", label: "Agents catalog" },
            { href: "/ai/agents/me", label: "My agents" },
            { href: "/ai/agents/new", label: "Request a new agent" },
          ],
        },
        {
          label: "Agents",
          links: agents.map((a) => ({
            href: `/ai/agents/${a.id}`,
            label: a.data.name,
            hint: "Live",
          })),
        },
        {
          label: "Fleet",
          links: [
            { href: "/ai/fleet", label: "Fleet overview" },
            { href: "/ai/fleet/briefing", label: "Today's briefing" },
          ],
        },
        {
          label: "Platform & governance",
          links: [
            { href: "/ai/platform", label: "Platform docs" },
            { href: "/ai/governance", label: "Governance" },
          ],
        },
      ],
    },
  },
  {
    href: "/tools",
    label: "Tools",
    sub: {
      groups: [
        {
          links: [{ href: "/tools", label: "All tools" }],
        },
        {
          label: "Live tools",
          links: tools.map((t) => ({
            href: t.data.href,
            label: t.data.name,
            external: t.data.external,
            hint: t.data.external ? "↗" : undefined,
          })),
        },
      ],
    },
  },
  {
    href: "/workflows",
    label: "Workflows",
    sub: {
      groups: [
        {
          links: [{ href: "/workflows", label: "Workflows catalog" }],
        },
        {
          label: "Active workflows",
          links: workflows.map((w) => ({
            href: `/workflows/${w.id}`,
            label: w.data.name,
          })),
        },
      ],
    },
  },
  {
    href: "/company",
    label: "Company",
    sub: {
      groups: [
        {
          links: [
            { href: "/company", label: "Company overview" },
            { href: "/company/onboarding", label: "Onboarding" },
            { href: "/company/org", label: "Org chart" },
          ],
        },
        {
          label: "Context",
          links: [
            { href: "/company/vision", label: "Vision" },
            { href: "/company/roadmap", label: "Roadmap" },
            { href: "/company/help", label: "How to use it" },
          ],
        },
      ],
    },
  },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
};
---

<nav
  data-nav
  data-mode={heroIsDark ? "dark" : "light"}
  class="fixed top-0 left-0 right-0 z-50 h-[72px] flex items-center"
>
  <div class="mx-auto w-full max-w-[1200px] px-6 md:px-10 flex items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-3 focus-visible:outline-none"
      aria-label="Luna — home"
    >
      <img
        data-logo-dark
        src="/luna-on-dark.svg"
        alt=""
        height="40"
        width="auto"
        class="h-10 w-auto"
      />
      <img
        data-logo-light
        src="/luna-on-white.svg"
        alt=""
        height="40"
        width="auto"
        class="hidden h-10 w-auto"
      />
      <span class="sr-only">Luna, internal</span>
    </a>

    <div class="flex items-center gap-0.5 md:gap-1">
      {
        navLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <div class="nav-item-wrap relative" data-has-sub={link.sub ? "true" : undefined}>
              <a
                href={link.href}
                class:list={[
                  "relative inline-flex items-center px-3 py-2 font-body text-[15px] font-medium transition-colors",
                  active ? "nav-link-active" : "nav-link",
                ]}
                data-active={active ? "true" : undefined}
                aria-haspopup={link.sub ? "true" : undefined}
              >
                {link.label}
                {active && (
                  <span
                    class="absolute left-3 right-3 bottom-[6px] h-[2px] bg-moonlight"
                    aria-hidden="true"
                  />
                )}
              </a>

              {link.sub && (
                <div
                  class="nav-dropdown absolute top-full right-0 mt-1 w-[280px] origin-top-right rounded-[12px] bg-white shadow-[0_12px_40px_rgba(4,30,66,0.12)] border border-border-subtle py-2 opacity-0 invisible scale-[0.98] transition-all duration-150"
                  role="menu"
                >
                  {link.sub.groups.map((group, gi) => (
                    <div class:list={[gi > 0 ? "mt-1 pt-2 border-t border-border-subtle" : ""]}>
                      {group.label && (
                        <p class="px-3 py-1.5 text-slate text-[10px] font-semibold uppercase tracking-[0.08em]">
                          {group.label}
                        </p>
                      )}
                      <ul>
                        {group.links.map((sub) => (
                          <li>
                            <a
                              href={sub.href}
                              role="menuitem"
                              target={sub.external ? "_blank" : undefined}
                              rel={sub.external ? "noopener noreferrer" : undefined}
                              class="flex items-center justify-between gap-3 px-3 py-1.5 text-[13px] text-ink hover:bg-soft-paper transition-colors"
                            >
                              <span>{sub.label}</span>
                              {sub.hint && (
                                <span class="text-slate text-[11px] font-medium">{sub.hint}</span>
                              )}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              )}
            </div>
          );
        })
      }

      {/* Notifications — UX Review comment activity. Hidden until the store responds. */}
      <NotificationsBell />

      {/* Sign out — hits Cloudflare Access logout. No-op in local dev. */}
      <a
        href="/cdn-cgi/access/logout"
        class="ml-2 md:ml-4 inline-flex items-center gap-1.5 px-3 py-2 font-body text-[13px] font-medium rounded-full border border-current opacity-70 hover:opacity-100 transition-opacity nav-link"
        title="Sign out of Luna"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        <span class="hidden sm:inline">Sign out</span>
      </a>
    </div>
  </div>
</nav>

{/* Spacer so content doesn't sit under the fixed nav. */}
<div aria-hidden="true" class="h-[72px]"></div>

<style>
  nav[data-mode="dark"] {
    background: color-mix(in oklab, var(--color-midnight) 72%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-midnight-soft);
  }
  nav[data-mode="light"] {
    background: color-mix(in oklab, var(--color-white) 80%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  /* link colors — scoped by nav mode */
  nav[data-mode="dark"] .nav-link {
    color: rgba(255, 255, 255, 0.72);
  }
  nav[data-mode="dark"] .nav-link:hover {
    color: #fff;
  }
  nav[data-mode="dark"] .nav-link-active {
    color: #fff;
  }
  nav[data-mode="light"] .nav-link {
    color: var(--color-graphite);
  }
  nav[data-mode="light"] .nav-link:hover {
    color: var(--color-ink);
  }
  nav[data-mode="light"] .nav-link-active {
    color: var(--color-ink);
  }

  /* logo swap by mode */
  nav[data-mode="dark"] [data-logo-light] { display: none; }
  nav[data-mode="dark"] [data-logo-dark] { display: block; }
  nav[data-mode="light"] [data-logo-dark] { display: none; }
  nav[data-mode="light"] [data-logo-light] { display: block; }

  /* Dropdown reveal — hover OR keyboard focus-within on the wrap. */
  .nav-item-wrap:hover > .nav-dropdown,
  .nav-item-wrap:focus-within > .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }
</style>

<script>
  // Scroll-reactive mode switch: after we scroll past the hero, flip light.
  function setupNav() {
    const nav = document.querySelector("nav[data-nav]") as HTMLElement | null;
    if (!nav) return;
    const startMode = nav.dataset.mode as "dark" | "light" | undefined;
    if (!startMode) return;

    let rafId = 0;
    const threshold = () => window.innerHeight * 0.7;

    const onScroll = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        if (startMode === "dark") {
          nav.dataset.mode = window.scrollY > threshold() ? "light" : "dark";
        } else {
          nav.dataset.mode = "light";
        }
        rafId = 0;
      });
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  setupNav();
  document.addEventListener("astro:page-load", setupNav);
</script>
