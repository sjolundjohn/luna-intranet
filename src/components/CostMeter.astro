---
/**
 * Horizontal budget meter. Used per-agent and per-user on /fleet and
 * /agents/me. Visual shows spent/cap; over-cap goes plum (critical),
 * approaching-cap goes amber (warning), normal is moonlight.
 */
interface Props {
  label: string;
  spentUsd: number;
  capUsd: number;
  /** Optional sub-label, e.g. "this month" or "this week". */
  period?: string;
}

const { label, spentUsd, capUsd, period = "this month" } = Astro.props;

const pct = capUsd <= 0 ? 0 : Math.min(spentUsd / capUsd, 1.2);
const pctDisplay = Math.round(pct * 100);

const fill =
  pct >= 1
    ? "bg-critical-fill"
    : pct >= 0.8
      ? "bg-warning-fill"
      : "bg-moonlight";

const ink =
  pct >= 1
    ? "text-critical-ink"
    : pct >= 0.8
      ? "text-warning-ink"
      : "text-graphite";
---

<div class="w-full">
  <div class="flex items-baseline justify-between mb-2">
    <p class="text-ink text-[14px] font-medium">{label}</p>
    <p class={`font-mono text-[12px] tabular-nums ${ink}`}>
      ${spentUsd.toFixed(2)} <span class="text-slate">/ ${capUsd.toFixed(2)}</span>
    </p>
  </div>
  <div
    class="relative h-[6px] w-full bg-periwinkle-mist rounded-full overflow-hidden"
    role="progressbar"
    aria-valuenow={pctDisplay}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={`${label} ${pctDisplay}% of budget`}
  >
    <div
      class={`h-full ${fill} transition-[width] duration-300`}
      style={`width: ${Math.min(pct, 1) * 100}%;`}
    ></div>
    {
      pct > 1 && (
        <div
          class="absolute top-0 right-0 h-full w-[3px] bg-critical-ink"
          aria-hidden="true"
        />
      )
    }
  </div>
  <p class="mt-1 text-slate text-[12px]">{pctDisplay}% used · {period}</p>
</div>
