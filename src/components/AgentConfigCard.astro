---
/**
 * One-agent config row on /agents/me. Shows: agent name, status, the
 * current per-user toggle, and a link into the deeper config form.
 *
 * Phase 1 is read-only/mock — `enabled` and `memoryEnabled` come from
 * mock data. Phase 2 wires writes through the config-api Worker.
 */
import AgentAvatar from "~/components/AgentAvatar.astro";
import StatusChip from "~/components/StatusChip.astro";

interface Props {
  slug: string;
  name: string;
  status: "live" | "coming-soon" | "by-request";
  agentClass: "A" | "B";
  summary: string;
  enabled: boolean;
  memoryEnabled: boolean;
  customInstructionLength: number;
}

const {
  slug,
  name,
  status,
  agentClass,
  summary,
  enabled,
  memoryEnabled,
  customInstructionLength,
} = Astro.props;
---

<article
  class="bg-white border border-border-subtle rounded-[16px] p-6 md:p-7 shadow-[0_2px_8px_rgba(4,30,66,0.04)]"
>
  <div class="flex items-start gap-4">
    <AgentAvatar slug={slug} name={name} size={44} />
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 flex-wrap">
        <h3 class="text-ink font-body text-[18px] font-semibold leading-tight">{name}</h3>
        <StatusChip status={status} />
        <span
          class="inline-flex items-center h-[20px] px-[10px] rounded-full font-body text-[11px] font-semibold tracking-[0.02em] bg-periwinkle-mist text-ink"
          title={agentClass === "A" ? "1:many shared agent" : "1:1 personal agent"}
        >
          Class {agentClass}
        </span>
      </div>
      <p class="mt-2 text-graphite text-[14px] leading-[1.55] max-w-[60ch]">{summary}</p>
    </div>
    <a
      href={`/agents/me#${slug}`}
      class="hidden md:inline-flex items-center gap-1 text-ink font-body text-[13px] font-medium px-3 py-1.5 rounded-full border border-border-default hover:border-ink transition-colors"
    >
      Configure
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  </div>

  <div
    class="mt-5 grid sm:grid-cols-3 gap-3 sm:gap-4 pt-5 border-t border-border-subtle"
  >
    <div>
      <p class="eyebrow mb-1.5">Enabled</p>
      <p class={`text-[14px] font-medium ${enabled ? "text-success-ink" : "text-slate"}`}>
        {enabled ? "On" : "Off"}
      </p>
    </div>
    <div>
      <p class="eyebrow mb-1.5">Memory</p>
      <p class={`text-[14px] font-medium ${memoryEnabled ? "text-info-ink" : "text-slate"}`}>
        {memoryEnabled ? "On" : "Off"}
      </p>
    </div>
    <div>
      <p class="eyebrow mb-1.5">Custom instructions</p>
      <p class="text-[14px] font-medium text-graphite">
        {customInstructionLength === 0
          ? "Default"
          : `${customInstructionLength.toLocaleString()} chars`}
      </p>
    </div>
  </div>
</article>
