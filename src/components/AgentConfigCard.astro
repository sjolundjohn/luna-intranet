---
/**
 * One-agent config row on /ai/agents/me. Interactive-looking toggles for
 * Enabled / Memory plus an inline custom-instructions textarea expander.
 *
 * Phase 1 = optimistic UI: toggles flip visually but don't persist.
 * Block 5 (config-api Worker) wires real writes. A "Preview · not yet
 * saving" pill makes it obvious the changes don't stick yet.
 */
import AgentAvatar from "~/components/AgentAvatar.astro";
import StatusChip from "~/components/StatusChip.astro";

interface Props {
  slug: string;
  name: string;
  status: "live" | "coming-soon" | "by-request";
  /** "1:many" = shared (Class A), "1:1" = owner (Class B). */
  scope: "1:many" | "1:1";
  summary: string;
  enabled: boolean;
  memoryEnabled: boolean;
  customInstructionLength: number;
}

const {
  slug,
  name,
  status,
  scope,
  summary,
  enabled,
  memoryEnabled,
  customInstructionLength,
} = Astro.props;

const scopeLabel = scope === "1:many" ? "Shared" : "Owner agent";
const scopeTitle = scope === "1:many" ? "1:many — shared agent" : "1:1 — personal owner agent";
---

<article
  id={slug}
  data-agent-config
  class="scroll-mt-24 bg-white border border-border-subtle rounded-[16px] p-6 md:p-7 shadow-[0_2px_8px_rgba(4,30,66,0.04)]"
>
  <div class="flex items-start gap-4">
    <AgentAvatar slug={slug} name={name} size={44} />
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 flex-wrap">
        <h3 class="text-ink font-body text-[18px] font-semibold leading-tight">{name}</h3>
        <StatusChip status={status} />
        <span
          class="inline-flex items-center h-[20px] px-[10px] rounded-full font-body text-[11px] font-semibold tracking-[0.02em] bg-periwinkle-mist text-ink"
          title={scopeTitle}
        >
          {scopeLabel}
        </span>
        <span
          class="inline-flex items-center h-[20px] px-[10px] rounded-full font-body text-[10px] font-semibold tracking-[0.04em] bg-success-bg text-success-ink"
          title="Writes persist to luna-config-api"
        >
          Live · saving
        </span>
      </div>
      <p class="mt-2 text-graphite text-[14px] leading-[1.55] max-w-[60ch]">{summary}</p>
    </div>
  </div>

  {/* Toggle row */}
  <div
    class="mt-5 grid sm:grid-cols-3 gap-4 pt-5 border-t border-border-subtle"
  >
    {/* Enabled toggle */}
    <label class="flex items-start gap-3 cursor-pointer group">
      <input
        type="checkbox"
        data-config-toggle="enabled"
        checked={enabled}
        class="sr-only peer"
      />
      <span
        class="mt-0.5 inline-flex items-center w-[36px] h-[20px] rounded-full bg-pebble-blue peer-checked:bg-success-ink relative transition-colors flex-shrink-0"
        aria-hidden="true"
      >
        <span
          class="absolute left-[2px] top-[2px] w-[16px] h-[16px] rounded-full bg-white shadow-sm transition-transform peer-checked:translate-x-[16px]"
          style="transition: transform 160ms ease-out;"
        ></span>
      </span>
      <span>
        <p class="eyebrow mb-0.5">Enabled</p>
        <p class="text-[13px] text-graphite leading-tight" data-config-label="enabled">
          {enabled ? "On" : "Off"}
        </p>
      </span>
    </label>

    {/* Memory toggle */}
    <label class="flex items-start gap-3 cursor-pointer group">
      <input
        type="checkbox"
        data-config-toggle="memory"
        checked={memoryEnabled}
        class="sr-only peer"
      />
      <span
        class="mt-0.5 inline-flex items-center w-[36px] h-[20px] rounded-full bg-pebble-blue peer-checked:bg-info-ink relative transition-colors flex-shrink-0"
        aria-hidden="true"
      >
        <span
          class="absolute left-[2px] top-[2px] w-[16px] h-[16px] rounded-full bg-white shadow-sm"
          style="transition: transform 160ms ease-out;"
        ></span>
      </span>
      <span>
        <p class="eyebrow mb-0.5">Memory</p>
        <p class="text-[13px] text-graphite leading-tight" data-config-label="memory">
          {memoryEnabled ? "On" : "Off"}
        </p>
      </span>
    </label>

    {/* Custom instructions — toggle-expand textarea inline */}
    <details class="group" data-config-instructions>
      <summary class="cursor-pointer list-none">
        <div class="flex items-center justify-between gap-3">
          <span>
            <p class="eyebrow mb-0.5">Custom instructions</p>
            <p class="text-[13px] text-graphite leading-tight">
              {customInstructionLength === 0
                ? "Default — click to add"
                : `${customInstructionLength.toLocaleString()} chars`}
            </p>
          </span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-slate transition-transform group-open:rotate-90 flex-shrink-0">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      </summary>
    </details>
  </div>

  {/* Expanded inline custom-instructions panel — shown when details is open */}
  <div data-config-instructions-panel class="hidden mt-4 pt-4 border-t border-border-subtle">
    <label class="block">
      <span class="sr-only">Custom instructions for {name}</span>
      <textarea
        class="w-full min-h-[100px] rounded-[12px] border border-border-default bg-white px-4 py-3 font-body text-[14px] text-ink placeholder:text-slate focus:outline-none focus:border-border-focus focus:ring-2 focus:ring-moonlight/30"
        placeholder={`Append to ${name}'s system prompt every time you talk to them. e.g. "Keep replies under 200 words. Skip preamble. Use plain text."`}
        maxlength="1000"
      ></textarea>
    </label>
    <p class="mt-2 text-slate text-[11px]">Capped at 1,000 characters. Preview — does not persist yet.</p>
  </div>
</article>

<script>
  // Toggle behavior: optimistic UI flip. Block 5 replaces this with a
  // fetch to /api/config that posts to config-api Worker.
  document.querySelectorAll<HTMLElement>("[data-agent-config]").forEach((card) => {
    card.querySelectorAll<HTMLInputElement>("[data-config-toggle]").forEach((input) => {
      input.addEventListener("change", () => {
        const kind = input.dataset.configToggle;
        const label = card.querySelector<HTMLElement>(
          `[data-config-label="${kind}"]`,
        );
        if (label) label.textContent = input.checked ? "On" : "Off";
      });
    });

    // <details> toggle reveals the panel via aria-state CSS; we wire it
    // to also unhide the panel below for layout consistency.
    const details = card.querySelector<HTMLDetailsElement>("[data-config-instructions]");
    const panel = card.querySelector<HTMLElement>("[data-config-instructions-panel]");
    if (details && panel) {
      details.addEventListener("toggle", () => {
        panel.classList.toggle("hidden", !details.open);
      });
    }
  });
</script>
