---
/**
 * Collapsible FAQ list. Uses native <details>/<summary> — no JS, accessible
 * by default, keyboard-friendly. Styled to the v1.0 tokens: 16px card radius,
 * Border subtle hairlines, Ink questions, Graphite answers.
 */
interface Item {
  q: string;
  /** Answer in plain text. Line breaks create paragraphs. */
  a: string;
}

interface Props {
  items: Item[];
  /** Start with the first item open. Defaults to false. */
  openFirst?: boolean;
}

const { items, openFirst = false } = Astro.props;
---

<div class="divide-y divide-border-subtle border-y border-border-subtle">
  {
    items.map((item, i) => (
      <details
        class="group py-6 md:py-7"
        open={openFirst && i === 0 ? true : undefined}
      >
        <summary class="flex items-start justify-between gap-6 cursor-pointer list-none focus-visible:outline-none">
          <h3 class="font-body text-ink text-[18px] md:text-[20px] font-semibold leading-[1.35]">
            {item.q}
          </h3>
          <span
            class="mt-1 flex-shrink-0 text-slate group-open:text-ink transition-transform duration-[220ms] group-open:rotate-45"
            aria-hidden="true"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
          </span>
        </summary>
        <div class="mt-4 text-graphite text-[16px] leading-[1.65] max-w-[68ch] space-y-3">
          {item.a.split("\n\n").map((p) => (
            <p set:html={p.replace(/\n/g, "<br/>")} />
          ))}
        </div>
      </details>
    ))
  }
</div>

<style>
  /* Hide the default summary marker in Safari/Firefox. */
  summary::-webkit-details-marker { display: none; }
  summary::marker { content: ""; }
</style>
