---
/**
 * Reusable Midnight band — used for closer sections, mid-page emphasis, etc.
 * Flat Midnight by default; pass `gradient` for the atmospheric hero gradient.
 */
interface Props {
  gradient?: boolean;
  size?: "full" | "tall" | "compact";
  id?: string;
  class?: string;
}

const { gradient = false, size = "tall", id, class: className = "" } = Astro.props;

const padding: Record<NonNullable<Props["size"]>, string> = {
  "full":    "py-20 md:py-28",
  "tall":    "py-14 md:py-20",
  "compact": "py-10 md:py-14",
};

const bg = gradient ? "bg-hero-gradient" : "bg-midnight";
---

<section id={id} class:list={[bg, "text-white", padding[size], className]}>
  <div class="mx-auto w-full max-w-[1200px] px-6 md:px-10">
    <slot />
  </div>
</section>
