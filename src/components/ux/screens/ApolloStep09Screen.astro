---
import ApolloStep from "../ios/ApolloStep.astro";
interface Props { variant?: "current" | "legacy"; }
---
<ApolloStep moduleLabel="Morning removal" count="Step 2 of 3" total={3} current={2} badge="Step 09"
  headline="Unclip the Luna Capsule from the Single-Sleep Reservoir" instr="Peel the tab, then press the release button to separate them."
  caption="video: Step 09 — poster TBD">
  <div style="margin-top:18px;"><span class="flag"><span class="k">Hardware</span>Next is blocked until the Capsule is detected as removed</span></div>
  {/* hardware check — gates Next until the capsule is removed from the reservoir */}
  <div slot="checkpoint" class="conn-row">
    <span class="lbl">Capsule removed from Single-Sleep Reservoir</span>
    <span class="stat"><span class="ok"></span><span class="ok-txt">Detected</span></span>
  </div>
</ApolloStep>
