---
/**
 * ConfirmSuccessScreen — positive confirmation after the two-step confirm
 * (v0.4; replaces the old Reset-Required sheet in the confirm flow). The user
 * has updated the setting and committed to the dose: confirm it landed, remind
 * them to take the actual dose this evening, and explain that relearning has
 * started (7 days + 5 sessions; Luna flags the next adjustment if one is
 * needed). Wording keeps the user as the actor — Luna never changed anything
 * on its own. Rendered with `sheet`.
 */
interface Props { variant?: "current" | "legacy"; }
---
{/* dimmed Home backdrop */}
<div class="content backdrop" aria-hidden="true">
  <div class="pad" style="padding-top:8px;">
    <div class="title-2" style="font-weight:700;">Hypo Shield</div>
    <div class="footnote muted" style="margin-top:2px;">Suggestion confirmed</div>
  </div>
  <div class="pad" style="margin-top:18px;">
    <div class="card-dark statuscard">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12.5l2 2 4.5-5"/></svg>
      <div class="headline" style="font-weight:700;">Luna</div>
      <div class="subhead muted">Planning around your new dose</div>
    </div>
  </div>
</div>

{/* dim scrim */}
<div class="scrim"></div>

{/* SUCCESS SHEET — settings adjusted; reminder + relearning */}
<div class="sheet-host">
  <div class="sheet">
    <div class="grabber"></div>
    <div class="hdr"><div class="moon"></div><span class="eyebrow">Hypo Shield · Updated</span></div>

    <span class="success-circle" aria-hidden="true">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
    </span>
    <h2>Your settings have been adjusted</h2>

    <div class="tdbd-now">
      <span class="lbl">Long-acting dose now</span>
      <span class="val">14</span><span class="u">U</span>
    </div>
    <p class="rationale">You've updated your long-acting dose from 12 to 14 units.</p>

    {/* REMINDER — the physical dose still has to happen */}
    <div class="retrieve">
      <span class="ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
      </span>
      <span class="tx"><b>Take your 14-unit dose this evening.</b> Luna will remind you before your session tonight.</span>
    </div>

    {/* RELEARNING — started around the new dose */}
    <div class="retrieve">
      <span class="ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7M21 4v5h-5"/></svg>
      </span>
      <span class="tx">Luna has started re-learning around your new dose. After <b>7 days and 5 sessions</b>, if another adjustment looks needed, Luna will flag it for you.</span>
    </div>

    <button class="btn sheet-primary" type="button">Done</button>
    <div class="skip"><button type="button">View Hypo Shield settings</button></div>
  </div>
</div>

<style is:global>
  .ux-ios .sheet .success-circle {
    display: flex; align-items: center; justify-content: center;
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--color-success-bg, #E6F4EA); color: var(--color-success, #2E7D32);
    margin-bottom: 14px;
  }
</style>
