---
/**
 * ApolloIntroScreen — Apollo Training intro (first session setup). Calm centered
 * intro with a close affordance. Lifted verbatim from `apollo-training/intro.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
{/* top-right close, aligned to the Luna logo (screen-level, like the overnight handoff) */}
<button class="close-x" style="top:64px; left:auto; right:22px;" aria-label="Close">✕</button>
<div class="content" style="position:relative;">
  <div class="center-screen">
    <div class="icon-badge">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-moonlight)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </div>
    <div class="eyebrow">First session setup</div>
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">Let's get you ready for your first sleep with Luna</h1>
    <p class="body muted" style="margin:20px 0 0; line-height:1.65;">Next is a quick walkthrough to help you get ready for your first session with Luna so you can sleep well. This should take about 5 to 10 minutes.</p>
  </div>
  <div class="pad" style="padding-bottom:28px;">
    <button class="btn primary">Let's start</button>
  </div>
</div>
