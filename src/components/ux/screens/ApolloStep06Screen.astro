---
import Icon from "../Icon.astro";
import ApolloStep from "../ios/ApolloStep.astro";
interface Props { variant?: "current" | "legacy"; }
---
<ApolloStep moduleLabel="Getting ready for your first sleep" count="Step 5 of 6" total={6} current={5} badge="Step 05"
  headline="Lift Luna off the base" instr="Using both your hands, lift Luna straight up from the base."
  caption="still: Step 06 — poster TBD">
  <div class="warn-banner" style="margin-top:18px;">
    <span class="ic" aria-hidden="true"><Icon name="warning-triangle" size={20} sw={1.8} /></span>
    <span class="tx">Heads up — there's an exposed needle in this step.</span>
  </div>
</ApolloStep>
