---
/**
 * DashboardScreen — Home dashboard (spine 01). The CGM graph is the HERO.
 * System-status strip leads, then glucose + trend, the full-width overnight
 * CGM graph (target band, Amber 180 line, PLUM 70 critical-low line, Moonlight
 * delivery ticks), an always-visible Luna insight card, and the discreet
 * Ask-Luna launcher. Active-insulin (IOB) row is OFF by default (IOB-gated).
 *
 * Renders the `.content` + tab bar slotted into the locked Phone frame.
 * Copy + markup lifted verbatim from `_spine/01-home-dashboard.html`.
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
import TabBar from "../ios/TabBar.astro";
import AskLuna from "../ios/AskLuna.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  {/* SYSTEM-STATUS cards LEAD (greeting + "session started" removed per review). */}
  <StatusStrip />

  {/* GLUCOSE + TREND hero header */}
  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose">
      <span class="num">112</span>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg);" aria-label="Steady"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </div>
    <div class="footnote muted">mg/dL · steady</div>
  </div>

  {/* HERO CGM GRAPH — full-width; Plum 70 critical-low; Moonlight delivery ticks. */}
  <CgmHero trace="inrange" height={190} />

  {/* INSIGHTS companion — a gentle Luna insight, ALWAYS visible. */}
  <div class="pad" style="margin-top:14px;">
    <div class="card-dark insight-card">
      <span class="ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
      </span>
      <span class="txt"><span class="lead">Steady night.</span> Your glucose held in range and Luna made a few small adjustments while you slept.</span>
    </div>
  </div>

  {/* Active-insulin (IOB) row intentionally OMITTED by default — appears only
      when the IOB Display flag is ON (Settings · 05). See iob-home-on. */}

  <div style="flex:1;"></div>
</div>

{/* Discreet Ask-Luna launcher — pinned bottom-right above the tab bar. */}
<AskLuna bottom={104} />

<TabBar active="dashboard" />
