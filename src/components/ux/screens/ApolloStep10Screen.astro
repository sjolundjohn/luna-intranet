---
import ApolloStep from "../ios/ApolloStep.astro";
interface Props { variant?: "current" | "legacy"; }
---
<ApolloStep moduleLabel="Morning removal" count="Step 3 of 3" total={3} current={3} badge="Step 10"
  headline="Place it on the charger" instr="Set the controller on its charger so it's ready for tonight."
  caption="asset: Cam+A-30" cta="Done" poster="/ux-review/apollo-posters/cam-a-30.jpg" posterAlt="Placing the controller on its charger">
  {/* informative-only checkpoint (never gates Done) */}
  <div slot="checkpoint" class="conn-row">
    <span class="lbl">Controller charging</span>
    <span class="stat"><span class="ok"></span><span class="ok-txt">Connected</span></span>
  </div>
</ApolloStep>
