---
/**
 * ApolloPendingScreen — un-numbered interstitial shown automatically after the
 * capsule is attached (Step 04). A calm, reassuring "Luna is getting ready"
 * moment that buys a few seconds while we verify (behind the scenes) that CGM
 * data is available, the capsule is seated, and priming is underway. Soothing
 * by design — a soft breathing moon, not a technical checklist. On success it
 * auto-advances; on failure it routes to a troubleshooting screen. No step number.
 */
interface Props { variant?: "current" | "legacy"; }
---
<div class="content">
  <div class="pad luna-prep-screen">
    {/* soft breathing moon — calm, not mechanical */}
    <div class="luna-prep" role="img" aria-label="Luna is getting ready">
      <span class="glow g1"></span>
      <span class="glow g2"></span>
      <span class="moon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
          <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" fill="rgba(104,210,223,0.18)" stroke="var(--color-moonlight)" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>

    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0; text-align:center;">Luna is checking the stars are aligned</h1>
    <p class="body muted" style="margin:16px 22px 0; line-height:1.7; text-align:center;">Take a breath — we're getting everything set so you can rest easy. This only takes a moment.</p>

    {/* gentle settling shimmer (calm, no technical readout) */}
    <div class="prep-dots" aria-hidden="true"><span></span><span></span><span></span></div>
  </div>

  <div class="pad" style="padding-bottom:28px;">
    <span class="flag" style="margin:0 auto 14px; display:inline-flex;"><span class="k">Auto</span>advances when ready · issue → troubleshooting</span>
    <button class="btn primary">Continue</button>
  </div>
</div>

<style is:global>
  .ux-ios .luna-prep-screen {
    flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .ux-ios .luna-prep {
    position: relative; width: 150px; height: 150px;
    display: flex; align-items: center; justify-content: center; margin-bottom: 30px;
  }
  .ux-ios .luna-prep .glow {
    position: absolute; border-radius: 50%;
    background: radial-gradient(circle, rgba(104,210,223,0.30), rgba(104,210,223,0) 70%);
  }
  .ux-ios .luna-prep .g1 { inset: 0; animation: lunaBreathe 4.2s ease-in-out infinite; }
  .ux-ios .luna-prep .g2 { inset: 26px; animation: lunaBreathe 4.2s ease-in-out infinite 0.6s; }
  .ux-ios .luna-prep .moon {
    position: relative; z-index: 1; filter: drop-shadow(0 0 12px rgba(104,210,223,0.45));
    animation: lunaFloat 5s ease-in-out infinite;
  }
  @keyframes lunaBreathe {
    0%, 100% { transform: scale(0.92); opacity: 0.45; }
    50%      { transform: scale(1.08); opacity: 0.9; }
  }
  @keyframes lunaFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-5px); }
  }
  .ux-ios .prep-dots { display: flex; gap: 8px; margin-top: 30px; }
  .ux-ios .prep-dots span {
    width: 6px; height: 6px; border-radius: 50%; background: var(--color-moonlight);
    opacity: 0.3; animation: prepPulse 1.6s ease-in-out infinite;
  }
  .ux-ios .prep-dots span:nth-child(2) { animation-delay: 0.25s; }
  .ux-ios .prep-dots span:nth-child(3) { animation-delay: 0.5s; }
  @keyframes prepPulse {
    0%, 100% { opacity: 0.25; transform: scale(0.85); }
    50%      { opacity: 0.95; transform: scale(1); }
  }
</style>
