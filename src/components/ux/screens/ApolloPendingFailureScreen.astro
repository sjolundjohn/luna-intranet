---
/**
 * ApolloPendingFailureScreen — troubleshooting/error state for the "Luna is
 * checking…" Pending step. Shown ONLY when the pre-session check fails after the
 * capsule is attached. Helps the user tell whether the issue is the CGM, the
 * Capsule not seated on the Single-Sleep Reservoir, or something else, and gives
 * a clear way to retry or get back to setup. Calm, not alarming.
 */
interface Props { variant?: "current" | "legacy"; }
---
<div class="content">
  <div class="pad" style="flex:1; display:flex; flex-direction:column; padding-top:16px;">
    <div style="text-align:center; padding:6px 0 2px;">
      <div style="display:flex; justify-content:center; margin-bottom:16px;">
        <span style="display:inline-flex; align-items:center; justify-content:center; width:60px; height:60px; border-radius:50%; background:rgba(249,205,134,0.12); border:1px solid rgba(249,205,134,0.35);">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/></svg>
        </span>
      </div>
      <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">Let's get this sorted</h1>
      <p class="subhead muted" style="margin:10px 16px 0; line-height:1.55;">We couldn't quite finish getting Luna ready. Let's check a couple of things and try again.</p>
    </div>

    {/* which check failed */}
    <div class="stack" style="gap:8px; margin-top:22px;">
      <div class="conn-row">
        <span class="lbl">CGM data</span>
        <span class="stat"><span class="ok"></span><span class="ok-txt">OK</span></span>
      </div>
      <div class="conn-row" style="background:rgba(249,205,134,0.07); border-color:rgba(249,205,134,0.30);">
        <span class="lbl">Capsule on the Single-Sleep Reservoir</span>
        <span class="stat"><span style="width:8px; height:8px; border-radius:50%; background:var(--color-warning); box-shadow:0 0 8px rgba(249,205,134,0.6);"></span><span style="color:var(--color-warning); font-weight:600;">Not seated</span></span>
      </div>
      <div class="conn-row">
        <span class="lbl">Priming</span>
        <span class="stat"><span style="width:8px; height:8px; border-radius:50%; background:var(--color-on-dark-sub);"></span><span class="ok-txt" style="color:var(--color-on-dark-sub);">On hold</span></span>
      </div>
    </div>

    <div class="warn-banner" style="margin-top:16px;">
      <span class="ic" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/><path d="M12 9v4M12 17h.01"/></svg></span>
      <span class="tx">Make sure the Capsule is snapped firmly onto the Single-Sleep Reservoir, then try again.</span>
    </div>

    <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:14px;">
      <span class="flag"><span class="k">Shows only</span>when the readiness check fails</span>
    </div>

    <div style="flex:1;"></div>
  </div>

  <div class="pad" style="padding-bottom:28px;">
    <div class="stack" style="gap:10px;">
      <button class="btn primary">Try again</button>
      <button class="btn secondary">Back to setup</button>
    </div>
  </div>
</div>
