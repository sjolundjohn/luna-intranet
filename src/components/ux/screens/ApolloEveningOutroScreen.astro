---
/**
 * ApolloEveningOutroScreen — evening outro (personal "Tonight" video). Auto-loops,
 * NO "Watch again". Lifted verbatim from `apollo-training/evening-outro.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="video-tile">
    <div class="scrim"></div>
    <button class="play" aria-label="Play step video">
      <svg width="18" height="18" viewBox="0 0 16 16"><path d="M5 3l9 5-9 5V3z" fill="#041E42"/></svg>
    </button>
    <span class="cap">video: Personal · Tonight — poster TBD</span>
    <span class="loop">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2l4 4-4 4M21 6H7a4 4 0 0 0-4 4v1M7 22l-4-4 4-4M3 18h14a4 4 0 0 0 4-4v-1"/></svg>
      Auto-loops
    </span>
  </div>

  <div class="pad" style="flex:1; display:flex; flex-direction:column; padding-top:20px;">
    <div class="step-badge" style="margin:0 0 12px;"><span class="dot"></span>Personal video · Tonight</div>
    <div style="flex:1; display:flex; flex-direction:column; justify-content:center; padding-bottom:12px;">
      <h1 class="title-2" style="font-weight:700; letter-spacing:-0.02em; margin:0;">You're all set for tonight.</h1>
      <p class="body muted" style="margin:12px 0 0; line-height:1.55;">Here's a quick note on what to expect on your first night with Luna — how it feels, what the alerts sound like, and what to do if anything surprises you.</p>
    </div>
  </div>

  <div class="pad" style="padding-bottom:8px;">
    <button class="btn primary">Continue</button>
  </div>
</div>
