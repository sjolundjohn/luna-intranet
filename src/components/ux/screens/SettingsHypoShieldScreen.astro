---
/**
 * SettingsHypoShieldScreen — Settings › Hypo Shield (v0.4). The ONE management
 * surface: feature state, last suggestions + dispositions, your long-acting
 * dose, learning progress and the full history (merged from the deleted TDBD
 * Detail screen — the Home chip deep-links here), and help. Study-facing
 * "always on" copy removed: it's not an option, so it isn't flagged as one.
 */
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
const chev = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>';
const check = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
---
<div class="content">
  {/* nav header: Moonlight back ("Settings"), then "Hypo Shield" title; NO divider */}
  <div class="navbar">
    <button class="back" aria-label="Settings">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      Settings
    </button>
  </div>
  <div class="pad" style="padding-bottom:10px;"><h1 style="margin:0; font-size:28px; font-weight:700; letter-spacing:-0.015em;">Hypo Shield</h1></div>

  <div class="pad" style="overflow-y:auto;">
    {/* FEATURE-STATE hero: always-on, no participant toggle */}
    <div class="card-dark feat-card">
      <div class="head">
        <span class="moon" aria-hidden="true"></span>
        <div>
          <div class="nm">Hypo Shield</div>
          <div class="state"><span class="dot"></span>Active</div>
        </div>
      </div>
      <div class="desc">Hypo Shield learns your overnight insulin needs and suggests a corrected dose when your long-acting dose looks mis-set. It never changes your dose for you.</div>
    </div>

    {/* LAST SUGGESTIONS + disposition */}
    <div class="sec-label">Last suggestions</div>
    <div class="list">
      <div class="row">
        <span class="sub-label">
          <span class="t">New dose · 14 U</span>
          <span class="s">May 26 · 10:18 PM</span>
        </span>
        <span class="disp skipped">Skipped</span>
        <span class="chev" set:html={chev} />
      </div>
      <div class="row">
        <span class="sub-label">
          <span class="t">New dose · 14 U</span>
          <span class="s">May 24 · 9:32 AM</span>
        </span>
        <span class="disp applied">Applied</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    {/* DOSING — your long-acting dose (the Home chip deep-links here) */}
    <div class="sec-label">Dosing</div>
    <div class="list">
      <div class="row">
        <span class="label">Long-acting dose</span>
        <span class="value">12 U</span>
      </div>
    </div>

    {/* LEARNING — merged from the old TDBD detail */}
    <div class="sec-label">Learning</div>
    <div class="card-dark" style="padding:18px;">
      <div class="lp">
        <div class="lp-item">
          <div class="lp-top">
            <span class="lp-lbl"><span class="done" set:html={check} /> Luna sessions</span>
            <span class="lp-count">5 of 5</span>
          </div>
          <div class="lp-bar"><i style="width:100%;"></i></div>
        </div>
        <div class="lp-item">
          <div class="lp-top">
            <span class="lp-lbl"><span class="done" set:html={check} /> Days of wear</span>
            <span class="lp-count">7 of 7</span>
          </div>
          <div class="lp-bar"><i style="width:100%;"></i></div>
        </div>
      </div>
      <span class="learned">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        Learned · Hypo Shield can now suggest
      </span>
    </div>

    {/* HISTORY — merged from the old TDBD detail */}
    <div class="sec-label" style="margin-top:14px;">History</div>
    <div class="list">
      <div class="hist-row">
        <span class="dt">May<br>26</span>
        <span class="mid">
          <span class="t">Suggested 14 U</span>
          <span class="s">Drifted up · you declined</span>
        </span>
        <span class="tag skipped">Skipped</span>
      </div>
      <div class="hist-row">
        <span class="dt">May<br>24</span>
        <span class="mid">
          <span class="t">Changed to 12 U</span>
          <span class="s">Suggestion applied</span>
        </span>
        <span class="tag applied">Applied</span>
      </div>
      <div class="hist-row">
        <span class="dt">May<br>19</span>
        <span class="mid">
          <span class="t">Manual change to 10 U</span>
          <span class="s">Learning reset, then re-learned</span>
        </span>
        <span class="tag reset">Reset</span>
      </div>
      <div class="hist-row">
        <span class="dt">May<br>12</span>
        <span class="mid">
          <span class="t">Started at 10 U</span>
          <span class="s">Your starting dose at setup</span>
        </span>
        <span class="tag applied">Set</span>
      </div>
    </div>

    {/* Help */}
    <div class="sec-label" style="margin-top:14px;">Support</div>
    <div class="list">
      <div class="row">
        <span class="label">How Hypo Shield works</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    <div style="height:12px;"></div>
  </div>

  <div style="flex:1;"></div>
</div>

<TabBar active="settings" />
