---
import Icon from "../Icon.astro";
/**
 * SettingsHypoShieldScreen — Settings › Hypo Shield (v0.5). Simplified to the
 * two things users need: (1) an on/off toggle with a clear current state, and
 * (2) a plain explanation of what Hypo Shield is and how it works (merged from
 * the deleted How-it-works screen). No suggestion log / history / dosing log.
 * White-card layout + colors matching the rest of the feature (the old dark
 * cards were too low-contrast to read).
 */
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  {/* nav header: Moonlight back ("Settings"), then "Hypo Shield" title */}
  <div class="navbar">
    <button class="back" aria-label="Settings">
      <Icon name="chevron-left" size={22} sw={2} />
      Settings
    </button>
  </div>
  <div class="pad" style="padding-bottom:10px;"><h1 style="margin:0; font-size:28px; font-weight:700; letter-spacing:-0.015em; color:var(--color-on-dark);">Hypo Shield</h1></div>

  <div class="pad" style="overflow-y:auto;">
    {/* ON/OFF toggle + clear state */}
    <div class="card-dark hypo-pop hs-set-card">
      <div class="hs-set-top">
        <span class="moon" aria-hidden="true"></span>
        <div class="hs-set-name">
          <div class="nm">Hypo Shield</div>
          <div class="state"><span class="dot"></span>On · learning your nights</div>
        </div>
        <button class="hs-toggle on" role="switch" aria-checked="true" aria-label="Turn Hypo Shield off"><span class="knob"></span></button>
      </div>
      <p class="hs-set-desc">Hypo Shield watches your nighttime glucose and, once it's learned your nights, suggests a long-acting dose change if yours looks set too high or too low. It never changes anything until you confirm.</p>
    </div>

    {/* WHAT IT IS / HOW IT WORKS — merged from the old How-it-works screen */}
    <div class="sec-label">How it works</div>
    <div class="card-dark hypo-pop hs-set-card">
      <div class="hiw-row">
        <div class="hiw-h">It learns first</div>
        <p>Over your first <b>7 Luna sessions</b>, Luna learns your overnight patterns and doses conservatively. The sessions don't need to be consecutive.</p>
      </div>
      <div class="hiw-div"></div>
      <div class="hiw-row">
        <div class="hiw-h">It suggests — you decide</div>
        <p>When your long-acting dose looks mis-set, Hypo Shield suggests a change and explains why. Nothing happens until you confirm.</p>
      </div>
      <div class="hiw-div"></div>
      <div class="hiw-row">
        <div class="hiw-h">You stay in control</div>
        <p>You take the new dose yourself; if you allow it, Luna updates your long-acting insulin setting in the app. You can turn Hypo Shield off any time using the switch above.</p>
      </div>
    </div>

    <div style="height:12px;"></div>
  </div>

  <div style="flex:1;"></div>
</div>

<TabBar active="settings" />
