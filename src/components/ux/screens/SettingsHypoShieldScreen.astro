---
/**
 * SettingsHypoShieldScreen — Settings › Hypo Shield. Always-on for the T1D
 * pivotal (NO participant toggle); the product-level disable exists only for
 * T2D basal-only, surfaced as an explanatory footnote, not a user control.
 * Shows feature state, last recommendation + disposition, TDBD + learning, help.
 * Lifted verbatim from `hypo-shield/settings-hypo-shield.html`.
 */
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
const chev = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>';
---
<div class="content">
  {/* nav header: Moonlight back ("Settings"), then "Hypo Shield" title; NO divider */}
  <div class="navbar">
    <button class="back" aria-label="Settings">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      Settings
    </button>
  </div>
  <div class="pad" style="padding-bottom:10px;"><h1 style="margin:0; font-size:28px; font-weight:700; letter-spacing:-0.015em;">Hypo Shield</h1></div>

  <div class="pad" style="overflow-y:auto;">
    {/* FEATURE-STATE hero: always-on, no participant toggle */}
    <div class="card-dark feat-card">
      <div class="head">
        <span class="moon" aria-hidden="true"></span>
        <div>
          <div class="nm">Hypo Shield</div>
          <div class="state"><span class="dot"></span>Active</div>
        </div>
      </div>
      <div class="desc">Hypo Shield learns your overnight basal needs and suggests a corrected dose when your standing basal looks mis-set. It never changes your dose for you.</div>
      <div class="alwayson">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Always on for your study
      </div>
      <div class="t2d-note">A product-level disable exists for T2D basal-only users; it isn't a setting you control in the pivotal.</div>
    </div>

    {/* LAST RECOMMENDATION + disposition */}
    <div class="sec-label">Last recommendation</div>
    <div class="list">
      <div class="row">
        <span class="sub-label">
          <span class="t">New basal · 14 U</span>
          <span class="s">May 26 · 10:18 PM</span>
        </span>
        <span class="disp skipped">Skipped</span>
        <span class="chev" set:html={chev} />
      </div>
      <div class="row">
        <span class="sub-label">
          <span class="t">New basal · 14 U</span>
          <span class="s">May 24 · 9:32 AM</span>
        </span>
        <span class="disp applied">Applied</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    {/* TDBD + detail */}
    <div class="sec-label">Dosing</div>
    <div class="list">
      <div class="row">
        <span class="label">Total daily basal (TDBD)</span>
        <span class="value">12 U</span>
        <span class="chev" set:html={chev} />
      </div>
      <div class="row">
        <span class="label">Learning &amp; history</span>
        <span class="value">5 sessions · 7 days</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    {/* Help */}
    <div class="sec-label">Support</div>
    <div class="list">
      <div class="row">
        <span class="label">How Hypo Shield works</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    <div style="height:12px;"></div>
  </div>

  <div style="flex:1;"></div>
</div>

<TabBar active="settings" />
