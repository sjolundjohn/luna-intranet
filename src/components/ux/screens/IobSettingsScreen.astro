---
import Icon from "../Icon.astro";
/**
 * IobSettingsScreen — Settings › IOB Display (v0.5 standards). White-card
 * layout matching Hypo Shield settings (the old dark cards were low-contrast):
 * an on/off toggle (DEFAULT OFF — opt-in) with a clear state, and a plain
 * explanation of what IOB shows. IOB counts Luna-delivered insulin only and is
 * decision-support — it never instructs or changes a dose. No logs/history.
 */
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="navbar">
    <button class="back" aria-label="Back to Settings">
      <Icon name="chevron-left" size={22} sw={2} />
      Settings
    </button>
  </div>
  <div class="pad" style="padding-bottom:10px;"><h1 style="margin:0; font-size:28px; font-weight:700; letter-spacing:-0.015em; color:var(--color-on-dark);">Insulin on board</h1></div>

  <div class="pad" style="overflow-y:auto;">
    {/* ON/OFF toggle + clear state — DEFAULT OFF (opt-in) */}
    <div class="card-dark hypo-pop hs-set-card">
      <div class="hs-set-top">
        <span class="moon" aria-hidden="true"></span>
        <div class="hs-set-name">
          <div class="nm">Insulin on board</div>
          <div class="state off"><span class="dot"></span>Off</div>
        </div>
        <button class="hs-toggle" role="switch" aria-checked="false" aria-label="Turn insulin on board on"><span class="knob"></span></button>
      </div>
      <p class="hs-set-desc">When on, your Home screen shows how much of your Luna-delivered insulin is still active — so you can avoid stacking a dose on top of insulin that's still working. Off by default.</p>
    </div>

    {/* WHAT IT SHOWS — plain language, decision-support only */}
    <div class="sec-label">What it shows</div>
    <div class="card-dark hypo-pop hs-set-card">
      <div class="hiw-row">
        <div class="hiw-h">Luna-delivered insulin only</div>
        <p>Counts the insulin Luna delivered overnight — not insulin you take outside Luna.</p>
      </div>
      <div class="hiw-div"></div>
      <div class="hiw-row">
        <div class="hiw-h">During and after a session</div>
        <p>Shows while a session is active, then the residual amount after it ends until that insulin clears — e.g. 0.4 U.</p>
      </div>
      <div class="hiw-div"></div>
      <div class="hiw-row">
        <div class="hiw-h">Information, not instruction</div>
        <p>It's there to help you decide. Luna won't recommend, change, or deliver a dose based on it.</p>
      </div>
    </div>

    <div style="height:12px;"></div>
  </div>

  <div style="flex:1;"></div>
</div>

<TabBar active="settings" />
