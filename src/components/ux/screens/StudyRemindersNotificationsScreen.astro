---
/**
 * StudyRemindersNotificationsScreen — the two study reminders as they appear on
 * the iOS lock screen (v0.1). Delivered by Apple Health / iOS, so they reach the
 * user even when Luna is closed. Two examples stacked bottom-aligned (stock iOS
 * 16+ placement): the nightly wear reminder and the missed-session nudge.
 * Modeled on the Hypo push-notification screen.
 */
interface Props { variant?: "current" | "legacy"; }
---
<div class="content">
  {/* LOCK-SCREEN FACE */}
  <div class="lockface">
    <div class="date">Tuesday, May 26</div>
    <div class="time">9:30</div>
    <div class="lock" aria-hidden="true">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Locked
    </div>
  </div>

  {/* NOTIFICATION ZONE — two study reminders, bottom-stacked (iOS 16+) */}
  <div class="notif-zone">
    <div class="flow-note">
      <span class="ic" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      </span>
      <span class="ln"><b>Delivered by Apple Health / iOS.</b> These reminders are scheduled in the OS, so they reach the user even when Luna is closed. Tapping opens Luna.</span>
    </div>

    {/* NIGHTLY WEAR */}
    <button class="push" aria-label="Time for tonight's Luna session">
      <span class="app-ico" aria-hidden="true"></span>
      <span class="body-txt">
        <span class="top"><span class="nm">Luna</span><span class="ago">now</span></span>
        <span class="ttl">Time for tonight's Luna session</span>
        <span class="msg">Wear Luna before bed to keep your study on track.</span>
      </span>
    </button>

    {/* MISSED-SESSION NUDGE */}
    <button class="push" aria-label="You missed last night's session" style="margin-top:10px;">
      <span class="app-ico" aria-hidden="true"></span>
      <span class="body-txt">
        <span class="top"><span class="nm">Luna</span><span class="ago">8:00 AM</span></span>
        <span class="ttl">You missed last night's session</span>
        <span class="msg">No problem — wear Luna tonight so your study stays on track.</span>
      </span>
    </button>
  </div>
</div>
