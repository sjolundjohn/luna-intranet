---
/**
 * ApolloTrainingGateScreen — conditional pre-start gate. Shown ONLY when the
 * preconditions for a first Luna session aren't met. Confirms three things:
 *   • TDBD entered
 *   • Luna Capsule paired & present
 *   • A recent CGM value (within ~10 min)
 * If any fail, training can't start — the user is routed back to setup to fix
 * it. Rendered here in a representative failure state (Capsule not detected).
 */
interface Props { variant?: "current" | "legacy"; }
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title" style="font-weight:600; color:var(--color-on-dark);">Before you start</span>
    </div>
  </div>

  <div class="pad" style="margin-top:18px; flex:1; display:flex; flex-direction:column;">
    <div style="text-align:center; padding:8px 0 4px;">
      <div style="display:flex; justify-content:center; margin-bottom:18px;">
        <span style="display:inline-flex; align-items:center; justify-content:center; width:64px; height:64px; border-radius:50%; background:rgba(249,205,134,0.12); border:1px solid rgba(249,205,134,0.35);">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>
        </span>
      </div>
      <div class="title-2" style="font-weight:700; letter-spacing:-0.02em;">Let's finish setup first</div>
      <p class="subhead muted" style="margin:8px 14px 0; line-height:1.55;">Luna needs a few things in place before your first session.</p>
    </div>

    {/* condition checklist */}
    <div class="stack" style="gap:8px; margin-top:22px;">
      <div class="conn-row">
        <span class="lbl">TDBD entered</span>
        <span class="stat"><span class="ok"></span><span class="ok-txt">Set</span></span>
      </div>
      <div class="conn-row" style="background:rgba(249,205,134,0.07); border-color:rgba(249,205,134,0.30);">
        <span class="lbl">Luna Capsule paired</span>
        <span class="stat"><span style="width:8px; height:8px; border-radius:50%; background:var(--color-warning); box-shadow:0 0 8px rgba(249,205,134,0.6);"></span><span style="color:var(--color-warning); font-weight:600;">Not detected</span></span>
      </div>
      <div class="conn-row">
        <span class="lbl">Recent CGM reading</span>
        <span class="stat"><span class="ok"></span><span class="ok-txt">OK · 2 min ago</span></span>
      </div>
    </div>

    <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:18px;">
      <span class="flag"><span class="k">Shows only</span>when a precondition fails</span>
    </div>

    <div style="flex:1;"></div>
  </div>

  <div class="pad" style="padding-bottom:28px;">
    <button class="btn primary">Go to setup</button>
  </div>
</div>
