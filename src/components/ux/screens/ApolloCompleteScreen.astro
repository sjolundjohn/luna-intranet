---
/**
 * ApolloCompleteScreen — Apollo Training complete (redesign v2.3, merges the
 * old Morning Outro + Complete into ONE screen). Warm, positive close: Luna-branded
 * moon-to-dawn hero, the message that Luna really starts here, and a
 * non-technical note that Luna is now learning about you + your long-acting dose
 * and will keep optimizing your settings so you sleep even better. Clock 7:18.
 */
interface Props { variant?: "current" | "legacy"; }
---
<div class="content">
  <div class="center-screen" style="justify-content:flex-start; padding-top:12px;">
    <div class="morning-hero" role="img" aria-label="Luna watching over your night — dawn breaking">
      <div class="sky-base"></div>
      <div class="dawn-sky-overlay"></div>

      <div class="star star-1"></div>
      <div class="star star-2"></div>
      <div class="star star-3"></div>
      <div class="star star-4"></div>
      <div class="star star-5"></div>

      <div class="horizon-glow"></div>

      <svg class="luna-moon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
      </svg>

      <svg class="cgm-svg" viewBox="0 0 1000 170" preserveAspectRatio="none" aria-hidden="true">
        <path class="trace-line" d="M 0,118 Q 200,112 400,122 T 750,116 L 930,118" />
      </svg>
      <div class="terminal-pulse-wrapper">
        <div class="terminal-dot"></div>
        <div class="terminal-pulse"></div>
      </div>
    </div>

    <div class="eyebrow" style="color:#E6A94B;">You're all set</div>
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">This is where Luna really begins</h1>
    <p class="body muted" style="margin:14px 0 0; line-height:1.6;">Nice work — your first night's done. From here, Luna learns about you and your long-acting dose, getting better each night at optimizing your settings so you sleep even better.</p>

    <div class="card-dark" style="margin-top:16px; display:flex; gap:12px; align-items:flex-start; text-align:left;">
      <span style="flex:none; color:var(--color-moonlight); margin-top:1px;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M5 8c2.5 0 4 1.5 4 4M19 8c-2.5 0-4 1.5-4 4"/></svg>
      </span>
      <div>
        <div style="font-weight:700; color:var(--color-on-dark); font-size:15px;">Luna is learning</div>
        <div class="subhead muted" style="margin-top:3px;">Each night sharpens your overnight settings — you don't have to do anything.</div>
      </div>
    </div>
  </div>

  <div class="pad" style="padding-bottom:24px;">
    <button class="btn primary">Go to dashboard</button>
  </div>
</div>

<style is:global>
  .ux-ios .morning-hero {
    position: relative;
    width: 100%;
    height: 170px;
    border-radius: 20px;
    overflow: hidden;
    background-color: #031632;
    margin-bottom: 18px;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .ux-ios .morning-hero .sky-base {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top center, #031632, #041E42);
    z-index: 1;
  }

  .ux-ios .morning-hero .dawn-sky-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, #E8975A 0%, #C97BA0 12%, #3a2a1a 25%, #1a1f4a 45%, transparent 100%);
    z-index: 2;
    mix-blend-mode: screen;
    animation: dawnSequence 60s ease-in-out infinite;
  }

  .ux-ios .morning-hero .star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: #ffffff;
    border-radius: 50%;
    z-index: 3;
  }
  .ux-ios .morning-hero .star-1 { top: 25px; left: 15%; animation: starTwinkle 60s infinite 0.1s; }
  .ux-ios .morning-hero .star-2 { top: 45px; left: 28%; animation: starTwinkle 60s infinite 0.4s; }
  .ux-ios .morning-hero .star-3 { top: 20px; left: 45%; animation: starTwinkle 60s infinite 0.2s; }
  .ux-ios .morning-hero .star-4 { top: 35px; left: 72%; animation: starTwinkle 60s infinite 0.6s; }
  .ux-ios .morning-hero .star-5 { top: 50px; left: 88%; animation: starTwinkle 60s infinite 0.3s; }

  .ux-ios .morning-hero .horizon-glow {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 80px;
    background: radial-gradient(ellipse at center, rgba(233,151,90,0.45) 0%, transparent 70%);
    z-index: 4;
    animation: horizonBloom 60s ease-in-out infinite;
  }

  .ux-ios .morning-hero .luna-moon {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 30px;
    height: 30px;
    z-index: 5;
    filter: drop-shadow(0 0 12px rgba(104,210,223,0.55));
    animation: moonLifecycle 60s ease-in-out infinite;
  }
  .ux-ios .morning-hero .luna-moon path {
    stroke: #68D2DF;
    stroke-width: 1px;
    fill: rgba(104,210,223,0.15);
  }

  .ux-ios .morning-hero .cgm-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 6;
  }
  .ux-ios .morning-hero .trace-line {
    fill: none;
    stroke: #68D2DF;
    stroke-width: 1.5px;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: drawTrace 60s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .ux-ios .morning-hero .terminal-pulse-wrapper {
    position: absolute;
    left: 93%;
    top: 118px;
    transform: translate(-50%, -50%);
    z-index: 7;
  }
  .ux-ios .morning-hero .terminal-dot {
    width: 5px;
    height: 5px;
    background-color: #68D2DF;
    border-radius: 50%;
    box-shadow: 0 0 6px #68D2DF;
    animation: dotState 60s ease-in-out infinite;
  }
  .ux-ios .morning-hero .terminal-pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 5px;
    height: 5px;
    margin: -2.5px 0 0 -2.5px;
    border: 1.5px solid #68D2DF;
    border-radius: 50%;
    opacity: 0;
    animation: terminalPulse 60s cubic-bezier(0.1, 0.8, 0.3, 1) infinite;
  }

  @keyframes dawnSequence {
    0%, 10% { opacity: 0; }
    40%, 84% { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes horizonBloom {
    0%, 10% { transform: translate(-50%, 0) scale(0.7); opacity: 0.2; }
    40%, 84% { transform: translate(-50%, -10px) scale(1.1); opacity: 0.6; }
    100% { transform: translate(-50%, 0) scale(0.7); opacity: 0.2; }
  }

  @keyframes starTwinkle {
    0%, 10% { opacity: 0.6; transform: scale(1); }
    30% { opacity: 0.1; }
    40%, 84% { opacity: 0; transform: scale(0.5); }
    100% { opacity: 0.6; transform: scale(1); }
  }

  @keyframes moonLifecycle {
    0%, 10% { opacity: 0.9; transform: translate(-50%, 0); }
    40% { opacity: 0.15; transform: translate(-50%, -2px); }
    84% { opacity: 0.15; transform: translate(-50%, -4px); }
    100% { opacity: 0.9; transform: translate(-50%, 0); }
  }

  @keyframes drawTrace {
    0%, 20% { stroke-dashoffset: 1000; }
    50%, 84% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 1000; }
  }

  @keyframes dotState {
    0%, 48% { opacity: 0; }
    50%, 84% { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes terminalPulse {
    0%, 50% { transform: scale(1); opacity: 0; }
    53% { transform: scale(3.5); opacity: 0.8; }
    58%, 84% { transform: scale(5); opacity: 0; }
    100% { transform: scale(1); opacity: 0; }
  }
</style>
