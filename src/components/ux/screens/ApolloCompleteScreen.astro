---
/**
 * ApolloCompleteScreen — Apollo Training complete. Pop-in check + "You're all
 * set." + stat cards (10 steps done / 1 night logged). Clock 7:18.
 * Lifted verbatim from `apollo-training/complete.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="center-screen">
    <div class="complete-check">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-midnight)" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">You're all set.</h1>
    <p class="body muted" style="margin:14px 0 0; line-height:1.55;">Luna is ready for tonight. From here, it's just the evening steps — you'll know them by heart.</p>
    <div class="stat-row">
      <div class="stat-card"><div class="v">10</div><div class="l">Steps done</div></div>
      <div class="stat-card"><div class="v">1</div><div class="l">Night logged</div></div>
    </div>
  </div>
  <div class="pad" style="padding-bottom:8px;">
    <button class="btn primary">Go to dashboard</button>
  </div>
</div>
