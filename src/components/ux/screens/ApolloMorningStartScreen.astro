---
/**
 * ApolloMorningStartScreen — morning re-entry (redesign v2.3). Feels alive: a
 * fresh morning, sunrise warmth, a flower opening — like the first restful,
 * restorative sleep of your life. Progress shows DOTS from the beginning of the
 * morning module (not a ¾-full bar). Clock 7:12.
 */
interface Props { variant?: "current" | "legacy"; }
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title" style="font-weight:600; color:var(--color-on-dark);">Morning · session start</span>
    </div>
    {/* dots from the start of the morning module (3 steps) — not a ¾ bar */}
    <div class="prog-dots" role="img" aria-label="Morning — start">
      <span class="d current"></span><span class="d"></span><span class="d"></span>
    </div>
  </div>

  <div class="center-screen">
    {/* sunrise + opening flower — a fresh, alive start to the day */}
    <div class="morning-hero" role="img" aria-label="Sunrise over a blooming flower">
      <span class="sun-glow"></span>
      <span class="sun-disc"></span>
      <svg class="flower" width="84" height="84" viewBox="0 0 48 48" fill="none">
        <path d="M24 26V44" stroke="#5BBE7A" stroke-width="2.6" stroke-linecap="round"/>
        <path d="M24 36c-3.2-.4-5.4-3-5.4-3s3.8-.6 5.4 2.2z" fill="#5BBE7A"/>
        <path d="M24 31c3.2-.4 5.4-3 5.4-3s-3.8-.6-5.4 2.2z" fill="#5BBE7A"/>
        <g class="petals">
          <circle cx="24" cy="13" r="5.4" fill="#FF8FA3"/>
          <circle cx="33" cy="19" r="5.4" fill="#FFB3C2"/>
          <circle cx="30" cy="29" r="5.4" fill="#FF9DB0"/>
          <circle cx="18" cy="29" r="5.4" fill="#FF9DB0"/>
          <circle cx="15" cy="19" r="5.4" fill="#FFB3C2"/>
        </g>
        <circle cx="24" cy="21" r="5.2" fill="#FFC94D"/>
      </svg>
    </div>

    <div class="eyebrow" style="color:#E6A94B;">Good morning</div>
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">Good morning, sunshine</h1>
    <p class="body muted" style="margin:16px 0 0; line-height:1.65;">You've had your first night with Luna. Let's take it off and get it charged for tonight.</p>
  </div>

  <div class="pad" style="padding-bottom:24px;">
    <button class="btn primary">Start morning steps</button>
  </div>
</div>

<style is:global>
  .ux-ios .morning-hero {
    position: relative; width: 100%; height: 170px; border-radius: 22px; overflow: hidden;
    display: flex; align-items: flex-end; justify-content: center; margin-bottom: 22px;
    background: linear-gradient(180deg, #15264f 0%, #3a4f86 28%, #E8975A 76%, #F8CE86 100%);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .ux-ios .morning-hero .sun-glow {
    position: absolute; bottom: -55px; width: 230px; height: 230px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,214,140,0.9), rgba(255,184,96,0) 62%);
    animation: sunRise 3.6s ease-in-out infinite;
  }
  .ux-ios .morning-hero .sun-disc {
    position: absolute; bottom: 6px; width: 72px; height: 72px; border-radius: 50%;
    background: radial-gradient(circle at 50% 38%, #FFE9AE, #FFC24D 68%, #FF9E3D);
    box-shadow: 0 0 34px rgba(255,196,77,0.75); animation: sunRise 3.6s ease-in-out infinite;
  }
  .ux-ios .morning-hero .flower {
    position: relative; z-index: 1; margin-bottom: 12px; transform-origin: bottom center;
    animation: flowerBloom 3.2s ease-in-out infinite; filter: drop-shadow(0 5px 12px rgba(0,0,0,0.28));
  }
  @keyframes sunRise { 0%, 100% { transform: translateY(22px); opacity: 0.85; } 50% { transform: translateY(-4px); opacity: 1; } }
  @keyframes flowerBloom { 0%, 100% { transform: scale(0.88) rotate(-3deg); } 50% { transform: scale(1.1) rotate(3deg); } }
</style>
