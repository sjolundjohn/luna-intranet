---
/**
 * ApolloMorningStartScreen — next-morning re-entry into Morning training. A
 * single clear way back in. Clock 7:12. (BR-B4 trigger mechanism is BRD-undecided
 * — this is the destination.) Lifted verbatim from `apollo-training/morning-start.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title" style="font-weight:600; color:var(--color-on-dark);">Morning · session start</span>
    </div>
    <div class="prog-bar"><i style="width:70%"></i></div>
  </div>
  <div class="center-screen">
    <div class="icon-badge" style="border-radius:50%;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-moonlight)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
    </div>
    <div class="eyebrow">Good morning</div>
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">Good morning.</h1>
    <p class="body muted" style="margin:14px 0 0; line-height:1.55;">Time to remove the device and place the controller on its charger for tonight.</p>
  </div>
  <div class="pad" style="padding-bottom:8px;">
    <button class="btn primary">Start morning steps</button>
  </div>
</div>
