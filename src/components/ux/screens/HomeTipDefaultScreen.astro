---
/**
 * HomeTipDefaultScreen — Home, Hypo Shield "Default Tip" RESTING state. No
 * pending recommendation: a calm reassurance card stating the standing nightly
 * basal (a chip that opens TDBD detail), NOT an accept control.
 * Lifted verbatim from `hypo-shield/home-tip-default.html`.
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
import TabBar from "../ios/TabBar.astro";
import AskLuna from "../ios/AskLuna.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <StatusStrip />

  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose">
      <span class="num">112</span>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg);" aria-label="Steady"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </div>
    <div class="footnote muted">mg/dL · steady</div>
  </div>

  {/* HERO CGM GRAPH — fills the freed space (tip bar sits at the bottom). */}
  <CgmHero trace="inrange" fill />

  {/* HYPO SHIELD "DEFAULT TIP" at the bottom, with the Ask-Luna "+" on its
      top-right corner. The bubble only appears when Hypo Shield has something
      to say — the first thing it says is that it's learning about you. The
      chip deep-links to Settings · Hypo Shield. */}
  <div class="pad" style="margin-top:12px; padding-bottom:8px;">
    <div class="insight-wrap" style="position:relative;">
      <AskLuna anchor="card" />
      <div class="card-dark tip-card hypo-pop">
        <div class="head">
          <span class="moon" aria-hidden="true"></span>
          <span class="eyebrow">Hypo Shield</span>
        </div>
        <div class="lead">Luna is getting to know your nights. You'll hear from Hypo Shield here the moment there's something to know.</div>
        <button class="tdbd-chip" style="align-self:stretch; width:100%;" aria-label="View your long-acting dose in Hypo Shield settings">
          <span class="k">Long-acting dose</span>
          <span class="v">12 <span class="u">U</span></span>
          <span class="chev" style="margin-left:auto;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span>
        </button>
      </div>
    </div>
  </div>
</div>

<TabBar active="dashboard" />
