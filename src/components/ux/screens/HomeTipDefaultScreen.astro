---
/**
 * HomeTipDefaultScreen — Home, Hypo Shield first-run RESTING state. The peek
 * card sits UNDER the CGM graph (collapsed state of the two-state card; tap /
 * swipe up expands to the Learning-state takeover). First time a user opens
 * Luna it signals that a week-long learning process is starting and explains
 * what Hypo Shield is — no dose value, no accept control.
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
import TabBar from "../ios/TabBar.astro";
import AskLuna from "../ios/AskLuna.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <StatusStrip />

  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose">
      <span class="num">112</span>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg);" aria-label="Steady"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </div>
    <div class="footnote muted">mg/dL · steady</div>
  </div>

  {/* HERO CGM GRAPH fills the freed space; the Hypo Shield peek sits below it. */}
  <CgmHero trace="inrange" fill />

  {/* HYPO SHIELD PEEK (collapsed) — under the CGM graph. Tap / swipe up expands
      to the Learning-state takeover. First-run copy: a week of learning is
      starting; explain the feature, no dose value, no accept control. */}
  <div class="pad" style="margin-top:12px; padding-bottom:8px;">
    <div class="insight-wrap" style="position:relative;">
      <AskLuna anchor="card" />
      <div class="card-dark tip-card hypo-pop">
        <div class="peek-grip"></div>
        <div class="head">
          <span class="moon" aria-hidden="true"></span>
          <span class="eyebrow">Hypo Shield</span>
        </div>
        <div class="lead">Over your first week, Hypo Shield learns your insulin sensitivity and how your glucose moves overnight — then suggests adjusting your long-acting dose as needed.</div>
        <div class="lead">It watches each night on its own and never changes anything for you. When there's a suggestion, you'll see it right here.</div>
        <div class="head" style="justify-content:space-between; margin-top:2px;">
          <button class="howlink" type="button" style="white-space:nowrap;">What is Hypo Shield?</button>
          <span class="peek-more">Tap to view</span>
        </div>
      </div>
    </div>
  </div>
</div>

<TabBar active="dashboard" />
