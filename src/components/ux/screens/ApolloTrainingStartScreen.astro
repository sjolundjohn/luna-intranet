---
/**
 * ApolloTrainingStartScreen — entry to Apollo evening training. After setup
 * completes the user is on Home; a bottom sheet (~1/3 height) asks whether to
 * start the first Luna session now. Uses the canonical sheet-over-backdrop
 * pattern (spine 03): a dimmed Home backdrop (status + glucose + overnight
 * graph) under a scrim, with the prompt sheet raised above it (Phone `sheet`).
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
interface Props { variant?: "current" | "legacy"; }
---
{/* dimmed Home dashboard backdrop */}
<div class="content backdrop" aria-hidden="true">
  <StatusStrip />
  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose"><span class="num">112</span></div>
    <div class="footnote muted">mg/dL · steady</div>
  </div>
  <CgmHero trace="inrange" fill />
</div>

{/* dim scrim */}
<div class="scrim"></div>

{/* bottom sheet — start the first session (distinct light card, ~half screen) */}
<div class="sheet-host">
  {/* no grab handle — the buttons are the only paths forward or out (v2.3 r3) */}
  <div class="apollo-sheet" style="padding-top:28px;">
    <h2 style="font-family:var(--font-brand); font-size:22px; font-weight:700; letter-spacing:-0.02em; margin:0; text-align:center; color:#041E42;">Ready to start your first Luna session?</h2>
    <p style="margin:14px 0 0; text-align:center; line-height:1.6; font-size:15px; color:#5b6b7a;">We'll set up together — about five minutes — and then Luna is on watch for the night.</p>
    <div class="stack" style="gap:12px; margin-top:28px;">
      <button class="btn primary">Yes, let's start</button>
      <button class="btn" style="background:transparent; border:1.5px solid rgba(4,30,66,0.18); color:#041E42;">No, I'll do it later</button>
    </div>
  </div>
</div>

<style is:global>
  .ux-ios .apollo-sheet {
    background: #ffffff;
    border-top-left-radius: 28px; border-top-right-radius: 28px;
    border: 1px solid rgba(0,0,0,0.10);
    padding: 16px 20px 40px;
    min-height: 380px;
    display: flex; flex-direction: column;
    box-shadow: 0 -18px 44px rgba(0,0,0,0.45);
  }
  .ux-ios .apollo-sheet .grab {
    width: 36px; height: 5px; border-radius: 999px;
    background: rgba(4,30,66,0.18); margin: 2px auto 20px;
  }
</style>
