---
/**
 * IobHomeOnScreen — Home dashboard with IOB Display ON (opted-in). Identical to
 * the spine Home, plus the Active-Insulin (IOB) row that is OFF by default and
 * appears only when the flag is on. IOB is decision-support — shown to 0.1 with
 * a capital "U", scoped to Luna-delivered insulin only; never instructs a dose.
 * Lifted verbatim from `iob-display/home-iob-on.html`.
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
import TabBar from "../ios/TabBar.astro";
import AskLuna from "../ios/AskLuna.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <StatusStrip />

  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose">
      <span class="num">112</span>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(90deg);" aria-label="Steady"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </div>
    <div class="footnote muted">mg/dL · steady</div>
  </div>

  {/* HERO CGM GRAPH — fills the freed space (insight + IOB sit at the bottom). */}
  <CgmHero trace="inrange" fill />

  {/* Bottom group: insight bar (with the Ask-Luna "+" on its corner) + the
      Active-Insulin (IOB) row — visible because IOB Display is ON. */}
  <div class="pad" style="margin-top:12px; padding-bottom:8px;">
    <div class="insight-wrap" style="position:relative;">
      <AskLuna anchor="card" />
      <div class="card-dark insight-card">
        <span class="ic" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>
        </span>
        <span class="txt"><span class="lead">Steady night.</span> Your glucose held in range and Luna made a few small adjustments while you slept.</span>
      </div>
    </div>
    {/* Active insulin (IOB) — decision-support; 0.1 U, capital U, Luna-delivered only. */}
    <div class="card-dark aic" style="margin-top:12px;">
      <span class="ico" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.7S5 9.5 5 14.5a7 7 0 0 0 14 0C19 9.5 12 2.7 12 2.7z"/></svg>
      </span>
      <span class="meta">
        <span class="k">Active insulin · Luna</span>
        <span class="scope">From Luna-delivered insulin only</span>
      </span>
      <span style="flex:1;"></span>
      <span class="v">0.4 <span class="u">U</span></span>
    </div>
  </div>
</div>

<TabBar active="dashboard" />
