---
/**
 * SettingsScreen — account + care configuration list.
 */
import StatusBar from "../ios/StatusBar.astro";
import ListRows from "../ios/ListRows.astro";
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
// Settings is Unchanged — no legacy/current divergence; prop kept for the
// uniform screen-registry interface.

const rows = [
  { label: "Target range", value: "70–140" },
  { label: "Basal Guidance", value: "On" },
  { label: "Notifications", value: "On" },
  { label: "Connected sensor", value: "Auto" },
  { label: "Account", value: "—" },
];
---
<div class="scr">
  <StatusBar tone="dark" />
  <div class="scr-body">
    <header class="scr-head">
      <h1 class="scr-title">Settings</h1>
    </header>
    <ListRows rows={rows} />
  </div>
  <TabBar active="settings" />
</div>
<style>
  .scr { display: flex; flex-direction: column; min-height: 844px; background: var(--color-cloud-lilac); }
  .scr-body { flex: 1; padding: 4px 16px 20px; display: flex; flex-direction: column; gap: 16px; }
  .scr-head { padding: 8px 2px 4px; }
  .scr-title { font-size: 34px; font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 0; }
</style>
