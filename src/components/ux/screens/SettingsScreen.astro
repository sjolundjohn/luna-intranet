---
import Icon from "../Icon.astro";
import { iconSvg } from "../../../lib/icon-svg";
/**
 * SettingsScreen — Settings root (spine 05). Moonlight back + bold title (no
 * divider), grouped lists: Hypo Shield (Active) + IOB Display (default OFF),
 * Devices (CGM "Recent reading OK", Luna Controller "Connected"), Support.
 * Copy + markup lifted verbatim from `_spine/05-settings-list.html`.
 */
import TabBar from "../ios/TabBar.astro";
import Toggle from "../ios/Toggle.astro";

interface Props {
  variant?: "current" | "legacy";
}
const chev = iconSvg("chevron-right", 18, 1.8);
---
<div class="content">
  {/* nav header: Moonlight back + "Settings", NO divider */}
  <div class="navbar">
    <button class="back" aria-label="Back">
      <Icon name="chevron-left" size={22} sw={2} />
    </button>
    <h1>Settings</h1>
  </div>

  <div class="pad" style="overflow-y:auto;">
    <div class="sec-label">Hypo Shield</div>
    <div class="list">
      <div class="row">
        <span class="label">Hypo Shield</span>
        <span class="ok-txt"><span class="dot"></span>Active</span>
        <span class="chev" set:html={chev} />
      </div>
      <div class="row">
        <span class="label">IOB Display</span>
        <Toggle checked={false} label="IOB Display" />
      </div>
    </div>

    <div class="sec-label">Devices</div>
    <div class="list">
      <div class="row">
        <span class="label">CGM</span>
        <span class="value">Recent reading OK</span>
        <span class="chev" set:html={chev} />
      </div>
      <div class="row">
        <span class="label">Luna Controller</span>
        <span class="value">Connected</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    <div class="sec-label">Support</div>
    <div class="list">
      <div class="row">
        <span class="label">Help</span>
        <span class="chev" set:html={chev} />
      </div>
    </div>

    <div style="height:12px;"></div>
  </div>

  <div style="flex:1;"></div>
</div>

<TabBar active="settings" />
