---
import Icon from "../Icon.astro";
/**
 * OnboardingUiWalkthroughScreen — UI Walkthrough (1 of 5). Reads as ONE
 * onboarding with Apollo Training (BR-B5); module-scoped dot progress. A
 * spotlighted preview of the night view + the seam note. NO skip valve.
 * Lifted verbatim from `onboarding/ui-walkthrough.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title">Quick tour</span>
      <span class="count">Step 1 of 5</span>
    </div>
    <div class="prog-dots" role="img" aria-label="Step 1 of 5">
      <span class="d current"></span><span class="d"></span><span class="d"></span><span class="d"></span><span class="d"></span>
    </div>
  </div>

  <div class="pad" style="margin-top:14px; flex:1; display:flex; flex-direction:column; overflow-y:auto;">
    <div class="eyebrow">Quick tour · 1 of 5</div>
    <h1 class="title-1" style="font-weight:700; margin:10px 0 0; letter-spacing:-0.015em;">This is your night view</h1>
    <p class="body muted" style="margin:10px 0 0;">
      Each morning you'll open here. The big number is your glucose; the graph shows your night and the small marks show when Luna acted.
    </p>

    <div class="wt-preview">
      <div class="mini">
        <div class="wt-glucose spotlight">
          <span class="num accent">112</span>
          <span class="un">mg/dL</span>
        </div>
        <p class="footnote muted" style="text-align:center; margin:14px 0 0;">Steady overnight · Luna made 3 small adjustments</p>
      </div>
    </div>

    <div class="wt-callout">
      <span class="ic"><Icon name="info-lined" size={20} sw={1.9} /></span>
      <span class="ln">After the tour, your coordinator picks up right here to set up your device for tonight — it's all one walkthrough.</span>
    </div>

    <div style="flex:1; min-height:14px;"></div>
  </div>

  <div class="pad" style="padding-bottom:8px;">
    <button class="btn primary">Next</button>
  </div>
</div>
