---
/**
 * ApolloTrainingStartMorningScreen — morning re-entry into Apollo training.
 * Mirrors the evening Training Start (sheet-over-backdrop, spine 03) with
 * morning copy: a bottom sheet prompting the user to begin the morning removal
 * steps. Appears ~4h after the Luna session started (so it can surface
 * mid-night and is dismissible until the user is up); the morning module
 * restarts the step count at 1. Clock 7:08 (see ScreenRenderer FRAME).
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
interface Props { variant?: "current" | "legacy"; }
---
{/* dimmed Home dashboard backdrop */}
<div class="content backdrop" aria-hidden="true">
  <StatusStrip />
  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose"><span class="num">112</span></div>
    <div class="footnote muted">mg/dL · steady</div>
  </div>
  <CgmHero trace="inrange" fill />
</div>

{/* dim scrim */}
<div class="scrim"></div>

{/* bottom sheet — begin morning removal (distinct light card, ~half screen) */}
<div class="sheet-host">
  <div class="apollo-sheet">
    <div class="grab"></div>
    <h2 style="font-family:var(--font-brand); font-size:22px; font-weight:700; letter-spacing:-0.02em; margin:0; text-align:center; color:#041E42;">Ready to remove Luna and start your day?</h2>
    <p style="margin:14px 0 0; text-align:center; line-height:1.6; font-size:15px; color:#5b6b7a;">A few quick steps to take Luna off and charge it for tonight. No rush — start whenever you're up.</p>
    <div class="stack" style="gap:12px; margin-top:28px;">
      <button class="btn primary">Yes, let's go</button>
      <button class="btn" style="background:transparent; border:1.5px solid rgba(4,30,66,0.18); color:#041E42;">Not yet</button>
    </div>
  </div>
</div>

<style is:global>
  .ux-ios .apollo-sheet {
    background: #ffffff;
    border-top-left-radius: 28px; border-top-right-radius: 28px;
    border: 1px solid rgba(0,0,0,0.10);
    padding: 16px 20px 40px;
    min-height: 380px;
    display: flex; flex-direction: column;
    box-shadow: 0 -18px 44px rgba(0,0,0,0.45);
  }
  .ux-ios .apollo-sheet .grab {
    width: 36px; height: 5px; border-radius: 999px;
    background: rgba(4,30,66,0.18); margin: 2px auto 20px;
  }
</style>
