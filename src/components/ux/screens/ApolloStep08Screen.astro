---
import Icon from "../Icon.astro";
import ApolloStep from "../ios/ApolloStep.astro";
interface Props { variant?: "current" | "legacy"; }
// Morning removal is its own module ("Morning removal · Step N of 3").
---
<ApolloStep moduleLabel="Morning removal" count="Step 1 of 3" total={3} current={1} badge="Step 08"
  headline="Remove Luna and start your day" instr="Gently peel the adhesive off your body to remove Luna."
  caption="video: Step 08 — poster TBD">
  <div class="warn-banner" style="margin-top:18px;">
    <span class="ic" aria-hidden="true"><Icon name="warning-triangle" size={20} sw={1.8} /></span>
    <span class="tx">Heads up — there's an exposed needle when you peel Luna off your body.</span>
  </div>
</ApolloStep>
