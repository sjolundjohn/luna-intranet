---
/**
 * ConfirmSkipScreen — Hypo Shield "Confirm Skip" (decline / defer), clock 10:18.
 * Nothing changes: the current basal stands, no setting touched, no dose taken.
 * The consequence of skipping is shown in PLUM (--color-critical), never red.
 * The recommendation isn't lost — retrievable under Settings · Hypo Shield. No
 * slide gesture (skipping is not a dose action). Rendered with `sheet`.
 * Lifted verbatim from `hypo-shield/confirm-skip.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
{/* dimmed Home backdrop */}
<div class="content backdrop" aria-hidden="true">
  <div class="pad" style="padding-top:8px;">
    <div class="title-2" style="font-weight:700;">Good night, moonbeam</div>
    <div class="footnote muted" style="margin-top:2px;">Luna's on watch · session started 10:42 PM</div>
  </div>
  <div class="pad" style="margin-top:18px;">
    <div class="card-dark statuscard">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12.5l2 2 4.5-5"/></svg>
      <div class="headline" style="font-weight:700;">Luna</div>
      <div class="subhead muted">Active · watching overnight</div>
    </div>
  </div>
  <div class="pad" style="margin-top:16px; text-align:center;">
    <div class="glucose"><span class="num">112</span></div>
  </div>
</div>

{/* dim scrim */}
<div class="scrim"></div>

{/* CONFIRM-SKIP SHEET — no dose value to apply, no slide; decline/defer */}
<div class="sheet-host">
  <div class="sheet">
    <div class="grabber"></div>
    <div class="hdr"><div class="moon"></div><span class="eyebrow">Hypo Shield · Skip</span></div>
    <h2>Skip this recommendation?</h2>

    <div class="stands">
      <span class="lbl">Your basal stays at</span>
      <span class="val">12</span><span class="u">U</span>
    </div>
    <span class="unchanged">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
      Nothing changes
    </span>
    <p class="rationale">If you skip, Luna doesn't update your setting and you don't take a new dose. Your current basal stays exactly as it is.</p>

    {/* CONSEQUENCE of skipping — Plum critical note, never red */}
    <div class="skip-note">
      <span class="ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>
      </span>
      <span class="tx">Luna found your basal looks mis-set. Skipping means you may keep waking outside range until you act on a future recommendation.</span>
    </div>

    {/* Retrievable later */}
    <div class="retrieve">
      <span class="ic" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7M21 4v5h-5"/></svg>
      </span>
      <span class="tx">This recommendation isn't lost. You can find it any time under <b>Settings · Hypo Shield</b>.</span>
    </div>

    <button class="btn sheet-primary" type="button">Skip this recommendation</button>
    <div class="skip"><button type="button">Back</button></div>
  </div>
</div>
