---
/**
 * ConfirmSkipScreen — Hypo Shield "Confirm Skip" (decline / defer), clock 10:18.
 * Simplified (team feedback): one neutral acknowledgement, no competing
 * green-check / plum-warning colors. Nothing changes — the current long-acting
 * dose stands, no dose taken. The suggestion isn't lost; it waits under
 * Settings · Hypo Shield. No slide gesture (skipping is not a dose action).
 */
interface Props {
  variant?: "current" | "legacy";
}
---
{/* dimmed Home backdrop */}
<div class="content backdrop" aria-hidden="true">
  <div class="pad" style="padding-top:8px;">
    <div class="title-2" style="font-weight:700;">Good night, moonbeam</div>
    <div class="footnote muted" style="margin-top:2px;">Luna's on watch · session started 10:42 PM</div>
  </div>
  <div class="pad" style="margin-top:18px;">
    <div class="card-dark statuscard">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12.5l2 2 4.5-5"/></svg>
      <div class="headline" style="font-weight:700;">Luna</div>
      <div class="subhead muted">Active · watching overnight</div>
    </div>
  </div>
  <div class="pad" style="margin-top:16px; text-align:center;">
    <div class="glucose"><span class="num">112</span></div>
  </div>
</div>

{/* dim scrim */}
<div class="scrim"></div>

{/* CONFIRM-SKIP SHEET — simplified: one neutral acknowledgement, no slide, no
    competing green/plum colors. Just confirm the skip and say what happens. */}
<div class="sheet-host">
  <div class="sheet">
    <div class="grabber"></div>
    <div class="hdr"><div class="moon"></div><span class="eyebrow">Hypo Shield · Skip</span></div>
    <h2>Skip this suggestion?</h2>

    <p class="rationale">Your long-acting dose stays at <b>12 U</b> and you take your usual dose tonight — nothing changes.</p>
    <p class="rationale">Luna keeps this suggestion for you under <b>Settings · Hypo Shield</b>, and may offer it again if the same pattern continues.</p>

    <button class="btn sheet-primary" type="button">Skip this suggestion</button>
    <div class="skip"><button type="button">Back</button></div>
  </div>
</div>

<style is:global>
  .ux-ios .sheet .rationale b { color: var(--color-ink); font-weight: 700; }
</style>
