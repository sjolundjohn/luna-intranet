---
/**
 * LearningStateScreen — Home, Hypo Shield learning takeover (v0.5 r2). The
 * conservative "we're still getting to know you" mode, shown until the first
 * suggestion arrives (after which this screen goes away and the user just gets
 * a recommendation — there is no separate "ready" screen). Covers the glucose +
 * CGM graph, between the status pills and the tab bar.
 *
 * Learning rule: 7 Luna sessions — they do NOT need to be consecutive. Shown as
 * a 7-segment progress (one per session needed), gamified ("2 more to unlock").
 * Two scenarios drive the dynamic-content selector (SCREEN_STATES):
 *   early  — first sessions, conservative, lots to go
 *   almost — close to 7, gamified nudge
 */
import StatusStrip from "../ios/StatusStrip.astro";
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
const arrow = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>';
// 7-segment session graph: `done` of 7 filled.
const seg = (done: number) => Array.from({ length: 7 }, (_, i) => `<div class="d${i < done ? ' on' : ''}"><span class="seg"></span></div>`).join("");
---
<div class="content">
  <StatusStrip />

  {/* HYPO SHIELD LEARNING TAKEOVER — covers glucose + CGM, between the status
      pills and the tab bar. */}
  <div class="pad hypo-takeover">
    <div class="card-dark learn-card hypo-pop" style="flex:1; display:flex; flex-direction:column;">
      <div class="head">
        <span class="moon" aria-hidden="true"></span>
        <span class="eyebrow">Hypo Shield</span>
      </div>

      {/* ── STATE: early (first sessions) ────────────────────────────── */}
      <div data-ux-state="early">
        <div class="title">Getting to know your insulin needs</div>
        <p class="ls-body">Hypo Shield is learning how your body responds overnight. For the first week, it is conservative to avoid hypoglycemia. You may have higher glucose than you expect — give us a little time to learn about your needs. Your first dose suggestion comes after <b>7 Luna sessions</b> (they don't have to be in a row).</p>

        <div class="week">
          <div class="week-top">
            <span class="week-count"><b>2</b> of 7 Luna sessions</span>
            <span class="week-goal">Unlocks at 7</span>
          </div>
          <div class="week-bars" set:html={seg(2)} />
          <div class="week-msg"><span set:html={arrow} /><span><b>5 more sessions</b> to unlock Hypo Shield suggestions.</span></div>
        </div>
      </div>

      {/* ── STATE: almost (close to 7) ───────────────────────────────── */}
      <div data-ux-state="almost" hidden>
        <div class="title">Almost there</div>
        <p class="ls-body">You're nearly there. Hypo Shield has watched most of your nights and will start suggesting once you reach <b>7 Luna sessions</b>.</p>

        <div class="week">
          <div class="week-top">
            <span class="week-count"><b>5</b> of 7 Luna sessions</span>
            <span class="week-goal">Unlocks at 7</span>
          </div>
          <div class="week-bars" set:html={seg(5)} />
          <div class="week-msg"><span set:html={arrow} /><span>Just <b>2 more sessions</b> to go — you're almost there!</span></div>
        </div>
      </div>

      <div class="grow"></div>

      <button class="howlink" type="button" style="margin-top:16px; white-space:nowrap;">What is Hypo Shield?</button>
    </div>
  </div>
</div>

<TabBar active="dashboard" />

<style is:global>
  /* Body copy matches the Home card paragraph — bigger + darker than the old sub. */
  .ux-ios .learn-card .ls-body { margin: 0 0 18px; font-size: 15px; line-height: 1.55; color: var(--color-ink); }
  .ux-ios .learn-card .ls-body b { font-weight: 700; }
</style>
