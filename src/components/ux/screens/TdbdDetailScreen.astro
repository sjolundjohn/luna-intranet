---
/**
 * TdbdDetailScreen — TDBD detail (reached by tapping the Home chip/banner).
 * Current programmed total daily basal (12 U, "You set this — Luna never changes
 * it for you"), learning progress (5 sessions AND 7 days, both met = learned),
 * and a plain history with dispositions. Pushed detail (Moonlight back), no tab
 * bar; scrolls inside the frame. Lifted verbatim from `hypo-shield/tdbd-detail.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
const check = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
---
<div class="content" style="overflow-y:auto;">
  {/* pushed detail: Moonlight back + title, NO divider */}
  <div class="navbar">
    <button class="back" aria-label="Back">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      Hypo Shield
    </button>
  </div>
  <div class="pad" style="padding-bottom:10px;"><h1 style="margin:0; font-size:28px; font-weight:700; letter-spacing:-0.015em;">Your basal</h1></div>

  {/* CURRENT PROGRAMMED TDBD value */}
  <div class="pad">
    <div class="card-dark tdbd-hero">
      <span class="eyebrow">Programmed now</span>
      <div class="valrow"><span class="val">12</span><span class="u">U</span></div>
      <div class="sub">Total daily basal Luna is automating around. You set this — Luna never changes it for you.</div>
    </div>
  </div>

  {/* LEARNING PROGRESS: 5 sessions AND 7 days (both met = learned) */}
  <div class="pad" style="margin-top:14px;">
    <div class="sec-label">Learning</div>
    <div class="card-dark" style="padding:18px;">
      <div class="lp">
        <div class="lp-item">
          <div class="lp-top">
            <span class="lp-lbl"><span class="done" set:html={check} /> Luna sessions</span>
            <span class="lp-count">5 of 5</span>
          </div>
          <div class="lp-bar"><i style="width:100%;"></i></div>
        </div>
        <div class="lp-item">
          <div class="lp-top">
            <span class="lp-lbl"><span class="done" set:html={check} /> Days of wear</span>
            <span class="lp-count">7 of 7</span>
          </div>
          <div class="lp-bar"><i style="width:100%;"></i></div>
        </div>
      </div>
      <span class="learned">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        Learned · Hypo Shield can now recommend
      </span>
    </div>
  </div>

  {/* HISTORY of changes / recommendations + dispositions */}
  <div class="pad" style="margin-top:14px;">
    <div class="sec-label">History</div>
    <div class="list">
      <div class="hist-row">
        <span class="dt">May<br>26</span>
        <span class="mid">
          <span class="t">Recommended 14 U</span>
          <span class="s">Drifted up · you declined</span>
        </span>
        <span class="tag skipped">Skipped</span>
      </div>
      <div class="hist-row">
        <span class="dt">May<br>24</span>
        <span class="mid">
          <span class="t">Changed to 12 U</span>
          <span class="s">Recommendation applied</span>
        </span>
        <span class="tag applied">Applied</span>
      </div>
      <div class="hist-row">
        <span class="dt">May<br>19</span>
        <span class="mid">
          <span class="t">Manual change to 10 U</span>
          <span class="s">Learning reset, then re-learned</span>
        </span>
        <span class="tag reset">Reset</span>
      </div>
      <div class="hist-row">
        <span class="dt">May<br>12</span>
        <span class="mid">
          <span class="t">Started at 10 U</span>
          <span class="s">Your starting basal at setup</span>
        </span>
        <span class="tag applied">Set</span>
      </div>
    </div>
    <div style="height:14px;"></div>
  </div>
</div>
