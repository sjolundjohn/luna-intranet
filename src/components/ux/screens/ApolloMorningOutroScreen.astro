---
import Icon from "../Icon.astro";
/**
 * ApolloMorningOutroScreen — morning outro (personal "week ahead" video).
 * Auto-loops, NO "Watch again". Clock 7:16.
 * Lifted verbatim from `apollo-training/morning-outro.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="video-tile">
    <div class="scrim"></div>
    <button class="play" aria-label="Play step video">
      <svg width="18" height="18" viewBox="0 0 16 16"><path d="M5 3l9 5-9 5V3z" fill="#041E42"/></svg>
    </button>
    <span class="cap">video: Personal · Week of learning — poster TBD</span>
    <span class="loop">
      <Icon name="loop" size={12} sw={2} />
      Auto-loops
    </span>
  </div>

  <div class="pad" style="flex:1; display:flex; flex-direction:column; padding-top:20px;">
    <div class="step-badge" style="margin:0 0 12px;"><span class="dot"></span>Personal video · The week ahead</div>
    <div style="flex:1; display:flex; flex-direction:column; justify-content:center; padding-bottom:12px;">
      <h1 class="title-2" style="font-weight:700; letter-spacing:-0.02em; margin:0;">Nice work — your morning's complete.</h1>
      <p class="body muted" style="margin:12px 0 0; line-height:1.55;">Over the next week, Luna is learning your patterns. A quick note on what we'll be watching for, what you'll see in the app, and when to check in.</p>
    </div>
  </div>

  <div class="pad" style="padding-bottom:8px;">
    <button class="btn primary">Go to dashboard</button>
  </div>
</div>
