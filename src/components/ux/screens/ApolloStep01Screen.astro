---
/**
 * ApolloStep01Screen — Evening setup, Step 01 (Inventory). Bespoke layout: a
 * still tile + a numbered inventory list (not the centered step copy).
 * Lifted verbatim from `apollo-training/step-01-inventory.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title">Getting ready for your first sleep</span>
      <span class="count">Step 1 of 6</span>
    </div>
    <div class="prog-dots" role="img" aria-label="Step 1 of 6">
      <span class="d current"></span><span class="d"></span><span class="d"></span><span class="d"></span><span class="d"></span><span class="d"></span>
    </div>
  </div>

  {/* still image — no play button / auto-loops (this step is a still, not a video) */}
  <div class="video-tile">
    <div class="scrim"></div>
    <span class="cap">still: Step 01 — poster TBD</span>
  </div>

  <div class="pad" style="flex:1; display:flex; flex-direction:column; padding-top:22px;">
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0 0 20px;">Gather what you'll need</h1>
    <div class="inv-list">
      <div class="inv-item"><span class="n">1</span><span class="lbl">Your rapid-acting insulin pen</span></div>
      <div class="inv-item"><span class="n">2</span><span class="lbl">Single-Sleep Reservoir</span></div>
      <div class="inv-item"><span class="n">3</span><span class="lbl">Luna Capsule (charged)</span></div>
    </div>
    <div style="flex:1;"></div>
  </div>

  <div class="pad" style="padding-bottom:28px;">
    <button class="btn primary">Ready — let's go</button>
  </div>
</div>

<style is:global>
  /* each item slides in (staggered), then its number keeps a gentle glowing pulse
     so there's ongoing motion drawing the eye to each one. */
  @keyframes invEnter { 0% { opacity: 0; transform: translateX(-20px); } 100% { opacity: 1; transform: translateX(0); } }
  @keyframes invGlow {
    0%, 100% { box-shadow: 0 0 0 rgba(104,210,223,0); transform: scale(1); }
    50%      { box-shadow: 0 0 16px rgba(104,210,223,0.75); transform: scale(1.14); }
  }
  .ux-ios .inv-item { opacity: 0; animation: invEnter 0.55s cubic-bezier(0.22,1,0.36,1) forwards; }
  .ux-ios .inv-item:nth-child(1) { animation-delay: 0.20s; }
  .ux-ios .inv-item:nth-child(2) { animation-delay: 0.50s; }
  .ux-ios .inv-item:nth-child(3) { animation-delay: 0.80s; }
  .ux-ios .inv-item .n { animation: invGlow 2.4s ease-in-out infinite; }
  .ux-ios .inv-item:nth-child(1) .n { animation-delay: 1.1s; }
  .ux-ios .inv-item:nth-child(2) .n { animation-delay: 1.5s; }
  .ux-ios .inv-item:nth-child(3) .n { animation-delay: 1.9s; }
</style>
