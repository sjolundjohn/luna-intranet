---
/**
 * IobSessionDetailScreen — Session History detail (a push from the session
 * list), surfacing the residual Luna IOB after a session ends (0.1 U, capital
 * "U", Luna-delivered only). Session summary (in-range ring + total insulin +
 * hi/lo + per-night CGM graph with Plum critical-low) then a focal residual-IOB
 * card. Pushed detail (Moonlight back), no tab bar; scrolls inside the frame.
 * Lifted verbatim from `iob-display/session-detail-iob.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content" style="overflow-y:auto;">
  {/* push header: Moonlight back to Session History */}
  <div class="navbar">
    <button class="back" aria-label="Back to Session History">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      Session History
    </button>
  </div>
  <div class="pad" style="padding-bottom:2px;">
    <div class="large-title" style="font-weight:700;">May 22 → 23</div>
    <div class="footnote muted" style="margin-top:2px;">Overnight session · 10:42 PM – 6:58 AM</div>
  </div>

  {/* SELECTED SESSION SUMMARY — ring + total insulin + hi/lo + residual at wake */}
  <div class="pad" style="margin-top:14px;">
    <div class="card-dark">
      <div class="footnote muted" style="text-transform:uppercase; letter-spacing:0.1em; font-weight:700; margin-bottom:16px;">Thursday, May 22 · overnight</div>
      <div class="sumrow">
        <svg class="ring" width="92" height="92" viewBox="0 0 92 92" aria-label="80% in range">
          <circle cx="46" cy="46" r="38" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="8"/>
          <circle cx="46" cy="46" r="38" fill="none" stroke="#68D2DF" stroke-width="8" stroke-linecap="round"
                  stroke-dasharray="238.76" stroke-dashoffset="47.75" transform="rotate(-90 46 46)"/>
          <text x="46" y="44" text-anchor="middle" font-size="20" font-weight="700" fill="#FFFFFF">80%</text>
          <text x="46" y="59" text-anchor="middle" font-size="9" fill="#ACC1DF">in range</text>
        </svg>
        <div class="metrics">
          <div class="m"><div class="k">Total insulin delivered</div><div class="v">5.0 <span style="font-size:13px; font-weight:400; color:var(--color-on-dark-sub);">U</span></div></div>
          <div class="m"><div class="k">Highest glucose</div><div class="v">178 <span style="font-size:13px; font-weight:400; color:var(--color-on-dark-sub);">mg/dL</span></div></div>
          <div class="m"><div class="k">Lowest glucose</div><div class="v">94 <span style="font-size:13px; font-weight:400; color:var(--color-on-dark-sub);">mg/dL</span></div></div>
        </div>
      </div>

      <svg viewBox="0 0 320 96" width="100%" height="96" style="margin-top:18px;" aria-label="Overnight glucose for May 22">
        <defs>
          <linearGradient id="nightFillIob" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#68D2DF" stop-opacity="0.26"/>
            <stop offset="1" stop-color="#68D2DF" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <line x1="0" y1="28" x2="320" y2="28" stroke="#F9CD86" stroke-width="1" stroke-dasharray="3 4" opacity="0.5"/>
        <line x1="0" y1="70" x2="320" y2="70" stroke="#8E3655" stroke-width="1.2" stroke-dasharray="4 4" opacity="0.85"/>
        <path d="M0,58 C30,54 55,44 88,48 S150,60 184,52 224,38 256,46 300,50 320,48" fill="none" stroke="#68D2DF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M0,58 C30,54 55,44 88,48 S150,60 184,52 224,38 256,46 300,50 320,48 L320,96 L0,96 Z" fill="url(#nightFillIob)"/>
        <g stroke="#68D2DF" stroke-width="2" stroke-linecap="round" opacity="0.95">
          <line x1="150" y1="86" x2="150" y2="94"/>
          <line x1="196" y1="86" x2="196" y2="94"/><line x1="202" y1="86" x2="202" y2="94"/>
        </g>
      </svg>
      <div style="display:flex; justify-content:space-between;" class="caption-2 muted">
        <span>10 PM</span><span>1 AM</span><span>4 AM</span><span>7 AM</span>
      </div>

      <div class="iobline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.7S5 9.5 5 14.5a7 7 0 0 0 14 0C19 9.5 12 2.7 12 2.7z"/></svg>
        <span class="v">0.1 U</span>
        <span class="t">on board at wake</span>
      </div>
    </div>
  </div>

  {/* RESIDUAL LUNA IOB — focal card. 0.1 precision, capital U, Luna-delivered
      only. Decision-support — does not instruct or change a dose. */}
  <div class="pad" style="margin-top:14px;">
    <div class="card-dark">
      <div class="iob-residual">
        <span class="moon-ic" aria-hidden="true"></span>
        <span class="col">
          <span class="k">Residual insulin on board</span>
          <span class="big">0.1<span class="u">U</span></span>
        </span>
      </div>
      <div class="iob-note">From your Luna-delivered insulin only. Still active at wake and clearing — shown so you can avoid stacking a manual dose on top of it.</div>
    </div>
  </div>

  <div style="height:14px;"></div>
</div>
