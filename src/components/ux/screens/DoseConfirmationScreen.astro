---
/**
 * DoseConfirmationScreen — the two-step dose-confirmation sheet over a dimmed
 * Midnight bedside backdrop (spine 03). The canonical safety-critical
 * confirmation: acknowledge BOTH (update setting AND take dose), then slide.
 * Feature is "Hypo Shield"; dose steps use generic long-acting insulin.
 *
 * Rendered by ScreenRenderer inside Phone with `sheet` (raises brandbar +
 * home indicator above the scrim/sheet) and clock 10:18. Backdrop copy +
 * markup lifted from `_spine/03-dose-confirmation.html`; the sheet is DoseSheet.
 */
import DoseSheet from "../ios/DoseSheet.astro";
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
{/* dimmed Home backdrop */}
<div class="content backdrop" aria-hidden="true">
  <div class="pad" style="padding-top:8px;">
    <div class="title-2" style="font-weight:700;">Good night, moonbeam</div>
    <div class="footnote muted" style="margin-top:2px;">Luna's on watch · session started 10:42 PM</div>
  </div>
  <div class="pad" style="margin-top:18px;">
    <div class="card-dark statuscard">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12.5l2 2 4.5-5"/></svg>
      <div class="headline" style="font-weight:700;">Luna</div>
      <div class="subhead muted">Active · watching overnight</div>
    </div>
  </div>
  <div class="pad" style="margin-top:16px; text-align:center;">
    <div class="glucose"><span class="num">112</span></div>
  </div>
</div>

{/* dim scrim */}
<div class="scrim"></div>

{/* DOSE CONFIRMATION SHEET (increase state) — stops above the tab bar, which
    stays visible (the bottom menu must never be covered). */}
<div class="sheet-host sheet-host--tabs">
  <DoseSheet variant="increase" value={14} prev={12} />
</div>

{/* bottom menu stays visible above the scrim */}
<div class="tabbar-float"><TabBar active="dashboard" /></div>
