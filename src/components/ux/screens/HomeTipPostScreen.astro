---
/**
 * HomeTipPostScreen — Home, Hypo Shield "Suggestion ready" peek. A long-acting
 * dose suggestion is available. The peek card sits UNDER the CGM graph (collapsed
 * state of the two-state card), consistent with the default tip. Compact notice
 * only — no dose detail; the single action opens the full-screen suggestion
 * review. Reading never accepts.
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
import TabBar from "../ios/TabBar.astro";
import AskLuna from "../ios/AskLuna.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <StatusStrip />

  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose">
      <span class="num">118</span>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(45deg);" aria-label="Drifting up"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </div>
    <div class="footnote muted">mg/dL · drifting up overnight</div>
  </div>

  {/* HERO CGM GRAPH fills the freed space; the Hypo Shield peek sits below it. */}
  <CgmHero trace="up" fill />

  {/* HYPO SHIELD "SUGGESTION READY" PEEK (collapsed) — under the CGM graph,
      consistent with the default tip. No dose detail here; the only action
      opens the full-screen suggestion review. Reading never accepts. */}
  <div class="pad" style="margin-top:12px; padding-bottom:8px;">
    <div class="insight-wrap" style="position:relative;">
      <AskLuna anchor="card" />
      <div class="card-dark tip-card hypo-pop">
        <div class="peek-grip"></div>
        <div class="head">
          <span class="moon" aria-hidden="true"></span>
          <span class="eyebrow">Hypo Shield · Suggestion</span>
        </div>
        <div class="lead">A new long-acting dose suggestion is ready</div>
        <div class="lead">Review it when you're ready — nothing changes until you confirm.</div>
        <button class="btn primary" type="button" style="margin-top:2px;">Review suggestion</button>
      </div>
    </div>
  </div>
</div>

<TabBar active="dashboard" />
