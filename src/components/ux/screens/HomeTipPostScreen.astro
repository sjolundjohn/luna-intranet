---
/**
 * HomeTipPostScreen — Home, Hypo Shield "Tip Post": a basal recommendation is
 * AVAILABLE. Decision-support framing (recommended value + direction + one-line
 * rationale), explicitly "a suggestion only — nothing changes until you review
 * and confirm". The only action — "Review recommendation" — opens the two-step
 * confirm sheet; the read never accepts.
 * Lifted verbatim from `hypo-shield/home-tip-post.html`.
 */
import StatusStrip from "../ios/StatusStrip.astro";
import CgmHero from "../ios/CgmHero.astro";
import TabBar from "../ios/TabBar.astro";

interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <StatusStrip />

  <div class="pad gluc-hero" style="margin-top:14px;">
    <div class="glucose">
      <span class="num">118</span>
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(45deg);" aria-label="Drifting up"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </div>
    <div class="footnote muted">mg/dL · drifting up overnight</div>
  </div>

  <CgmHero trace="up" height={158} />

  {/* HYPO SHIELD "SUGGESTION READY" — v0.4: a compact two-step gate. No dose
      detail here; the ONLY action opens the full-screen suggestion review
      (hypo-recommendation-detail), which then leads to the two-step confirm.
      Reading never accepts. */}
  <div class="pad" style="margin-top:14px;">
    <div class="card-dark tip-post hypo-pop">
      <div class="head">
        <span class="moon" aria-hidden="true"></span>
        <span class="eyebrow">Hypo Shield · Suggestion</span>
      </div>
      <div class="title">A new long-acting dose suggestion is ready</div>
      <div class="note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 16v-4M12 8h.01"/></svg>
        Review it when you're ready — nothing changes until you confirm.
      </div>
      <button class="btn primary" type="button">Review suggestion</button>
    </div>
  </div>

  <div style="flex:1;"></div>
</div>

<TabBar active="dashboard" />
