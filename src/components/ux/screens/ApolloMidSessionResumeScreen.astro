---
/**
 * ApolloMidSessionResumeScreen — same-evening / overnight re-entry that lands the
 * user back at a CLEAN STEP BOUNDARY (start of the morning module), never partway
 * through a step (closes the BR-B2 resume gap). Clock 7:08.
 * Lifted verbatim from `apollo-training/mid-session-resume.html`.
 */
interface Props {
  variant?: "current" | "legacy";
}
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title">Morning removal · Step 1 of 3</span>
      <span class="count">1 of 3</span>
    </div>
    <div class="prog-dots" role="img" aria-label="Morning removal, step 1 of 3">
      <span class="d current"></span><span class="d"></span><span class="d"></span>
    </div>
  </div>

  <div class="center-screen">
    <div class="icon-badge" style="border-radius:50%;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-moonlight)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
    </div>
    <div class="eyebrow">Good morning</div>
    <h1 class="title-1" style="font-weight:700; letter-spacing:-0.02em; margin:0;">Resume your morning steps</h1>
    <p class="body muted" style="margin:14px 0 22px; line-height:1.55;">Luna paused overnight and is done watching. You left off after last night's setup — pick up at the first morning step. Nothing's mid-way.</p>

    <button class="card-dark resume-card">
      <span class="badge">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </span>
      <span class="body-txt">
        <span class="ek">Pick up here</span>
        <span class="tt">Step 1 · Remove the device</span>
        <span class="ss">First of 3 morning steps. Take it off your arm before your next meal.</span>
      </span>
      <span class="chev"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span>
    </button>

    <div class="boundary-note">
      <span class="ic" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      </span>
      <span class="ln">You always come back at the start of a step — never halfway through one — so it's easy to find your place.</span>
    </div>
  </div>

  <div class="pad" style="padding-bottom:8px;">
    <button class="btn primary">Resume morning steps</button>
  </div>
</div>
