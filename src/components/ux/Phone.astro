---
/**
 * Phone — the locked Luna iOS device frame (SPINE-NOTES r2, 2026-05-28).
 *
 * Realistic BLACK metallic bezel (414px), a fixed-height 780px clipped
 * `.screen` on the Midnight gradient, a Dynamic-Island pill cue, the
 * status bar (9:41) + Luna on-dark wordmark ("brandbar") top-left, and
 * the home indicator — shared chrome on EVERY screen. Per-screen content
 * (the `.content` region + optional `.tabbar`) is slotted between the
 * brandbar and the home indicator.
 *
 * The frame styling lives in the shared, `.ux-ios`-scoped ios-spine.css
 * (the lifted spine `<style>` block) so it never drifts per-screen. Only
 * the scale wrapper is scoped here.
 *
 * `scale` shrinks the whole frame via a CSS transform, so pointer
 * coordinates resolved via getBoundingClientRect() stay correct — anchored
 * comment pins survive frame scaling.
 *   mode="full"  → detail view; no clip, drop shadow visible (scale ~1).
 *   mode="thumb" → grid/compare; clip the outer box to the scaled frame.
 * `clock` overrides the status-bar time (03 uses 10:18).
 * `sheet`        raises the brandbar + home indicator above a dose-sheet scrim.
 */
import "~/styles/ios-tokens.css";
import "~/styles/ios-spine.css";

interface Props {
  scale?: number;
  mode?: "full" | "thumb";
  /** Accepted for call-site compatibility; the screen is a fixed 780px device. */
  thumbHeight?: number;
  clock?: string;
  sheet?: boolean;
  /** When false, omit the status bar / brandbar / home indicator (legacy
      screenshots carry their own chrome — show just the bezel + image). */
  chrome?: boolean;
  class?: string;
}
const { scale = 1, mode = "full", clock = "9:41", sheet = false, chrome = true, class: className = "" } = Astro.props;

// Frame footprint: 414px wide × (12 pad + 780 screen + 12 pad) = 804px tall.
const FRAME_W = 414;
const FRAME_H = 804;
---

<div
  class:list={["ux-phone", `ux-phone--${mode}`, className]}
  style={`--ux-scale:${scale}; --ux-frame-w:${FRAME_W}px; --ux-frame-h:${FRAME_H}px;`}
  data-ux-phone
>
  <div class="ux-phone-frame">
    <div class="ux-ios">
      <div class="phone">
        <div class:list={["screen", sheet && "screen--sheet"]} data-ux-screen>
          {chrome && (
            <Fragment>
              <div class="statusbar">
                <span class="clock">{clock}</span>
                <span class="right">
                  <svg width="18" height="12" viewBox="0 0 18 12" fill="none"><rect x="0" y="7" width="3" height="5" rx="1" fill="#fff"/><rect x="5" y="4" width="3" height="8" rx="1" fill="#fff"/><rect x="10" y="1" width="3" height="11" rx="1" fill="#fff"/><rect x="15" y="1" width="3" height="11" rx="1" fill="#fff" opacity="0.4"/></svg>
                  <svg width="24" height="12" viewBox="0 0 24 12" fill="none"><rect x="0.5" y="1" width="20" height="10" rx="2.5" stroke="#fff" opacity="0.5"/><rect x="2" y="2.5" width="16" height="7" rx="1.2" fill="#fff"/><rect x="21.5" y="4" width="1.5" height="4" rx="0.75" fill="#fff" opacity="0.5"/></svg>
                </span>
              </div>
              <div class="brandbar"><img class="luna-mark" src="/luna-on-dark.svg" alt="Luna" /></div>
            </Fragment>
          )}
          <slot />
          {chrome && <div class="homebar"></div>}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .ux-phone { display: inline-block; }
  .ux-phone-frame {
    width: var(--ux-frame-w);
    transform: scale(var(--ux-scale));
    transform-origin: top left;
  }
  /* Full (detail): reserve the scaled width; let the drop shadow breathe. */
  .ux-phone--full { width: calc(var(--ux-frame-w) * var(--ux-scale)); }
  /* Thumb (grid/compare): clip the outer box to the scaled frame footprint. */
  .ux-phone--thumb {
    width: calc(var(--ux-frame-w) * var(--ux-scale));
    height: calc(var(--ux-frame-h) * var(--ux-scale));
    overflow: hidden;
  }
</style>
