// HypoShield & In-App Comms
import HomeTipDefaultScreen from "./screens/HomeTipDefaultScreen.astro";
import HomeTipPostScreen from "./screens/HomeTipPostScreen.astro";
import LearningStateScreen from "./screens/LearningStateScreen.astro";
import MidSessionAnnouncementScreen from "./screens/MidSessionAnnouncementScreen.astro";
import ConfirmResetRequiredScreen from "./screens/ConfirmResetRequiredScreen.astro";
import ConfirmSkipScreen from "./screens/ConfirmSkipScreen.astro";
import SettingsHypoShieldScreen from "./screens/SettingsHypoShieldScreen.astro";
import TdbdDetailScreen from "./screens/TdbdDetailScreen.astro";
import PushNotificationScreen from "./screens/PushNotificationScreen.astro";
// IOB Display
import IobHomeOnScreen from "./screens/IobHomeOnScreen.astro";
import IobSettingsScreen from "./screens/IobSettingsScreen.astro";
import IobPreSessionScreen from "./screens/IobPreSessionScreen.astro";
import IobSessionDetailScreen from "./screens/IobSessionDetailScreen.astro";
// Onboarding Update
import OnboardingChapter1Screen from "./screens/OnboardingChapter1Screen.astro";
import OnboardingChapter2Screen from "./screens/OnboardingChapter2Screen.astro";
import OnboardingChapter3Screen from "./screens/OnboardingChapter3Screen.astro";
import OnboardingChapter4Screen from "./screens/OnboardingChapter4Screen.astro";
import OnboardingChapter5Screen from "./screens/OnboardingChapter5Screen.astro";
import OnboardingSetupLandingScreen from "./screens/OnboardingSetupLandingScreen.astro";
import OnboardingUiWalkthroughScreen from "./screens/OnboardingUiWalkthroughScreen.astro";
import OnboardingTonightPanelStatesScreen from "./screens/OnboardingTonightPanelStatesScreen.astro";
import OnboardingSetupAppWalkthroughScreen from "./screens/OnboardingSetupAppWalkthroughScreen.astro";
import OnboardingSessionHistoryIntroScreen from "./screens/OnboardingSessionHistoryIntroScreen.astro";
import OnboardingLongActingInsulinScreen from "./screens/OnboardingLongActingInsulinScreen.astro";
import OnboardingSettingsLunaControllerScreen from "./screens/OnboardingSettingsLunaControllerScreen.astro";
// Apollo Training
import ApolloIntroScreen from "./screens/ApolloIntroScreen.astro";
import ApolloStep01Screen from "./screens/ApolloStep01Screen.astro";
import ApolloStep02Screen from "./screens/ApolloStep02Screen.astro";
import ApolloStep03Screen from "./screens/ApolloStep03Screen.astro";
import ApolloStep04Screen from "./screens/ApolloStep04Screen.astro";
import ApolloStep05Screen from "./screens/ApolloStep05Screen.astro";
import ApolloStep06Screen from "./screens/ApolloStep06Screen.astro";
import ApolloStep07Screen from "./screens/ApolloStep07Screen.astro";
import ApolloStep08Screen from "./screens/ApolloStep08Screen.astro";
import ApolloStep09Screen from "./screens/ApolloStep09Screen.astro";
import ApolloStep10Screen from "./screens/ApolloStep10Screen.astro";
import ApolloEveningOutroScreen from "./screens/ApolloEveningOutroScreen.astro";
import ApolloOvernightHandoffScreen from "./screens/ApolloOvernightHandoffScreen.astro";
import ApolloMorningStartScreen from "./screens/ApolloMorningStartScreen.astro";
import ApolloMorningOutroScreen from "./screens/ApolloMorningOutroScreen.astro";
import ApolloCompleteScreen from "./screens/ApolloCompleteScreen.astro";
import ApolloMidSessionResumeScreen from "./screens/ApolloMidSessionResumeScreen.astro";
import ApolloReplayFromSettingsScreen from "./screens/ApolloReplayFromSettingsScreen.astro";
// Apollo Training — v2.3 new screens
import ApolloTrainingStartScreen from "./screens/ApolloTrainingStartScreen.astro";
import ApolloTrainingGateScreen from "./screens/ApolloTrainingGateScreen.astro";
import ApolloPendingScreen from "./screens/ApolloPendingScreen.astro";
import ApolloPendingFailureScreen from "./screens/ApolloPendingFailureScreen.astro";
import ApolloTrainingStartMorningScreen from "./screens/ApolloTrainingStartMorningScreen.astro";

interface Props {
  id: string;
  variant?: "current" | "legacy";
  scale?: number;
  mode?: "full" | "thumb";
}
const { id, variant = "current", scale = 1, mode = "full" } = Astro.props;

/** id → screen component. Keys are the manifest ids (== component ids). */
const REGISTRY: Record<string, any> = {
  // Core spine archetypes
  "home-dashboard": DashboardScreen,
  "settings-list": SettingsScreen,
  "session-history": SessionHistoryScreen,
  "hardware-checkpoint-spine": HardwareCheckpointScreen,
  "dose-confirmation-spine": DoseConfirmationScreen,
  // HypoShield & In-App Comms
  "hypo-home-tip-default": HomeTipDefaultScreen,
  "hypo-home-tip-post": HomeTipPostScreen,
  "hypo-learning-state": LearningStateScreen,
  "hypo-mid-session-announcement": MidSessionAnnouncementScreen,
  "hypo-confirm-increase": DoseConfirmationScreen,
  "hypo-confirm-reset-required": ConfirmResetRequiredScreen,
  "hypo-confirm-skip": ConfirmSkipScreen,
  "hypo-settings": SettingsHypoShieldScreen,
  "hypo-tdbd-detail": TdbdDetailScreen,
  "hypo-push-notification": PushNotificationScreen,
  // IOB Display
  "iob-home-on": IobHomeOnScreen,
  "iob-settings": IobSettingsScreen,
  "iob-pre-session-announcement": IobPreSessionScreen,
  "iob-session-detail": IobSessionDetailScreen,
  // Onboarding Update
  "onboarding-chapter-1": OnboardingChapter1Screen,
  "onboarding-chapter-2": OnboardingChapter2Screen,
  "onboarding-chapter-3": OnboardingChapter3Screen,
  "onboarding-chapter-4": OnboardingChapter4Screen,
  "onboarding-chapter-5": OnboardingChapter5Screen,
  "onboarding-setup-landing": OnboardingSetupLandingScreen,
  "onboarding-ui-walkthrough": OnboardingUiWalkthroughScreen,
  "onboarding-tonight-panel-states": OnboardingTonightPanelStatesScreen,
  "onboarding-setup-app-walkthrough": OnboardingSetupAppWalkthroughScreen,
  "onboarding-session-history-intro": OnboardingSessionHistoryIntroScreen,
  "onboarding-long-acting-insulin": OnboardingLongActingInsulinScreen,
  "onboarding-settings-luna-controller": OnboardingSettingsLunaControllerScreen,
  // Apollo Training
  "apollo-intro": ApolloIntroScreen,
  "apollo-step-01-inventory": ApolloStep01Screen,
  "apollo-step-02-open-tray": ApolloStep02Screen,
  "apollo-step-03-fill": ApolloStep03Screen,
  "apollo-step-04-remove-label": ApolloStep04Screen,
  "apollo-step-05-attach-capsule": ApolloStep05Screen,
  "apollo-step-06-remove-base": ApolloStep06Screen,
  "apollo-step-07-apply-body": ApolloStep07Screen,
  "apollo-hardware-checkpoint": HardwareCheckpointScreen,
  "apollo-evening-outro": ApolloEveningOutroScreen,
  "apollo-overnight-handoff": ApolloOvernightHandoffScreen,
  "apollo-morning-start": ApolloMorningStartScreen,
  "apollo-step-08-remove-device": ApolloStep08Screen,
  "apollo-step-09-detach-reservoir": ApolloStep09Screen,
  "apollo-step-10-charge": ApolloStep10Screen,
  "apollo-morning-outro": ApolloMorningOutroScreen,
  "apollo-complete": ApolloCompleteScreen,
  "apollo-mid-session-resume": ApolloMidSessionResumeScreen,
  "apollo-replay-from-settings": ApolloReplayFromSettingsScreen,
  // Apollo Training — v2.3 new screens
  "apollo-training-start": ApolloTrainingStartScreen,
  "apollo-training-gate": ApolloTrainingGateScreen,
  "apollo-pending": ApolloPendingScreen,
  "apollo-pending-failure": ApolloPendingFailureScreen,
  "apollo-training-start-morning": ApolloTrainingStartMorningScreen,
};

/** Per-screen frame config: sheet raises brandbar/home indicator; custom clock. */
const FRAME: Record<string, { sheet?: boolean; clock?: string }> = {
  "dose-confirmation-spine": { sheet: true, clock: "10:18" },
  "hypo-confirm-increase": { sheet: true, clock: "10:18" },
  "hypo-confirm-reset-required": { sheet: true, clock: "9:41" },
  "hypo-confirm-skip": { sheet: true, clock: "10:18" },
  "hypo-mid-session-announcement": { sheet: true, clock: "2:14" },
  "hypo-push-notification": { clock: "10:18" },
  "iob-pre-session-announcement": { sheet: true, clock: "10:18" },
  // Apollo evening/morning timings
  "apollo-evening-outro": { clock: "11:22" },
  "apollo-overnight-handoff": { clock: "11:23" },
  "apollo-morning-start": { clock: "7:12" },
  "apollo-morning-outro": { clock: "7:16" },
  "apollo-complete": { clock: "7:18" },
  "apollo-mid-session-resume": { clock: "7:08" },
  // v2.3 new screens — bottom-sheet over dashboard (sheet raises brandbar/home indicator)
  "apollo-training-start": { sheet: true, clock: "10:42" },
  "apollo-training-start-morning": { sheet: true, clock: "7:08" },
};

const screen = getScreen(id);
const src = variant === "legacy" ? (screen?.legacy ?? null) : (screen?.wireframe ?? `component:${id}`);
const cid = componentId(src);
const Comp = cid ? REGISTRY[cid] : undefined;
const cfg = FRAME[cid ?? id] ?? {};

/** Map a manifest legacy path (`wireframes/legacy/x.jpg`) to its public URL. */
function legacyImg(path: string | null): string | null {
  if (!path) return null;
  const m = path.match(/legacy\/([^/]+\.(?:jpe?g|png))$/i);
  if (m) return `/ux-review/legacy/${m[1]}`;
  return path.startsWith("/") ? path : null;
}
const imgSrc = !cid && src && /\.(jpe?g|png)$/i.test(src) ? legacyImg(src) : null;
---
{Comp ? (
  <Phone scale={scale} mode={mode} sheet={cfg.sheet} clock={cfg.clock}>
    <Comp variant={variant} />
  </Phone>
) : imgSrc ? (
  <Phone scale={scale} mode={mode} chrome={false}>
    <img class="ux-legacy-fill" src={imgSrc} alt={`${screen?.title ?? id} (legacy)`} />
  </Phone>
) : (
  <Phone scale={scale} mode={mode}>
    <div class="content">
      <div class="ux-missing">
        <p>No wireframe yet</p>
        <code>{id}</code>
        <span>Native component pending</span>
      </div>
    </div>
  </Phone>
)}
