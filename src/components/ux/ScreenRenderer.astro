---
/**
 * ScreenRenderer — resolves a manifest screen id to its rendered iOS artboard
 * inside the locked Phone frame. Three render kinds:
 *   1. native component  (wireframe/legacy === "component:<id>")
 *   2. legacy screenshot (wireframe/legacy === a ".jpg" path) — chrome-off bezel
 *   3. graceful fallback ("No wireframe yet") for not-yet-built ids
 *
 * Owning the Phone frame here lets per-screen frame config (dose-sheet
 * z-index, custom clock) live with the registry. `variant` selects
 * "current" vs "legacy" for the old-vs-new compare. `scale`/`mode` pass
 * through to Phone (1/full = detail; <1/thumb = grid + compare).
 */
import Phone from "./Phone.astro";
import { getScreen, componentId } from "~/lib/ux-review";

import DashboardScreen from "./screens/DashboardScreen.astro";
import SettingsScreen from "./screens/SettingsScreen.astro";
import SessionHistoryScreen from "./screens/SessionHistoryScreen.astro";
import HardwareCheckpointScreen from "./screens/HardwareCheckpointScreen.astro";
