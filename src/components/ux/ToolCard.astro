---
/**
 * ToolCard — a registry tile for the Tools hub. Like SectionCard, but:
 *  - external tools (`external`) open in a new tab with an ↗ affordance,
 *  - an optional `screenshot` renders as a preview thumbnail.
 * Driven entirely by a `tools` collection entry's frontmatter.
 */
interface Props {
  href: string;
  name: string;
  summary: string;
  eyebrow?: string;
  external?: boolean;
  screenshot?: string;
  class?: string;
}

const {
  href,
  name,
  summary,
  eyebrow,
  external = false,
  screenshot,
  class: className = "",
} = Astro.props;

const externalAttrs = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a
  href={href}
  {...externalAttrs}
  class:list={[
    "group relative flex flex-col h-full bg-white rounded-[16px] shadow-[0_5px_50px_rgba(0,0,0,0.07)]",
    "overflow-hidden transition-all duration-[160ms] ease-out",
    "hover:-translate-y-[1px] hover:shadow-[0_12px_60px_rgba(4,30,66,0.14)]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-moonlight focus-visible:ring-offset-2",
    className,
  ]}
>
  {
    screenshot && (
      <div class="aspect-[16/9] w-full overflow-hidden bg-cloud-lilac border-b border-border-subtle">
        <img
          src={screenshot}
          alt={`${name} preview`}
          class="h-full w-full object-cover transition-transform duration-[220ms] group-hover:scale-[1.02]"
          loading="lazy"
        />
      </div>
    )
  }

  <div class="flex flex-col flex-1 p-8 md:p-9">
    {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}

    <h3
      class="font-display text-ink font-normal text-balance"
      style="font-size: clamp(26px, 2.4vw, 34px); line-height: 1.05; letter-spacing: -0.02em;"
    >
      {name}
    </h3>

    <p class="mt-3 text-graphite text-[16px] leading-[1.55] max-w-[42ch]">
      {summary}
    </p>

    <div class="mt-auto pt-6 inline-flex items-center gap-2 text-ink font-body text-[15px] font-medium">
      <span class="relative">
        {external ? "Open" : "Open tool"}
        <span
          class="absolute left-0 -bottom-1 h-[2px] w-full bg-moonlight origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-[220ms] ease-out"
          aria-hidden="true"></span>
      </span>
      {
        external ? (
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-[220ms] group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true">
            <path d="M7 17 17 7M8 7h9v9" />
          </svg>
        ) : (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-[220ms] group-hover:translate-x-1" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        )
      }
    </div>
  </div>
</a>
