---
/**
 * StatusBadge — New / Changed / Unchanged pill for a screen.
 * Uses the intranet @theme tokens (this renders in the intranet chrome,
 * not inside the .ux-ios scope).
 */
import type { ScreenStatus } from "~/lib/ux-review";

interface Props {
  status: ScreenStatus;
  class?: string;
}
const { status, class: className = "" } = Astro.props;

const styles: Record<ScreenStatus, string> = {
  New: "bg-success-bg text-success-ink",
  Changed: "bg-warning-bg text-warning-ink",
  Unchanged: "bg-periwinkle-mist text-graphite",
};
---
<span
  class:list={[
    "inline-flex items-center gap-[6px] h-[22px] px-2.5 rounded-full font-body text-[11px] font-semibold",
    styles[status],
    className,
  ]}
>
  <span class="block h-[6px] w-[6px] rounded-full bg-current" aria-hidden="true"></span>
  {status}
</span>
