---
import Icon from "../Icon.astro";
/**
 * ApolloStep — the Apollo training-step archetype (spine 02). Per-module DOTS
 * ("Evening setup · Step N of 7" / "Morning removal · Step N of 3"), an
 * auto-looping video tile (NO "Watch again"), centered enlarged step copy
 * (step badge tight above headline), and a primary that is NEVER gated on
 * hardware. Poster images are production placeholders (SOONA shoot pending);
 * the caption preserves the asset mapping.
 *
 * Slots: default = extra content inside step-copy (flag chip); `checkpoint` =
 * an informative conn-row after step-copy (steps 09/10).
 */
interface Props {
  moduleLabel: string;
  count: string;
  total: number;
  current: number;
  badge: string;
  headline: string;
  instr?: string;
  instrHtml?: string;
  caption: string;
  cta?: string;
  /** Public path to a real SOONA still; when absent the tile is a dark poster-TBD placeholder. */
  poster?: string;
  posterAlt?: string;
  /** Hardware-gated step: the primary stays grayed until an auto-detect check passes. */
  gated?: boolean;
  gatedLabel?: string;
}
const { moduleLabel, count, total, current, badge, headline, instr, instrHtml, caption, cta = "Next", poster, posterAlt, gated = false, gatedLabel = "" } = Astro.props;
const dots = Array.from({ length: total }, (_, i) => (i + 1 < current ? "done" : i + 1 === current ? "current" : ""));
const hasCheckpoint = Astro.slots.has("checkpoint");
---
<div class="content">
  <div class="prog-head">
    <div class="prog-row">
      <button class="back" aria-label="Back">‹</button>
      <span class="title">{moduleLabel}</span>
      <span class="count">{count}</span>
    </div>
    <div class="prog-dots" role="img" aria-label={count}>
      {dots.map((d) => <span class:list={["d", d]}></span>)}
    </div>
  </div>

  {/* video tile (auto-loops; NO "Watch again") */}
  <div class="video-tile">
    {poster && <img src={poster} alt={posterAlt ?? headline} />}
    <div class="scrim"></div>
    <button class="play" aria-label="Play step video">
      <svg width="18" height="18" viewBox="0 0 16 16"><path d="M5 3l9 5-9 5V3z" fill="#041E42"/></svg>
    </button>
    <span class="cap">{caption}</span>
    <span class="loop">
      <Icon name="loop" size={12} sw={2} />
      Auto-loops
    </span>
  </div>

  {/* step copy CENTERED at larger text; step badge tight above headline */}
  <div class="pad step-copy">
    <h1 class="title-1">{headline}</h1>
    {instrHtml ? (
      <p class="instr body muted" set:html={instrHtml} />
    ) : (
      <p class="instr body muted">{instr}</p>
    )}
    <slot />
  </div>

  {hasCheckpoint && !gated && (
    <div class="pad" style="margin-bottom:12px;">
      <slot name="checkpoint" />
    </div>
  )}

  {/* hardware-gated: auto-detect row flips Detecting → Detected, the button enables in sync */}
  {gated && (
    <div class="pad" style="margin-bottom:12px;">
      <div class="conn-row gate-row">
        <span class="lbl">{gatedLabel}</span>
        <span class="stat">
          <span class="gate-dot"></span>
          <span class="ok-txt gate-txt"><span class="t-wait">Detecting…</span><span class="t-done">Detected</span></span>
        </span>
      </div>
    </div>
  )}

  {/* primary — gated steps gray out until the hardware check passes */}
  <div class="pad" style="padding-bottom:28px;">
    <button class:list={["btn", "primary", gated && "gate-btn"]}>{cta}</button>
  </div>
</div>
