---
/**
 * StatusCard — top of Dashboard. Luna activity + active insulin.
 * `legacy` shows the pre-redesign look (used by the old-vs-new compare).
 */
interface Props {
  state?: string;
  activeInsulin?: string;
  legacy?: boolean;
}
const { state = "Active · watching overnight", activeInsulin = "1.2", legacy = false } = Astro.props;
---
<div class:list={["ios-status-card", { legacy }]}>
  <div class="ios-status-card-info" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7A8892" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 8h.01"/></svg>
  </div>
  <div class="ios-status-card-head">
    {!legacy && (
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12.5l2 2 4.5-5"/></svg>
    )}
    <div class="ios-status-card-title">Luna</div>
    <div class="ios-status-card-sub">{state}</div>
  </div>
  <div class="ios-status-card-foot">
    <span class="ios-status-card-iob">{activeInsulin} <span>U</span></span>
    <span class="ios-status-card-iob-label">active insulin</span>
  </div>
</div>
<style>
  .ios-status-card {
    position: relative;
    background: var(--color-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 22px 24px;
  }
  /* Legacy: square-ish card, no shadow, no brand check, left-aligned. */
  .ios-status-card.legacy {
    border-radius: 10px;
    box-shadow: none;
    border: 1px solid var(--color-border-default);
  }
  .ios-status-card-info { position: absolute; top: 16px; right: 16px; }
  .ios-status-card-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
  }
  .ios-status-card.legacy .ios-status-card-head { align-items: flex-start; text-align: left; }
  .ios-status-card-title { font-weight: 700; font-size: 17px; line-height: 1.2; }
  .ios-status-card-sub { font-size: 15px; color: var(--color-graphite); }
  .ios-status-card-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--color-pebble-blue);
  }
  .ios-status-card.legacy .ios-status-card-foot { justify-content: flex-start; }
  .ios-status-card-iob { font-weight: 700; font-size: 16px; }
  .ios-status-card-iob span { font-size: 12px; color: var(--color-graphite); font-weight: 400; }
  .ios-status-card-iob-label { font-size: 13px; color: var(--color-slate); }
</style>
