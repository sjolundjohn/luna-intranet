---
/**
 * CgmHero — the full-width overnight CGM graph (spine 01 hero). Right-side mg/dL
 * axis to 400, 70–180 target band, Amber 180 line, PLUM 70 critical-low line
 * (never red), Moonlight insulin-delivery ticks + legend, plain time x-axis.
 *
 * `trace` selects the glucose path: "inrange" (held in range) or "up" (drifting
 * up overnight — used by the Hypo Shield recommendation home). The gradient id
 * is per-instance so multiple graphs on one page (the gallery) don't collide.
 * Styling is the `.cgm-hero` kit in ios-spine.css.
 *
 * `fill` makes the graph grow to fill the available column space (the Home
 * layout pushes the insight bar to the bottom and lets the graph take the rest);
 * it stretches vertically via preserveAspectRatio="none".
 */
interface Props {
  trace?: "inrange" | "up";
  height?: number;
  fill?: boolean;
}
const { trace = "inrange", height = 180, fill: grow = false } = Astro.props;
const gid = "cgmFill-" + Math.random().toString(36).slice(2, 9);
const path =
  trace === "up"
    ? "M0,120 C40,112 67,104 99,100 S161,92 185,88 224,82 258,80 292,78 312,77"
    : "M0,126 C40,121 67,108 99,112 S161,123 185,114 224,98 258,107 292,111 312,110";
const fill = `${path} L312,165 L0,165 Z`;
---
<div class:list={["pad", "cgm-hero", grow && "cgm-hero--fill"]}>
  <svg viewBox="0 0 340 188" width="100%" height={grow ? undefined : height} preserveAspectRatio={grow ? "none" : undefined} aria-label="Overnight glucose with insulin deliveries">
    <defs>
      <linearGradient id={gid} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#68D2DF" stop-opacity="0.26" />
        <stop offset="1" stop-color="#68D2DF" stop-opacity="0" />
      </linearGradient>
    </defs>
    <g>
      <line class="grid" x1="0" y1="10" x2="312" y2="10" />
      <line class="grid" x1="0" y1="48.75" x2="312" y2="48.75" />
      <line class="grid" x1="0" y1="87.5" x2="312" y2="87.5" />
      <line class="grid" x1="0" y1="126.25" x2="312" y2="126.25" />
      <line class="grid" x1="0" y1="165" x2="312" y2="165" />
      <text class="ylab" x="340" y="13" text-anchor="end">400</text>
      <text class="ylab" x="340" y="52" text-anchor="end">300</text>
      <text class="ylab" x="340" y="91" text-anchor="end">200</text>
      <text class="ylab" x="340" y="129" text-anchor="end">100</text>
      <text class="ylab" x="340" y="168" text-anchor="end">0</text>
    </g>
    <rect x="0" y="95.3" width="312" height="59.1" fill="#68D2DF" opacity="0.08" />
    <line x1="0" y1="95.3" x2="312" y2="95.3" stroke="#F9CD86" stroke-width="1" stroke-dasharray="3 4" opacity="0.55" />
    <line x1="0" y1="154.4" x2="312" y2="154.4" stroke="#8E3655" stroke-width="1.4" stroke-dasharray="4 4" opacity="0.9" />
    <text x="4" y="151.5" text-anchor="start" font-size="8.5" fill="#8E3655" opacity="0.9">70 low</text>
    <path d={path} fill="none" stroke="#68D2DF" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
    <path d={fill} fill={`url(#${gid})`} />
    <g stroke="#68D2DF" stroke-width="2" stroke-linecap="round" opacity="0.95">
      <line x1="129" y1="154" x2="129" y2="164" />
      <line x1="175" y1="154" x2="175" y2="164" /><line x1="181" y1="154" x2="181" y2="164" />
      <line x1="221" y1="154" x2="221" y2="164" /><line x1="227" y1="154" x2="227" y2="164" /><line x1="233" y1="154" x2="233" y2="164" /><line x1="239" y1="154" x2="239" y2="164" />
    </g>
  </svg>
  <div class="cgm-axis">
    <span>10 PM</span><span>11 PM</span><span>12 AM</span><span>1 AM</span><span>2 AM</span><span>3 AM</span><span>4 AM</span>
  </div>
  <span class="cgm-legend"><span class="tick"></span>= Luna delivered insulin</span>
</div>
