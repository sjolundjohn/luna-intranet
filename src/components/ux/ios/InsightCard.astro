---
/**
 * InsightCard — white card, Moonlight icon, inline primary action.
 */
interface Props {
  title?: string;
  body?: string;
  cta?: string;
}
const {
  title = "A calmer night",
  body = "You spent 92% of last night in range. Luna made 3 quiet adjustments while you slept.",
  cta = "See the night",
} = Astro.props;
---
<div class="ios-insight">
  <span class="ios-insight-icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"/></svg>
  </span>
  <div class="ios-insight-body">
    <div class="ios-insight-title">{title}</div>
    <div class="ios-insight-text">{body}</div>
    <button type="button" class="ios-insight-cta">{cta}</button>
  </div>
</div>
<style>
  .ios-insight {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--color-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 24px;
  }
  .ios-insight-icon { flex: none; margin-top: 2px; }
  .ios-insight-body { flex: 1; min-width: 0; }
  .ios-insight-title { font-weight: 700; font-size: 17px; margin-bottom: 4px; }
  .ios-insight-text { font-size: 15px; color: var(--color-graphite); line-height: 1.45; }
  .ios-insight-cta {
    all: unset;
    display: block;
    text-align: center;
    background: var(--color-moonlight);
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    padding: 13px;
    border-radius: var(--radius-pill);
    margin-top: 18px;
    cursor: pointer;
  }
</style>
