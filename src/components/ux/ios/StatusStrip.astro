---
import Icon from "../Icon.astro";
/**
 * StatusStrip — the thin System · Long-acting · Reservoir · Battery row that
 * LEADS every Home surface (spine 01 + all hypo/iob home variants). The
 * Long-acting cell reminds the user of their current dose so changes are
 * always visible. Styling is the `.statusstrip` kit in ios-spine.css.
 */
interface Props {
  /** Current long-acting dose shown in the strip. */
  dose?: string;
}
const { dose = "12 U" } = Astro.props;
---
<div class="pad" style="padding-top:4px;">
  <div class="card-dark" style="padding:0;">
    <div class="statusstrip">
      <div class="item">
        <Icon name="check-circle" size={20} sw={1.8} color="#B0F9B3" />
        <span class="lbl"><span class="k">System</span><span class="v ok">Automating</span></span>
      </div>
      <div class="item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2s6 7 6 11a6 6 0 0 1-12 0c0-4 6-11 6-11z"/></svg>
        <span class="lbl"><span class="k">Long-acting</span><span class="v">{dose}</span></span>
      </div>
      <div class="item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#68D2DF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="3" width="10" height="18" rx="2"/><path d="M9 7h6M9 10h6M9 13h6"/></svg>
        <span class="lbl"><span class="k">Reservoir</span><span class="v">Full</span></span>
      </div>
      <div class="item">
        <svg width="22" height="14" viewBox="0 0 24 14" fill="none"><rect x="0.5" y="1" width="20" height="12" rx="3" stroke="#68D2DF"/><rect x="2.5" y="3" width="15" height="8" rx="1.5" fill="#68D2DF"/><rect x="21.5" y="5" width="1.8" height="4" rx="0.9" fill="#68D2DF"/></svg>
        <span class="lbl"><span class="k">Battery</span><span class="v">86%</span></span>
      </div>
    </div>
  </div>
</div>
