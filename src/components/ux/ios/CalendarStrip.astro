---
/**
 * CalendarStrip — Session History week strip. Selected day = Moonlight fill.
 */
interface Props {
  selected?: number;
}
const { selected = 22 } = Astro.props;
const days = [
  { d: "Su", n: 18 },
  { d: "Mo", n: 19 },
  { d: "Tu", n: 20 },
  { d: "We", n: 21 },
  { d: "Th", n: 22 },
  { d: "Fr", n: 23 },
  { d: "Sa", n: 24 },
];
---
<div class="ios-calstrip">
  {days.map((day) => (
    <div class="ios-calstrip-day">
      <span class="ios-calstrip-dow">{day.d}</span>
      <span class="ios-calstrip-num" data-sel={day.n === selected ? "true" : undefined}>{day.n}</span>
    </div>
  ))}
</div>
<style>
  .ios-calstrip {
    background: var(--color-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 16px 12px;
    display: flex;
    justify-content: space-between;
  }
  .ios-calstrip-day { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .ios-calstrip-dow { font-size: 12px; color: var(--color-slate); }
  .ios-calstrip-num {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 400;
    color: var(--color-midnight);
  }
  .ios-calstrip-num[data-sel] {
    font-weight: 700;
    background: var(--color-moonlight);
    color: #fff;
  }
</style>
