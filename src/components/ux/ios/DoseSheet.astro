---
/**
 * DoseSheet — the canonical two-step Dose-Confirmation bottom sheet.
 * Ported from projects/UX Review/dose-confirmation/index.html (vanilla).
 *
 * Acting on a long-acting dose suggestion requires BOTH: take the new dose
 * yourself AND allow Luna to auto-adjust the setting going forward. Both
 * acknowledgements gate a single Confirm button (no Settings trip). `variant`
 * selects one of the states; the IOB opt-in still uses the slide gesture.
 *
 * The button/slider + ack toggles are wired per-instance (scoped to
 * [data-dose-root]) so multiple sheets can coexist (e.g. the old-vs-new compare).
 */
interface Props {
  variant?: "increase" | "decrease" | "nochange" | "reset" | "disabled" | "skip" | "optin";
  value?: number;
  prev?: number;
  unit?: string;
}
const { variant = "increase", value = 14, prev = 12, unit = "U" } = Astro.props;

const isRec = variant === "increase" || variant === "decrease";
const dir = variant === "increase" ? "up" : "down";
const word = dir === "up" ? "Increase" : "Decrease";
const rationale =
  variant === "increase"
    ? "Hypo Shield has observed your glucose drifting up overnight, which may mean you need a bit more of your long-acting insulin."
    : "Hypo Shield has observed your glucose drifting low overnight, which may mean you need a bit less of your long-acting insulin.";

const ICONS: Record<string, string> = {
  up: "M12 19V5M5 12l7-7 7 7",
  down: "M12 5v14M19 12l-7 7-7-7",
  arrowRight: "M5 12h14M13 5l7 7-7 7",
  pause: "M10 4H6v16h4zM18 4h-4v16h4z",
  minus: "M5 12h14",
  info: "M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM12 16v-4M12 8h.01",
  check: "M20 6L9 17l-5-5",
};
function icon(name: string, size = 18, color = "currentColor", sw = 1.5) {
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="${sw}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${ICONS[name]}"/></svg>`;
}
---
<div class="dose-sheet" data-dose-root data-variant={variant}>
  <div class="dose-grabber"></div>
  <div class="dose-hdr">
    <div class="dose-moon" aria-hidden="true"></div>
    <span class="dose-eyebrow">{variant === "optin" ? "IOB Display · Insight" : "Hypo Shield"}</span>
  </div>

  {variant === "optin" && (
    <Fragment>
      <h2 class="dose-h2">Turn on insulin on board?</h2>
      <p class="dose-rationale">Luna can show your <strong>insulin on board (IOB)</strong> — how much of your Luna-delivered insulin is still active — during a session and as a residual amount after. It's decision support to help you avoid stacking.</p>
      <div class="dose-ackbox">
        <div class="dose-ackbox-h">Before you turn it on, confirm you understand</div>
        <button class="dose-ack" data-ack="1" role="checkbox" aria-checked="false">
          <span class="dose-box"></span>
          <span><span class="dose-lbl">This number considers Luna-delivered insulin only</span><br /><span class="dose-sub">Not insulin you deliver outside Luna</span></span>
        </button>
        <div class="dose-ackdiv"></div>
        <button class="dose-ack" data-ack="2" role="checkbox" aria-checked="false">
          <span class="dose-box"></span>
          <span><span class="dose-lbl">It's information, not an instruction</span><br /><span class="dose-sub">Luna won't change or deliver a dose based on it</span></span>
        </button>
      </div>
      <button class="dose-btn primary" data-confirm-btn data-proto-to="iob-home-on" disabled>Turn on insulin on board</button>
      <div class="dose-hint" data-confirm-hint set:html={`${icon("info", 14, "var(--color-slate)")} Confirm both above to continue`} />
      <button class="dose-btn secondary" type="button" style="margin-top:10px;" data-proto-to="home-dashboard">Not now</button>
    </Fragment>
  )}

  {isRec && (
    <Fragment>
      <h2 class="dose-h2">A new long-acting dose</h2>
      <div class="dose-valrow">
        <span class="dose-val">{value}</span>
        <span class="dose-unit">{unit}</span>
        <span class="dose-chip" set:html={`${icon(dir, 15, "var(--color-moonlight-deep)", 2.2)} ${word} your long-acting dose`} />
      </div>
      <div class="dose-prev">Current dose <s>{prev} {unit}</s></div>
      <p class="dose-rationale">{rationale}</p>
      <div class="dose-ackbox">
        <div class="dose-ackbox-h">Confirm both to continue</div>
        <button class="dose-ack" data-ack="1" role="checkbox" aria-checked="false">
          <span class="dose-box"></span>
          <span><span class="dose-lbl">Take {value} units of your long-acting dose the next time you take your dose</span></span>
        </button>
        <div class="dose-ackdiv"></div>
        <button class="dose-ack" data-ack="2" role="checkbox" aria-checked="false">
          <span class="dose-box"></span>
          <span><span class="dose-lbl">Allow Luna to automatically update your long-acting insulin settings in the app.</span></span>
        </button>
      </div>
      <button class="dose-btn primary" data-confirm-btn data-proto-to="hypo-confirm-success" disabled>Confirm changes</button>
      <div class="dose-hint" data-confirm-hint set:html={`${icon("info", 14, "var(--color-slate)")} Confirm both above to continue`} />
      {/* Not now → back to Home with the Hypo Shield card minimized (still there
          to review later) — the suggestion-ready peek. */}
      <button class="dose-btn secondary" type="button" style="margin-top:10px;" data-proto-to="hypo-home-tip-post">Not now</button>
    </Fragment>
  )}

  {variant === "nochange" && (
    <Fragment>
      <div class="dose-check-circle" set:html={icon("check", 26, "var(--color-success-ink)", 2.2)} />
      <h2 class="dose-h2">No change needed tonight</h2>
      <p class="dose-rationale">Your current dose seems appropriate for your body's needs. Luna will continue to observe and inform you if this changes.</p>
      <div class="dose-prev">Current dose holding at <strong style="color:var(--color-ink)">{value} {unit}</strong></div>
      <button class="dose-btn primary">Got it</button>
    </Fragment>
  )}

  {variant === "reset" && (
    <Fragment>
      <div class="dose-banner info" set:html={`${icon("pause", 15, "currentColor", 2)} Recommendations paused`} />
      <h2 class="dose-h2">Luna is re-learning your nights</h2>
      <p class="dose-rationale">Your long-acting dose setting changed, so Luna reset its learning. Hypo Shield is paused until Luna has observed enough of your nights again.</p>
      <div class="dose-metricbox">
        <div class="dose-metric"><span class="dose-metric-l">Luna sessions observed</span><span class="dose-metric-v">2 of 5</span></div>
        <div class="dose-metricdiv"></div>
        <div class="dose-metric"><span class="dose-metric-l">Days of wear</span><span class="dose-metric-v">3 of 7</span></div>
      </div>
      <button class="dose-btn primary">Got it</button>
    </Fragment>
  )}

  {variant === "disabled" && (
    <Fragment>
      <div class="dose-banner neutral" set:html={`${icon("minus", 15, "currentColor", 2)} Hypo Shield off`} />
      <h2 class="dose-h2">Hypo Shield isn't on for you</h2>
      <p class="dose-rationale">Your care setup doesn't include Luna basal dose recommendations. Luna keeps monitoring overnight, but won't suggest dose changes. Talk to your care team if you think this should change.</p>
      <button class="dose-btn secondary">Close</button>
    </Fragment>
  )}

  {variant === "skip" && (
    <Fragment>
      <div class="dose-banner critical" set:html={`${icon("info", 15, "currentColor", 2)} Confirm you're skipping`} />
      <h2 class="dose-h2">Skip the increase to {value} {unit}?</h2>
      <p class="dose-rationale">Your long-acting dose stays where it is and you take your usual dose tonight. Luna will keep this suggestion in mind and may offer it again.</p>
      <div class="dose-stack">
        <button class="dose-btn primary">Skip this recommendation</button>
        <button class="dose-btn ghost">Back</button>
      </div>
    </Fragment>
  )}
</div>

<style>
  .dose-sheet { background: var(--color-white); border-top-left-radius: 28px; border-top-right-radius: 28px; padding: 14px 26px 30px; box-shadow: 0 -8px 40px rgba(4,30,66,0.18); font-family: var(--ios-font-brand); max-height: 100%; overflow-y: auto; scrollbar-width: none; }
  .dose-sheet::-webkit-scrollbar { width: 0; display: none; }
  .dose-grabber { width: 40px; height: 5px; border-radius: 999px; background: var(--color-lunar-lavender); margin: 0 auto 18px; }
  .dose-hdr { display: flex; align-items: center; gap: 9px; margin-bottom: 18px; }
  .dose-moon { width: 24px; height: 24px; border-radius: 50%; background: var(--color-midnight); position: relative; overflow: hidden; flex: none; }
  .dose-moon::before { content:""; position:absolute; right:-5px; top:4.5px; width:15px; height:15px; border-radius:50%; background: var(--color-moonlight); }
  .dose-moon::after { content:""; position:absolute; right:-1px; top:6.5px; width:11px; height:11px; border-radius:50%; background: var(--color-midnight); }
  .dose-eyebrow { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-slate); }
  .dose-h2 { margin: 0 0 16px; font-size: 22px; font-weight: 700; letter-spacing: -0.01em; color: var(--color-ink); line-height: 1.25; }
  .dose-valrow { display: flex; align-items: baseline; gap: 12px; margin-bottom: 8px; }
  .dose-val { font-family: var(--ios-font-brand); font-size: 34px; font-weight: 700; line-height: 0.95; letter-spacing: -0.03em; color: var(--color-midnight); }
  .dose-unit { font-size: 28px; font-weight: 700; color: var(--color-midnight); letter-spacing: -0.01em; }
  .dose-chip { display: inline-flex; align-items: center; gap: 5px; padding: 5px 11px 5px 9px; border-radius: 8px; background: var(--color-moonlight-tint); color: var(--color-moonlight-deep); font-size: 13px; font-weight: 600; }
  .dose-prev { font-size: 13px; color: var(--color-slate); margin-bottom: 18px; }
  .dose-prev s { text-decoration: line-through; }
  .dose-rationale { margin: 0 0 22px; font-size: 15px; line-height: 1.55; color: var(--color-graphite); max-width: 60ch; }
  .dose-ackbox { background: var(--color-cloud-lilac); border-radius: 20px; padding: 16px 18px 14px; margin-bottom: 20px; }
  .dose-ackbox-h { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-graphite); margin-bottom: 4px; }
  .dose-ack { display: flex; align-items: flex-start; gap: 14px; width: 100%; min-height: 44px; padding: 10px 4px; background: none; border: none; text-align: left; cursor: pointer; font: inherit; }
  .dose-box { width: 26px; height: 26px; flex: none; margin-top: 1px; border-radius: 8px; border: 1.5px solid var(--color-border-strong); background: var(--color-white); display: flex; align-items: center; justify-content: center; transition: background 160ms; }
  .dose-ack[aria-checked="true"] .dose-box { border: none; background: var(--color-midnight); }
  .dose-lbl { font-size: 15px; font-weight: 600; line-height: 1.4; color: var(--color-ink); }
  .dose-sub { font-size: 13px; line-height: 1.4; color: var(--color-slate); }
  .dose-ackdiv { height: 1px; background: var(--color-border-subtle); margin: 2px 0 2px 40px; }
  .dose-slide { display: flex; flex-direction: column; gap: 8px; }
  .dose-track { position: relative; height: 60px; border-radius: 999px; background: var(--color-cloud-lilac); overflow: hidden; user-select: none; touch-action: none; }
  .dose-track.enabled { background: var(--color-periwinkle-mist); }
  .dose-track.done { background: var(--color-success-bg); }
  .dose-trail { position: absolute; left: 0; top: 0; bottom: 0; width: 30px; background: var(--color-moonlight-ice); }
  .dose-track.done .dose-trail { background: var(--color-success-fill); }
  .dose-tlabel { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: 8px; pointer-events: none; font-size: 15px; font-weight: 600; color: var(--color-disabled); }
  .dose-track.enabled .dose-tlabel { color: var(--color-midnight); }
  .dose-track.done .dose-tlabel { color: var(--color-success-ink); }
  .dose-thumb { position: absolute; top: 4px; left: 4px; width: 52px; height: 52px; border-radius: 50%; background: var(--color-white); border: 1px solid var(--color-border-default); display: flex; align-items: center; justify-content: center; }
  .dose-track.enabled .dose-thumb { background: var(--color-midnight); border: none; box-shadow: 0 2px 8px rgba(4,30,66,0.20); cursor: grab; }
  .dose-track.done .dose-thumb { background: var(--color-success-ink); border: none; }
  .dose-hint { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--color-slate); padding-left: 4px; }
  .dose-skip { display:flex; justify-content:center; margin-top:16px; }
  .dose-skip button { background:none; border:none; font:inherit; cursor:pointer; font-size:15px; font-weight:600; color:var(--color-slate); padding:8px 16px; }
  .dose-banner { display: inline-flex; align-items: center; gap: 7px; padding: 6px 13px 6px 11px; border-radius: 999px; margin-bottom: 16px; font-size: 12px; font-weight: 600; }
  .dose-banner.info { background: var(--color-info-bg); color: var(--color-info-ink); }
  .dose-banner.neutral { background: var(--color-cloud-lilac); color: var(--color-graphite); }
  .dose-banner.critical { background: var(--color-critical-bg); color: var(--color-critical-ink); }
  .dose-btn { width: 100%; height: 54px; border-radius: 28px; font: inherit; font-size: 16px; font-weight: 600; cursor: pointer; border: none; }
  .dose-btn.primary { background: var(--color-midnight); color: var(--color-white); box-shadow: 0 2px 8px rgba(4,30,66,0.20); }
  .dose-btn.secondary { background: transparent; color: var(--color-ink); border: 1px solid var(--color-border-strong); }
  .dose-btn.ghost { background: transparent; color: var(--color-slate); }
  .dose-btn[disabled] { background: var(--color-cloud-lilac); color: var(--color-disabled); box-shadow: none; cursor: not-allowed; }
  .dose-btn.done { background: var(--color-success-ink); color: var(--color-white); }
  .dose-hint[data-confirm-hint] { justify-content: center; margin-top: 10px; }
  .dose-check-circle { display:flex; align-items:center; justify-content:center; width:52px; height:52px; border-radius:50%; background:var(--color-success-bg); margin-bottom:18px; }
  .dose-metric { display:flex; justify-content:space-between; align-items:baseline; }
  .dose-metric-l { font-size:15px; color:var(--color-graphite); }
  .dose-metric-v { font-size:15px; font-weight:700; color:var(--color-ink); font-variant-numeric:tabular-nums; }
  .dose-metricbox { background:var(--color-cloud-lilac); border-radius:20px; padding:14px 18px; margin-bottom:24px; display:flex; flex-direction:column; gap:10px; }
  .dose-metricdiv { height:1px; background:var(--color-border-subtle); }
  .dose-stack { display:flex; flex-direction:column; gap:10px; }
</style>

<script>
  const ICON = {
    arrowRight: "M5 12h14M13 5l7 7-7 7",
    check: "M20 6L9 17l-5-5",
    info: "M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM12 16v-4M12 8h.01",
  };
  function svg(name: keyof typeof ICON, size = 18, color = "currentColor", sw = 1.5) {
    return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="${sw}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="${ICON[name]}"/></svg>`;
  }

  // The IOB opt-in keeps the slide-to-turn-on gesture; the dose-confirmation
  // (increase/decrease) now uses two checkboxes + a single Confirm button —
  // consistent with the app's other confirmatory buttons (team feedback).
  function wireButton(root: HTMLElement) {
    if (root.dataset.doseWired) return;
    root.dataset.doseWired = "true";
    const ack1 = root.querySelector<HTMLElement>('[data-ack="1"]')!;
    const ack2 = root.querySelector<HTMLElement>('[data-ack="2"]')!;
    const btn = root.querySelector<HTMLButtonElement>("[data-confirm-btn]")!;
    const hint = root.querySelector<HTMLElement>("[data-confirm-hint]");
    if (!ack1 || !ack2 || !btn) return;
    let s1 = false, s2 = false, done = false;
    function paint() {
      const both = s1 && s2;
      btn.disabled = !both || done;
      if (hint) hint.style.display = both || done ? "none" : "flex";
      if (done) { btn.textContent = "Confirmed"; btn.classList.add("done"); }
    }
    function toggle(b: HTMLElement, which: 1 | 2) {
      b.addEventListener("click", () => {
        if (done) return;
        if (which === 1) s1 = !s1; else s2 = !s2;
        const on = which === 1 ? s1 : s2;
        b.setAttribute("aria-checked", on ? "true" : "false");
        const box = b.querySelector(".dose-box")!;
        box.innerHTML = on ? svg("check", 16, "var(--color-moonlight)", 2.4) : "";
        paint();
      });
    }
    toggle(ack1, 1);
    toggle(ack2, 2);
    btn.addEventListener("click", () => { if (btn.disabled) return; done = true; paint(); });
    paint();
  }

  function init() {
    document.querySelectorAll<HTMLElement>("[data-dose-root]").forEach((r) => {
      const v = r.dataset.variant;
      if (v === "optin" || v === "increase" || v === "decrease") wireButton(r);
    });
  }
  init();
  document.addEventListener("astro:page-load", init);
</script>
