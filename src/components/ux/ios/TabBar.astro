---
/**
 * TabBar — bottom navigation. Dashboard · History · Settings.
 * `active` selects the Moonlight-tinted tab.
 */
interface Props {
  active?: "dashboard" | "history" | "settings";
}
const { active = "dashboard" } = Astro.props;
const tabs = [
  { id: "dashboard", label: "Dashboard", path: "M3 11l9-8 9 8M5 10v10h14V10" },
  { id: "history", label: "History", path: "M12 8v4l3 2 M21 12a9 9 0 1 1-9-9" },
  { id: "settings", label: "Settings", path: "M12 15a3 3 0 100-6 3 3 0 000 6z M19 12a7 7 0 00-.1-1l2-1.6-2-3.4-2.4 1a7 7 0 00-1.7-1l-.4-2.5H10l-.4 2.5a7 7 0 00-1.7 1l-2.4-1-2 3.4 2 1.6a7 7 0 000 2l-2 1.6 2 3.4 2.4-1a7 7 0 001.7 1l.4 2.5h3.8l.4-2.5a7 7 0 001.7-1l2.4 1 2-3.4-2-1.6a7 7 0 00.1-1z" },
] as const;
---
<nav class="ios-tabbar" aria-label="Tabs">
  {tabs.map((t) => (
    <div class="ios-tab" data-active={t.id === active ? "true" : undefined}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="${t.path}"/>`} />
      <span>{t.label}</span>
    </div>
  ))}
</nav>
<style>
  .ios-tabbar {
    display: flex;
    background: var(--color-white);
    padding: 10px 8px calc(10px + env(safe-area-inset-bottom, 14px));
    border-top: 1px solid var(--color-border-subtle);
  }
  .ios-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: var(--color-slate);
    font-family: var(--ios-font-brand);
    font-size: 11px;
    font-weight: 400;
  }
  .ios-tab[data-active] {
    color: var(--color-moonlight);
    font-weight: 700;
  }
</style>
