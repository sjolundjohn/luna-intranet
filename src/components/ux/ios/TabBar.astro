---
/**
 * TabBar — the locked bottom navigation: Dashboard · Session History ·
 * Settings. Active tab uses Moonlight + aria-current="page"; inactive uses
 * on-dark-sub. Styling comes from the shared `.tabbar`/`.tab` kit classes
 * in ios-spine.css; markup lifted verbatim from the spine archetypes
 * (01/05/07). Only the three tab-root screens render this; flow screens omit it.
 */
interface Props {
  active: "dashboard" | "session-history" | "settings";
}
const { active } = Astro.props;
const isDash = active === "dashboard";
const isHist = active === "session-history";
const isSet = active === "settings";
---
<nav class="tabbar" aria-label="Primary">
  <button class:list={["tab", isDash && "active"]} aria-current={isDash ? "page" : undefined}>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isDash ? 1.8 : 1.6} stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8M5 10v10h14V10"/></svg>
    <span>Dashboard</span>
  </button>
  <button class:list={["tab", isHist && "active"]} aria-current={isHist ? "page" : undefined}>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isHist ? 1.8 : 1.6} stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 2M21 12a9 9 0 1 1-9-9"/></svg>
    <span>Session History</span>
  </button>
  <button class:list={["tab", isSet && "active"]} aria-current={isSet ? "page" : undefined}>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isSet ? 1.8 : 1.6} stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19 12a7 7 0 0 0-.1-1l2-1.6-2-3.4-2.4 1a7 7 0 0 0-1.7-1l-.4-2.5H10l-.4 2.5a7 7 0 0 0-1.7 1l-2.4-1-2 3.4 2 1.6a7 7 0 0 0 0 2l-2 1.6 2 3.4 2.4-1a7 7 0 0 0 1.7 1l.4 2.5h3.8l.4-2.5a7 7 0 0 0 1.7-1l2.4 1 2-3.4-2-1.6a7 7 0 0 0 .1-1z"/></svg>
    <span>Settings</span>
  </button>
</nav>
