---
/**
 * CompareSlider — old-vs-new overlay for `status === "Changed"` screens.
 * Two layers stacked; the "after" (current) layer is clipped at a draggable
 * divider, revealing the "before" (legacy) layer behind it. Provide both via
 * the `legacy` and `current` named slots (identically sized Phone frames).
 */
---
<div class="cmp" data-compare style="--x:50%;">
  <div class="cmp-layer cmp-legacy">
    <slot name="legacy" />
    <span class="cmp-tag cmp-tag-before">Before</span>
  </div>
  <div class="cmp-layer cmp-current" data-cmp-current>
    <slot name="current" />
    <span class="cmp-tag cmp-tag-after">After</span>
  </div>
  <div class="cmp-divider" data-cmp-divider>
    <button class="cmp-handle" type="button" aria-label="Drag to compare before and after">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7l-4 5 4 5M16 7l4 5-4 5"/></svg>
    </button>
  </div>
</div>
<style>
  .cmp { position: relative; display: inline-block; user-select: none; touch-action: none; }
  .cmp-layer { top: 0; left: 0; }
  .cmp-legacy { position: absolute; inset: 0; }
  .cmp-current { position: relative; clip-path: inset(0 calc(100% - var(--x)) 0 0); }
  /* Frames are static in compare mode — only the divider is interactive. */
  .cmp-legacy :global([data-ux-phone]),
  .cmp-current :global([data-ux-phone]) { pointer-events: none; }
  .cmp-tag {
    position: absolute;
    top: 14px;
    z-index: 5;
    padding: 3px 9px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cmp-tag-before { right: 14px; background: var(--color-periwinkle-mist); color: var(--color-graphite); }
  .cmp-tag-after { left: 14px; background: var(--color-moonlight); color: var(--color-midnight); }
  .cmp-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--x);
    width: 2px;
    background: var(--color-moonlight);
    z-index: 6;
    transform: translateX(-1px);
  }
  .cmp-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 2px solid var(--color-moonlight);
    background: #fff;
    color: var(--color-midnight);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: ew-resize;
    box-shadow: 0 2px 8px rgba(4, 30, 66, 0.2);
  }
</style>
<script>
  function wireCompare(el: HTMLElement) {
    if (el.dataset.cmpWired) return;
    el.dataset.cmpWired = "true";
    const handle = el.querySelector<HTMLElement>(".cmp-handle")!;
    let dragging = false;

    function setFromClientX(clientX: number) {
      const r = el.getBoundingClientRect();
      const x = Math.max(0, Math.min(r.width, clientX - r.left));
      el.style.setProperty("--x", `${x}px`);
    }
    handle.addEventListener("pointerdown", (e) => {
      dragging = true;
      handle.setPointerCapture(e.pointerId);
      e.preventDefault();
    });
    window.addEventListener("pointermove", (e) => { if (dragging) setFromClientX(e.clientX); });
    window.addEventListener("pointerup", () => { dragging = false; });
    handle.addEventListener("keydown", (e) => {
      const r = el.getBoundingClientRect();
      const cur = parseFloat(getComputedStyle(el).getPropertyValue("--x")) || r.width / 2;
      const step = r.width * 0.05;
      if (e.key === "ArrowLeft") { el.style.setProperty("--x", `${Math.max(0, cur - step)}px`); e.preventDefault(); }
      if (e.key === "ArrowRight") { el.style.setProperty("--x", `${Math.min(r.width, cur + step)}px`); e.preventDefault(); }
    });
  }
  function init() {
    document.querySelectorAll<HTMLElement>("[data-compare]").forEach(wireCompare);
  }
  init();
  document.addEventListener("astro:page-load", init);
</script>
