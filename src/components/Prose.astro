---
/**
 * MDX wrapper. Applies the v1.0 typography scale to long-form content:
 *   H1 Inter 32/700 · H2 Inter 28/700 · H3 Inter 20/600
 *   Body Inter 17/1.6 · eyebrow Inter 11/600 uppercase
 * Headings in Ink, body in Graphite, links underlined in Moonlight.
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["luna-prose", className]}>
  <slot />
</div>

<style is:global>
  .luna-prose {
    color: var(--color-graphite);
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    max-width: 65ch;
  }
  .luna-prose > * + * {
    margin-top: 1.25em;
  }

  .luna-prose h1,
  .luna-prose h2,
  .luna-prose h3,
  .luna-prose h4 {
    color: var(--color-ink);
    font-family: var(--font-body);
    letter-spacing: -0.01em;
  }
  .luna-prose h1 {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.15;
    margin-top: 2em;
  }
  .luna-prose h2 {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.2;
    margin-top: 2em;
  }
  .luna-prose h3 {
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 1.75em;
  }
  .luna-prose h2:first-child,
  .luna-prose h1:first-child {
    margin-top: 0;
  }

  .luna-prose a {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-moonlight);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    transition: color 160ms ease-out;
  }
  .luna-prose a:hover {
    color: var(--color-moonlight-deep);
  }

  .luna-prose strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .luna-prose ul,
  .luna-prose ol {
    padding-left: 1.5em;
  }
  .luna-prose ul {
    list-style: none;
  }
  .luna-prose ul > li {
    position: relative;
    padding-left: 0.25em;
  }
  .luna-prose ul > li::before {
    content: "";
    position: absolute;
    left: -1em;
    top: 0.7em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-moonlight);
  }
  .luna-prose ol {
    list-style: decimal;
  }
  .luna-prose li + li {
    margin-top: 0.5em;
  }

  .luna-prose blockquote {
    border-left: 2px solid var(--color-moonlight);
    padding-left: 1em;
    color: var(--color-ink);
    font-style: normal;
  }

  .luna-prose code {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    padding: 0.1em 0.4em;
    background: var(--color-cloud-lilac);
    border-radius: 4px;
    color: var(--color-ink);
  }
  .luna-prose pre {
    background: var(--color-midnight);
    color: var(--color-white);
    padding: 1.25em 1.5em;
    border-radius: 12px;
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.6;
  }
  .luna-prose pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .luna-prose hr {
    border: none;
    height: 2px;
    width: 48px;
    background: var(--color-moonlight);
    margin: 3em 0;
  }

  .luna-prose img {
    border-radius: 12px;
  }
</style>
