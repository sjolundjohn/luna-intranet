---
/**
 * Midnight hero. Gradient background (#133465 → #031632). Big D-DIN headline,
 * Inter sub-copy, Moonlight 2px rule. Generous vertical padding per v1.0.
 */
import MoonlightRule from "~/components/MoonlightRule.astro";
import MoonPhases from "~/components/MoonPhases.astro";

interface Props {
  /** Optional overline above headline (e.g. "LUNA · INTERNAL"). */
  eyebrow?: string;
  /** Scale the hero's vertical space: "full" ≈ 80vh, "tall" ≈ 65vh, "compact" ≈ 50vh. */
  size?: "full" | "tall" | "compact";
  /** Animate the moon phases in the corner. */
  animateMoons?: boolean;
}

const { eyebrow, size = "full", animateMoons = true } = Astro.props;

const padding: Record<NonNullable<Props["size"]>, string> = {
  "full":    "pt-32 pb-28 md:pt-40 md:pb-36 min-h-[80vh]",
  "tall":    "pt-28 pb-24 md:pt-36 md:pb-28 min-h-[65vh]",
  "compact": "pt-24 pb-20 md:pt-28 md:pb-24 min-h-[50vh]",
};
---

<section
  class:list={[
    "relative bg-hero-gradient text-white overflow-hidden",
    padding[size],
  ]}
>
  {/* Subtle starfield — pure CSS dots, no external image. */}
  <div class="pointer-events-none absolute inset-0 starfield opacity-60" aria-hidden="true"></div>

  <div class="relative mx-auto w-full max-w-[1200px] px-6 md:px-10">
    {
      eyebrow && (
        <p class="eyebrow eyebrow-on-dark mb-6" transition:name="hero-eyebrow">
          {eyebrow}
        </p>
      )
    }

    <h1
      class="font-display text-white font-normal"
      style="font-size: clamp(48px, 8vw, 96px); line-height: 1.02; letter-spacing: -0.025em;"
      transition:name="hero-title"
    >
      <slot name="headline" />
    </h1>

    <div class="mt-6 max-w-[620px] text-[18px] md:text-[20px] leading-[1.55] text-white/72">
      <slot name="subcopy" />
    </div>

    <div class="mt-8">
      <MoonlightRule width={48} />
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      <slot name="cta" />
    </div>
  </div>

  {/* decorative moon phases bottom-right */}
  <div class="pointer-events-none absolute right-6 bottom-6 md:right-10 md:bottom-10 opacity-80">
    <MoonPhases size={20} gap={10} class="text-moonlight" animate={animateMoons} />
  </div>
</section>

<style>
  .starfield {
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255, 255, 255, 0.55), transparent 50%),
      radial-gradient(1.5px 1.5px at 25% 60%, rgba(201, 248, 254, 0.5), transparent 50%),
      radial-gradient(1px 1px at 40% 15%, rgba(255, 255, 255, 0.4), transparent 50%),
      radial-gradient(1px 1px at 55% 78%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1.5px 1.5px at 70% 30%, rgba(201, 248, 254, 0.45), transparent 50%),
      radial-gradient(1px 1px at 85% 55%, rgba(255, 255, 255, 0.4), transparent 50%),
      radial-gradient(1px 1px at 92% 12%, rgba(255, 255, 255, 0.4), transparent 50%),
      radial-gradient(1px 1px at 15% 85%, rgba(255, 255, 255, 0.3), transparent 50%),
      radial-gradient(1.5px 1.5px at 35% 42%, rgba(104, 210, 223, 0.35), transparent 50%),
      radial-gradient(1px 1px at 65% 8%, rgba(255, 255, 255, 0.4), transparent 50%);
  }
</style>
